<UserControl x:Class="Rift_App.Library.Library"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Library"
             mc:Ignorable="d"
             d:Height="1000"
             d:Width="1200">

    <Grid>
        <Border Grid.Row="0"
                Background="#1A2636"
                CornerRadius="0,0,7.5,7.5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="GuestPanel"
                      Visibility="Collapsed">
                    <TextBlock Text="You are browsing as a guest. Sign in to see your games." />
                </Grid>
                
                <Grid Grid.Row="1"
                      Grid.Column="0">
                    <ScrollViewer Background="#22272E"
                                  x:Name="MyScrollViewer"
                                  Width="Auto">

                        <StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Stretch"
                                        Height="30">
                                <StackPanel.Background>
                                    <LinearGradientBrush EndPoint="1,0"
                                                         StartPoint="0,0"
                                                         Opacity="0.1">
                                        <GradientStop Color="#6F88B0"
                                                      Offset="0.361" />
                                        <GradientStop Color="Transparent"
                                                      Offset="0.95" />
                                    </LinearGradientBrush>
                                </StackPanel.Background>

                                <materialIcons:MaterialIcon Kind="HorizontalLine"
                                                            Foreground="#A7BDD1"
                                                            Height="1.5"
                                                            Width="20" />

                                <TextBlock  Text="ALL"
                                            FontSize="14"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                            Foreground="#A7BDD1" />

                                <TextBlock Text="(60/61)"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                           Foreground="#525762"
                                           Margin="5,0,0,0" />
                            </StackPanel>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0"
                                            x:Name="GamesPanel">
                                    <ItemsControl ItemsSource="{Binding Games}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <Button Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        Height="23">
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Center"
                                                                Width="235"
                                                                Height="22"
                                                                Margin="0">
                                                        <Image Height="20"
                                                               Width="20"
                                                               Margin="5,0,0,0"
                                                               Source="{Binding IconPath}"
                                                               Stretch="UniformToFill"
                                                               VerticalAlignment="Bottom" />
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="#9197A5"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                                   Margin="6,0,0,0" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>



                <ScrollViewer Background="#22272E"
