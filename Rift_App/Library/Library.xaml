                                                            FontSize="14"
                                                            FontFamily="Arial" />

                                                <TextBlock  Text="Mar 21"
                                                            Margin="2,3,0,0"
                                                            FontSize="13.2"
                                                            FontWeight="Medium"
                                                            Foreground="#92969C"
                                                            FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal"
                                                        Margin="35,17,0,0">

                                                <materialIcons:MaterialIcon Kind="ClockOutline"
                                                                            Width="25"
                                                                            Height="25"
                                                                            Margin="0,-10,0,0"
