                                                    <GradientStop Color="#3CB031"
                                                                  Offset="1" />

                                                </LinearGradientBrush>

                                            </Button.Background>

                                            <StackPanel Orientation="Horizontal">

                                                <materialIcons:MaterialIcon Kind="Play"
                                                                            Margin="0,0,11,0"
                                                                            Foreground="White"
                                                                            Opacity="0.75"
                                                                            Height="17"
                                                                            Width="17" />

                                                <TextBlock Text="PLAY"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,2,0"
                                                           Foreground="White"
                                                           FontSize="22"
                                                           FontWeight="Regular"
                                                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />

                                            </StackPanel>
                                        </Button>

                                        <StackPanel Orientation="Vertical"
