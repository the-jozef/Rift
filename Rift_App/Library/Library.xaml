<UserControl x:Class="Rift_App.Library.Library"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Library"
             mc:Ignorable="d"
             d:Height="1000"
             d:Width="1000">

    <Grid>
        <Border Grid.Row="0"
                Background="{StaticResource RiftStoreBackground}"
                CornerRadius="0,0,7.5,7.5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="1"
                      Grid.Column="0">
                    <ScrollViewer Background="#22272E"
                                  x:Name="MyScrollViewer"                     
                                  Width="Auto">

                        <StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Stretch"
                                        Height="30">
                                <StackPanel.Background>
                                    <LinearGradientBrush EndPoint="1,0"
                                                         StartPoint="0,0"
                                                         Opacity="0.1">
                                        <GradientStop Color="#6F88B0"
                                                      Offset="0.361" />
                                        <GradientStop Color="Transparent"
                                                      Offset="0.95" />
                                    </LinearGradientBrush>
                                </StackPanel.Background>

                                <materialIcons:MaterialIcon Kind="HorizontalLine"
                                                            Foreground="#A7BDD1"
                                                            Height="1.5"
                                                            Width="20" />

                                <TextBlock  Text="ALL"
                                            FontSize="14"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                            Foreground="#A7BDD1" />

                                <TextBlock Text="(60/61)"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                           Foreground="#525762"
                                           Margin="5,0,0,0" />
                            </StackPanel>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0"
                                            x:Name="MyStackPanel">
                                    <ItemsControl ItemsSource="{Binding Games}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>

                                                <Button Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        Height="23">
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Center"
                                                                Width="235"
                                                                Height="22"
                                                                Margin="0">
                                                        <Image Height="20"
                                                               Width="20"
                                                               Margin="5,0,0,0"
                                                               Source="{Binding IconPath}"
                                                               Stretch="UniformToFill"
                                                               VerticalAlignment="Bottom" />
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="#9197A5"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                                   Margin="6,0,0,0" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                
                
                <ScrollViewer Background="#22272E"
                              x:Name="MyScrollViewer2"
                              Width="Auto"
                              Grid.Row="1"
                              Grid.Column="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel VerticalAlignment="Top"
                                    Grid.Row="0">

                            <Image Source="/Icons/Red.png"
                                   Stretch="UniformToFill"
                                   Height="310" />
                        </StackPanel>

                        <Border BorderBrush="Green"
                                BorderThickness="1"
                                Height="1.5"
                                Grid.Row="1">
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.Background>
                                <LinearGradientBrush EndPoint="0,1"
                                                     StartPoint="0,0"
                                                     Opacity="0.7">

                                    <GradientStop Color="#474A54"
                                                  Offset="0" />
                                    <GradientStop Color="#22262E"
                                                  Offset="0.846" />
                                </LinearGradientBrush>
                            </Grid.Background>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel VerticalAlignment="Top"
                                        Height="100"
                                        Grid.Row="0">

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Width="Auto"
                                            Height="50">

                                    <Button BorderBrush="Transparent"
                                            Width="100">
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0,0"
                                                                 EndPoint="1,0">

                                                <GradientStop Color="#45C435"
                                                              Offset="0.341" />

                                                <GradientStop Color="#41AD36"
                                                              Offset="1" />

                                            </LinearGradientBrush>
                                            
                                        </Button.Background>
                                        
                                        <StackPanel Orientation="Horizontal">

                                            <materialIcons:MaterialIcon Kind="Play"
                                                                        Foreground="White"
                                                                        Opacity="0.5"/>

                                            <TextBlock Text="Play"
                                                       Foreground="White" />

                                        </StackPanel>
                                    </Button>

                                    <StackPanel Orientation="Vertical"
                                                Margin="20,0,0,0">

                                        <TextBlock  Text="LAST PLAYED"
                                                    Foreground="#B6BBBF"
                                                    FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"/>

                                        <TextBlock  Text="Mar 21"
                                                    Foreground="#92969C"
                                                    FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"/>

                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal"
                                                Margin="15,0,0,0">

                                        <StackPanel Orientation="Horizontal">

                                            <materialIcons:MaterialIcon Kind="ClockOutline"
                                                                        Foreground="#B6BBBF" />

                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">

                                            <TextBlock Text="PLAY TIME"
                                                       Foreground="#B6BBBF" />

                                            <TextBlock Text="28.6 hours"
                                                       Foreground="#92969C" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Margin="15,0,0,0">

                                        <Button Background="Transparent"
                                                BorderBrush="Transparent"
                                                Height="55">

                                            <StackPanel Orientation="Horizontal">
                                                <materialIcons:MaterialIcon Kind="MedalOutline"
                                                                            Foreground="#B6BBBF" />

                                                <StackPanel Orientation="Vertical">

                                                    <TextBlock Text="ACHIEVEMENTS"
                                                               Foreground="#B6BBBF" />

                                                    <StackPanel Orientation="Horizontal">

                                                        <TextBlock Text="22/57"
                                                                   Foreground="#92969C" />

                                                        <ProgressBar Background="Black"
                                                                     BorderBrush="Transparent"
                                                                     Width="55"
                                                                     Foreground="#2D73FF"
                                                                     Maximum="57"
                                                                     Value="27" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel HorizontalAlignment="Right"
                                            Background="#333B42" >
                                    
                                    
                                    
                                    
                                </StackPanel>
                                
                                
                            </StackPanel>
                            
                            
                            
                            
                            
                            
                            
                            
                            
                            
                            
                            
                            
                            
                            
                            
                            
                        </Grid>
                    </Grid>
                </ScrollViewer>


            </Grid>
        </Border>
    </Grid>
</UserControl>
