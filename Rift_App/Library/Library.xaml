<UserControl x:Class="Rift_App.Library.Library"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Library"           
             mc:Ignorable="d"
             d:Height="1500"
             d:Width="1200">

    <Grid>
        <Border Grid.Row="0"
                Background="#1A2636"
                CornerRadius="0,0,7.5,7.5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="1"
                      Grid.Column="0">

                    <ScrollViewer Background="#22272E"
                                  x:Name="MyScrollViewer"
                                  Width="Auto">
                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">

                                <Border BorderBrush="Transparent"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"
                                        Padding="5">

                                    <Border.Background>
                                        <LinearGradientBrush EndPoint="1,0"
                                                             StartPoint="0,0"
                                                             Opacity="0.2">
                                            <GradientStop Color="#6F88B0"
                                                          Offset="0.361" />
                                            <GradientStop Color="Transparent"
                                                          Offset="0.95" />
                                        </LinearGradientBrush>
                                    </Border.Background>

                                    <StackPanel Orientation="Horizontal"
                                                Margin="10,0,0,0">

                                        <materialIcons:MaterialIcon Kind="HorizontalLine"
                                                                    Foreground="#A7BDD1"
                                                                    Height="20"
                                                                    Width="20" />

                                        <TextBlock  Text="ALL"
                                                    FontSize="14"
                                                    VerticalAlignment="Center"
                                                    FontWeight="SemiBold"
                                                    FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                    Foreground="#A7BDD1" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="60" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="0,8,0,0">

                                    <StackPanel x:Name="GamesPanel">

                                        <ItemsControl ItemsSource="{Binding Games}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Vertical">

                                                        <StackPanel Margin="0,2,0,0">

                                                            <RadioButton GroupName="Games"
                                                                         Height="25"
                                                                         Command="{Binding DataContext.SelectGameCommand,
                                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                         CommandParameter="{Binding}">
                                                                
                                                                <RadioButton.Style>
                                                                    <Style TargetType="RadioButton">
                                                                        <Setter Property="Background"
                                                                                Value="Transparent" />
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="RadioButton">
                                                                                    <Border x:Name="Root"
                                                                                            Background="Transparent">
                                                                                        <Grid Width="253.2">

                                                                                            <StackPanel Orientation="Horizontal"
                                                                                                        Margin="30,0,0,0">

                                                                                                <Image Height="20"
                                                                                                       Width="20"
                                                                                                       Source="{Binding IconPath}"
                                                                                                       Stretch="UniformToFill" />

                                                                                                <TextBlock x:Name="Text"
                                                                                                           Text="{Binding Name}"
                                                                                                           Foreground="#ACB1BF"
                                                                                                           VerticalAlignment="Center"
                                                                                                           FontSize="13"
                                                                                                           FontWeight="SemiBold"
                                                                                                           Margin="3,0,0,0" />
                                                                                            </StackPanel>
                                                                                        </Grid>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver"
                                                                                                 Value="True">
                                                                                            <Setter TargetName="Root"
                                                                                                    Property="Background">
                                                                                                <Setter.Value>
                                                                                                    <SolidColorBrush Color="#344159"
                                                                                                                     Opacity="0.5" />
                                                                                                </Setter.Value>
                                                                                            </Setter>

                                                                                            <Setter TargetName="Text"
                                                                                                    Property="TextBlock.Foreground"
                                                                                                    Value="#B7BCC9" />

                                                                                            <Setter TargetName="Text"
                                                                                                    Property="TextBlock.FontWeight"
                                                                                                    Value="Bold" />
                                                                                        </Trigger>
                                                                                        <Trigger Property="IsChecked"
                                                                                                 Value="True">
                                                                                            <Setter TargetName="Root"
                                                                                                    Property="Background"
                                                                                                    Value="#344159" />

                                                                                            <Setter TargetName="Text"
                                                                                                    Property="TextBlock.Foreground"
                                                                                                    Value="#26B7FF" />
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </RadioButton.Style>
                                                            </RadioButton>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <local:LibraryGamePage x:Name="GameDetailPanel"
                       Grid.Column="1"
                       Grid.Row="1" />
            </Grid>
        </Border>
    </Grid>
</UserControl>