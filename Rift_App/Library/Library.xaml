                                                                            Foreground="#B6BBBF" />

                                                <StackPanel Orientation="Vertical"
                                                            Margin="10,0,0,0">

                                                    <TextBlock Text="PLAY TIME"
                                                               FontSize="14"
                                                               FontFamily="Arial"
                                                               Foreground="#B6BBBF" />

                                                    <TextBlock Text="28.6 hours"
                                                               Margin="2,3,0,0"
                                                               FontSize="13.2"
                                                               Foreground="#92969C"
                                                               FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Margin="18,16,0,0"
                                                        Orientation="Horizontal">

                                                <materialIcons:MaterialIcon Kind="MedalOutline"
                                                                            Width="25"
                                                                            Height="25"
                                                                            Opacity="0.6"
                                                                            Margin="0,4,0,0"
                                                                            Foreground="#B6BBBF" />

                                                <StackPanel Orientation="Vertical"
                                                            Margin="10,0,0,0">

                                                    <TextBlock Text="ACHIEVEMENTS"
                                                               FontSize="14"
                                                               FontFamily="Arial"
                                                               Foreground="#B6BBBF" />

                                                    <StackPanel Orientation="Horizontal">

                                                        <TextBlock Text="22/57"
                                                                   Margin="1,2,0,0"
                                                                   FontSize="13.2"
                                                                   Foreground="#92969C"
                                                                   FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />

                                                        <ProgressBar HorizontalAlignment="Right"
                                                                     Width="80"
                                                                     Height="4.5"
                                                                     Margin="6,4,0,0"
                                                                     Foreground="#2D73FF"
                                                                     Maximum="57"
                                                                     Value="22">

                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ProgressBar">
                                                                                <Border Background="Black"
                                                                                        CornerRadius="2"
                                                                                        ClipToBounds="True">
                                                                                    <Grid x:Name="PART_Track">
                                                                                        <Border x:Name="PART_Indicator"
                                                                                                Background="{TemplateBinding Foreground}"
                                                                                                CornerRadius="2"
                                                                                                HorizontalAlignment="Left" />
                                                                                    </Grid>
                                                                                </Border>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>

                                        <Grid Grid.Column="1">

                                            <StackPanel HorizontalAlignment="Right"
                                                        Margin="0,17,10,0">

                                                <Border CornerRadius="2">

                                                    <Border.Background>
                                                        <SolidColorBrush Color="#747A7C"
                                                                         Opacity="0.3" />
                                                    </Border.Background>

                                                    <Button Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            Foreground="#B9BABD">

                                                        <StackPanel Orientation="Horizontal">

                                                            <materialIcons:MaterialIcon Kind="StorefrontOutline"
                                                                                        Margin="0,0,6,0"
                                                                                        Height="17"
                                                                                        Width="17" />

                                                            <TextBlock Text="Store Page"
                                                                       FontSize="14"
                                                                       VerticalAlignment="Center"
                                                                       FontFamily="Arial" />
                                                        </StackPanel>
                                                    </Button>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>

                                    <Grid Grid.Row="2"
                                          Margin="0,20,20,0">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="415" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0"
                                              Margin="20,0,0,0">

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0"
                                                  Margin="0,80,0,0">

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">

                                                    <DockPanel>

                                                        <TextBlock Text="March 16"
                                                                   Foreground="#87898C"
                                                                   FontSize="17"
                                                                   FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />

                                                        <Border Margin="5,-3,0,0"
                                                                Height="0.5"
                                                                CornerRadius="0.5"
                                                                VerticalAlignment="Center">

                                                            <Border.Background>
                                                                <LinearGradientBrush EndPoint="0,0"
                                                                                     StartPoint="1,0">
                                                                    <GradientStop Color="Transparent"
                                                                                  Offset="0.957" />
                                                                    <GradientStop Color="#87898C"
                                                                                  Offset="0" />
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </DockPanel>
                                                </Grid>

                                                <Grid Grid.Row="1"
                                                      Margin="5,8,0,0">

                                                    <StackPanel HorizontalAlignment="Left"
                                                                Orientation="Horizontal">

                                                        <Border Height="26"
                                                                Width="27"
                                                                CornerRadius="2">

                                                            <Border.Background>
                                                                <ImageBrush ImageSource="{Binding AvatarUrl}"
                                                                            Stretch="UniformToFill" />
                                                            </Border.Background>
                                                        </Border>

                                                        <Rectangle Fill="#6DCFF6"
                                                                   Height="26"
                                                                   VerticalAlignment="Top"
                                                                   Width="1.5" />

                                                        <TextBlock Text="{Binding Username}"
                                                                   Margin="10,4,0,0"
                                                                   Foreground="#67c1f5"
                                                                   FontSize="16"
                                                                   FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />

                                                        <TextBlock Text="achieved"
                                                                   Margin="4,6,0,0"
                                                                   Foreground="#87898C"
                                                                   FontSize="14"
                                                                   FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Grid.Row="2"
                                                      Margin="20,15,0,0">

                                                    <Border Background="#1F2429"
                                                            Padding="15,10,0,10">

                                                        <StackPanel Orientation="Horizontal">

                                                            <Border x:Name="GlowBorder"
                                                                    CornerRadius="2">

                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="Gold"
                                                                                      BlurRadius="80"
                                                                                      ShadowDepth="0"
                                                                                      Opacity="0.8" />
                                                                </Border.Effect>

                                                                <Border CornerRadius="2"
                                                                        Width="43"
                                                                        Height="43">

                                                                    <Border.Background>
                                                                        <ImageBrush ImageSource="/Image/Red.png"
                                                                                    Stretch="UniformToFill" />
                                                                    </Border.Background>
                                                                </Border>
                                                            </Border>

                                                            <StackPanel Orientation="Vertical"
                                                                        Margin="10,0,0,0">

                                                                <TextBlock Text="Bloody Trail"
                                                                           Foreground="White"
                                                                           Margin="0,8,0,0"
                                                                           FontSize="15"
                                                                           FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />

                                                                <TextBlock Text="Complete Memory Sequence 8."
                                                                           Margin="1,0,0,0"
                                                                           Foreground="#B1B1B5"
                                                                           FontSize="13"
                                                                           FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Grid>

                                            <Grid Grid.Row="1"
                                                  Margin="0,60,0,0">

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <DockPanel>

                                                        <TextBlock Text="March 16"
                                                                   Foreground="#87898C"
                                                                   FontSize="17"
                                                                   FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />

                                                        <Border Margin="5,-3,0,0"
                                                                Height="0.5"
                                                                CornerRadius="0.5"
                                                                VerticalAlignment="Center">

                                                            <Border.Background>
                                                                <LinearGradientBrush EndPoint="0,0"
                                                                                     StartPoint="1,0">
                                                                    <GradientStop Color="Transparent"
                                                                                  Offset="0.957" />
                                                                    <GradientStop Color="#87898C"
                                                                                  Offset="0" />
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </DockPanel>
                                                </Grid>

                                                <Grid Grid.Row="1"
                                                      Margin="5,8,0,0">

                                                    <StackPanel HorizontalAlignment="Left"
                                                                Orientation="Horizontal">

                                                        <Border Height="26"
                                                                Width="27"
                                                                CornerRadius="2">

                                                            <Border.Background>
                                                                <ImageBrush ImageSource="{Binding AvatarUrl}"
