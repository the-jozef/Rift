                                                        <TextBlock Text="{Binding Username}"
                                                                   Margin="10,4,0,0"
                                                                   Foreground="#67c1f5"
                                                                   FontSize="16"
                                                                   FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />

                                                        <TextBlock Text="achieved"
                                                                   Margin="4,6,0,0"
                                                                   Foreground="#87898C"
                                                                   FontSize="14"
                                                                   FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Grid.Row="2"
                                                      Margin="20,15,0,0">

                                                    <Border Background="#1F2429"
                                                            Padding="15,10,0,10">

                                                        <StackPanel Orientation="Vertical">

                                                            <StackPanel Orientation="Horizontal">

                                                                <Border CornerRadius="2"
                                                                        Width="43"
                                                                        Height="43">

                                                                    <Border.Effect>
                                                                        <DropShadowEffect Color="Gold"
                                                                                          BlurRadius="80"
                                                                                          ShadowDepth="0"
                                                                                          Opacity="0.8" />
                                                                    </Border.Effect>

                                                                    <Border.Background>
                                                                        <ImageBrush ImageSource="/Image/Red.png"
                                                                                    Stretch="UniformToFill" />
                                                                    </Border.Background>
                                                                </Border>

                                                                <StackPanel Orientation="Vertical"
                                                                            Margin="10,0,0,0">

                                                                    <TextBlock Text="Bloody Trail"
                                                                               Foreground="White"
                                                                               Margin="0,8,0,0"
                                                                               FontSize="15"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />

                                                                    <TextBlock Text="Complete Memory Sequence 8."
                                                                               Margin="1,0,0,0"
                                                                               Foreground="#B1B1B5"
                                                                               FontSize="13"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal"
                                                                        Margin="0,10,0,0">

                                                                <Border CornerRadius="2"
                                                                        Width="43"
                                                                        Height="43">

                                                                    <Border.Effect>
                                                                        <DropShadowEffect Color="Gold"
                                                                                          BlurRadius="80"
                                                                                          ShadowDepth="0"
                                                                                          Opacity="0.8" />
                                                                    </Border.Effect>

                                                                    <Border.Background>
                                                                        <ImageBrush ImageSource="/Image/Red.png"
                                                                                    Stretch="UniformToFill" />
                                                                    </Border.Background>
                                                                </Border>

                                                                <StackPanel Orientation="Vertical"
                                                                            Margin="10,0,0,0">

                                                                    <TextBlock Text="Bloody Trail"
                                                                               Foreground="White"
                                                                               Margin="0,8,0,0"
                                                                               FontSize="15"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />

                                                                    <TextBlock Text="Complete Memory Sequence 8."
                                                                               Margin="1,0,0,0"
                                                                               Foreground="#B1B1B5"
                                                                               FontSize="13"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal"
                                                                        Margin="0,10,0,0">

                                                                <Border CornerRadius="2"
                                                                        Width="43"
                                                                        Height="43">

                                                                    <Border.Effect>
                                                                        <DropShadowEffect Color="Gold"
                                                                                          BlurRadius="80"
                                                                                          ShadowDepth="0"
                                                                                          Opacity="0.8" />
                                                                    </Border.Effect>

                                                                    <Border.Background>
                                                                        <ImageBrush ImageSource="/Image/Red.png"
                                                                                    Stretch="UniformToFill" />
                                                                    </Border.Background>
                                                                </Border>

                                                                <StackPanel Orientation="Vertical"
                                                                            Margin="10,0,0,0">

                                                                    <TextBlock Text="Bloody Trail"
                                                                               Foreground="White"
                                                                               Margin="0,8,0,0"
                                                                               FontSize="15"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />

                                                                    <TextBlock Text="Complete Memory Sequence 8."
                                                                               Margin="1,0,0,0"
                                                                               Foreground="#B1B1B5"
                                                                               FontSize="13"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Grid>

                                        <Grid Grid.Column="2"
                                              Margin="0,30,0,0">

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">

                                                <TextBlock Text="ACHIEVEMENTS"
                                                           Foreground="#AFB8BD"
                                                           FontFamily="Bold"
                                                           HorizontalAlignment="Left"
                                                           Margin="5,0,0,5"
                                                           FontWeight="Medium"
                                                           FontSize="17" />
                                            </Grid>

                                            <Grid Grid.Row="1">

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">

                                                    <Border Padding="5">

                                                        <Border.Background>
                                                            <LinearGradientBrush EndPoint="0,0"
                                                                                 StartPoint="1,0">
                                                                <GradientStop Color="#2A2F36"
                                                                              Offset="0.537" />
                                                                <GradientStop Color="#363A42"
                                                                              Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>

                                                        <StackPanel Orientation="Vertical">

                                                            <StackPanel Orientation="Horizontal"
                                                                        Margin="8,7,0,0">

                                                                <TextBlock Text="You've unlocked 22/57"
                                                                           FontFamily="Bold"
                                                                           Foreground="#D4D4D4"
                                                                           FontWeight="Medium"
                                                                           FontSize="13.4" />

                                                                <TextBlock Text="(38%)"
                                                                           Margin="5,0,0,0"
                                                                           FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                           Foreground="#848B91"
                                                                           FontSize="13.4" />
                                                            </StackPanel>

                                                            <DockPanel>

                                                                <ProgressBar Height="8"
                                                                             Margin="8,7,10,5"
                                                                             Foreground="#2D73FF"
                                                                             Maximum="57"
                                                                             Value="22">

                                                                    <ProgressBar.Style>
                                                                        <Style TargetType="ProgressBar">
                                                                            <Setter Property="Template">
                                                                                <Setter.Value>
