<UserControl
    x:Class="Rift_App.Library.Library"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rift_App.Library"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Height="1500"
    d:Width="1200"
    mc:Ignorable="d">
    <Grid>
        <Border Background="#22272E" CornerRadius="0,0,6.1,6.1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">

                    <ScrollViewer Style="{StaticResource SlimScrollViewerStyle2}">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">

                                <Border
                                    Padding="5"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"
                                    BorderBrush="Transparent">

                                    <Border.Background>
                                        <LinearGradientBrush Opacity="0.2" StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0.361" Color="#6F88B0" />
                                            <GradientStop Offset="0.95" Color="Transparent" />
                                        </LinearGradientBrush>
                                    </Border.Background>

                                    <StackPanel Margin="10,0,0,0" Orientation="Horizontal">

                                        <materialIcons:MaterialIcon
                                            Width="20"
                                            Height="20"
                                            Foreground="#A7BDD1"
                                            Kind="HorizontalLine" />

                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="#A7BDD1">

                                            <Run Text="All" />
                                            <Run Text="{Binding TotalGames}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="15" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,8,0,0">

                                    <StackPanel x:Name="GamesPanel">

                                        <ItemsControl ItemsSource="{Binding Games}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Vertical">

                                                        <StackPanel Margin="0,2,0,0">

                                                            <RadioButton
                                                                Height="25"
                                                                Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Cursor="Hand"
                                                                GroupName="Games">

                                                                <RadioButton.Style>
                                                                    <Style TargetType="RadioButton">
                                                                        <Setter Property="Background" Value="Transparent" />
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="RadioButton">
                                                                                    <Border x:Name="Root" Background="Transparent">
                                                                                        <Grid Width="253.2">

                                                                                            <StackPanel Margin="25,0,0,0"
                                                                                                        Orientation="Horizontal">

                                                                                                <Image Width="20"
                                                                                                           Height="20"
                                                                                                       Margin="0,0,4,0"
                                                                                                           Visibility="{Binding IconPath,Converter={StaticResource StringToVisibilityConverter}}"
                                                                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                                                                           Source="{Binding IconPath}"
                                                                                                           Stretch="UniformToFill" />
                                                                                            
                                                                                                <TextBlock
                                                                                                    x:Name="Text"
                                                                                                    VerticalAlignment="Center"
                                                                                                    FontSize="13"
                                                                                                    FontWeight="SemiBold"
                                                                                                    Text="{Binding Name}">

                                                                                                    <TextBlock.Style>
                                                                                                        <Style TargetType="TextBlock">
                                                                                                            <Setter Property="Foreground" Value="#ACB1BF" />
                                                                                                            <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                                                                    <Setter Property="Foreground" Value="White" />
                                                                                                                </DataTrigger>
                                                                                                            </Style.Triggers>
                                                                                                        </Style>
                                                                                                    </TextBlock.Style>
                                                                                                </TextBlock>
                                                                                            </StackPanel>
                                                                                        </Grid>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="Root" Property="Background">
                                                                                                <Setter.Value>
                                                                                                    <SolidColorBrush Opacity="0.5" Color="#344159" />
                                                                                                </Setter.Value>
                                                                                            </Setter>

                                                                                            <Setter TargetName="Text" Property="TextBlock.Foreground" Value="#B7BCC9" />

                                                                                            <Setter TargetName="Text" Property="TextBlock.FontWeight" Value="Bold" />
                                                                                        </Trigger>
                                                                                        <Trigger Property="IsChecked" Value="True">
                                                                                            <Setter TargetName="Root" Property="Background" Value="#344159" />

                                                                                            <Setter TargetName="Text" Property="TextBlock.Foreground" Value="#26B7FF" />
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </RadioButton.Style>
                                                            </RadioButton>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <local:LibraryGamePage x:Name="GameDetailPanel" Grid.Column="1" />
            </Grid>
        </Border>
    </Grid>
</UserControl>