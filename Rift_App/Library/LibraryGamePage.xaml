<UserControl x:Class="Rift_App.Library.LibraryGamePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Library"
             mc:Ignorable="d"
             d:Height="1500"
             d:Width="1200">

    <Grid>
        
        <TextBlock Text="Select a game from the list"
                   Foreground="#555B63"
                   FontSize="15"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding HasGame, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />


        <ScrollViewer Background="#22272E"
               x:Name="MyScrollViewer2"
               VerticalScrollBarVisibility="Auto"
               Visibility="{Binding HasGame, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="55" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Height="510">
                    
                    <Rectangle Fill="#1A1E24" />

                    <Image Source="{Binding HeroImage}"
                           Stretch="UniformToFill" />
                </Grid>

                <Grid Grid.Row="1">

                    <Border>

                        <Border.Background>
                            <LinearGradientBrush EndPoint="0,1"
                                          StartPoint="0,0"
                                          Opacity="0.7">
                                <GradientStop Color="#474A54"
                                       Offset="0" />
                                <GradientStop Color="#22262E"
                                       Offset="0.846" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">

                                <Border BorderBrush="#A6A6A6"
                                 BorderThickness="1">
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Top"
                                     Orientation="Horizontal"
                                     HorizontalAlignment="Left">

                                    <Button BorderBrush="Transparent"
                                     Padding="0"
                                     Width="165"
                                     Height="50"
                                     Margin="20,10,0,0"
                                            Command="{Binding LaunchOrInstallCommand}">

                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0,0"
                                                          EndPoint="1,0">

                                                <GradientStop Color="#49D136"
                                                       Offset="0.341" />

                                                <GradientStop Color="#3CB031"
                                                       Offset="1" />

                                            </LinearGradientBrush>
                                        </Button.Background>

                                        <StackPanel Orientation="Horizontal">

                                            <materialIcons:MaterialIcon Kind="Play"
                                                                 Foreground="White"
                                                                 Opacity="0.75"
                                                                 Height="30"
                                                                 Width="30" />

                                            <TextBlock Text="PLAY"
                                                HorizontalAlignment="Center"
                                                Margin="6,0,2,0"
                                                Foreground="White"
                                                FontSize="23"
                                                FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />

                                        </StackPanel>
                                    </Button>

                                    <Border CornerRadius="3"
                                            Padding="6,2"
                                            Margin="8,18,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding NeedsUpdate, Converter={StaticResource BooleanToVisibilityConverter}}">

                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0"
                                                                 EndPoint="1,0">

                                                <GradientStop Color="#318FDE"
                                                              Offset="0.341" />

                                                <GradientStop Color="#245FD0"
                                                              Offset="1" />

                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <TextBlock Text="Update available"
                                               Foreground="White"
                                               FontWeight="Medium"
                                               FontSize="11" />
                                    </Border>

                                    <StackPanel Orientation="Vertical"
                                         Margin="25,17,0,0">

                                        <TextBlock  Text="LAST PLAYED"
                                             Foreground="#B6BBBF"
                                             FontSize="14"
                                             FontFamily="Arial" />

                                        <TextBlock Text="{Binding Detail.LastPlayedDisplay}"
                                             Margin="2,3,0,0"
                                             FontSize="13.2"
                                             Foreground="#92969C"
                                             FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal"
                                         Margin="35,17,0,0">

                                        <materialIcons:MaterialIcon Kind="ClockOutline"
                                                             Width="25"
                                                             Height="25"
                                                             Margin="0,-10,0,0"
                                                             Opacity="0.6"
                                                             Foreground="#B6BBBF" />

                                        <StackPanel Orientation="Vertical"
                                             Margin="10,0,0,0">

                                            <TextBlock Text="PLAY TIME"
                                                FontSize="14"
                                                FontFamily="Arial"
                                                Foreground="#B6BBBF" />

                                            <TextBlock Text="{Binding Game.PlaytimeDisplay}"
                                                Margin="2,3,0,0"
                                                FontSize="13.2"
                                                Foreground="#92969C"
                                                FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Margin="18,16,0,0"
                                         Orientation="Horizontal">

                                        <materialIcons:MaterialIcon Kind="MedalOutline"
                                                             Width="25"
                                                             Height="25"
                                                             Opacity="0.6"
                                                             Margin="0,4,0,0"
                                                             Foreground="#B6BBBF" />

                                        <StackPanel Orientation="Vertical"
                                             Margin="10,0,0,0">

                                            <TextBlock Text="ACHIEVEMENTS"
                                                FontSize="14"
                                                FontFamily="Arial"
                                                Foreground="#B6BBBF" />

                                            <StackPanel Orientation="Horizontal">

                                                <TextBlock Margin="1,2,0,0"
                                                    FontSize="13.2"
                                                    Foreground="#92969C"
                                                    FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans">
                                                    
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}/{1}">
                                                            <Binding Path="Detail.AchievementsUnlocked" />
                                                            <Binding Path="Detail.AchievementsTotal" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>

                                                <ProgressBar HorizontalAlignment="Right"
                                                      Width="80"
                                                      Height="4.5"
                                                      Margin="6,4,0,0"
                                                      Foreground="#2D73FF"
                                                      Maximum="{Binding Detail.AchievementsTotal}"
                                                         Value="{Binding Detail.AchievementsUnlocked}">
                                                    
                                                    <ProgressBar.Style>
                                                        <Style TargetType="ProgressBar">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ProgressBar">
                                                                        <Border Background="Black"
                                                                         CornerRadius="2"
                                                                         ClipToBounds="True">
                                                                            <Grid x:Name="PART_Track">
                                                                                <Border x:Name="PART_Indicator"
                                                                                 Background="{TemplateBinding Foreground}"
                                                                                 CornerRadius="2"
                                                                                 HorizontalAlignment="Left" />
                                                                            </Grid>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ProgressBar.Style>
                                                </ProgressBar>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Column="1"
                                      HorizontalAlignment="Right"
                                         Margin="0,17,10,0">

                                    <Border CornerRadius="2">

                                        <Border.Background>
                                            <SolidColorBrush Color="#747A7C"
                                                          Opacity="0.3" />
                                        </Border.Background>

                                        <Button Background="Transparent"
                                             BorderBrush="Transparent"
                                             Foreground="#B9BABD"
                                                Command="{Binding OpenStoreCommand}">

                                            <StackPanel Orientation="Horizontal">

                                                <materialIcons:MaterialIcon Kind="StorefrontOutline"
                                                                         Margin="0,0,6,0"
                                                                         Height="17"
                                                                         Width="17" />

                                                <TextBlock Text="Store Page"
                                                        FontSize="14"
                                                        VerticalAlignment="Center"
                                                        FontFamily="Arial" />
                                            </StackPanel>
                                        </Button>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      Margin="0,20,20,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="415" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="20,0,0,0">
                        <ItemsControl ItemsSource="{Binding RecentActivity}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,30">

                                        <!-- Date header -->
                                        <DockPanel>
                                            <TextBlock Text="{Binding DateLabel}"
                                                       Foreground="#87898C" FontSize="17"
                                                       FontWeight="Bold" />
                                            <Border Margin="5,-3,0,0" Height="0.5"
                                                    CornerRadius="0.5" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                                                        <GradientStop Color="#87898C" Offset="0" />
                                                        <GradientStop Color="Transparent" Offset="0.957" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </DockPanel>

                                        <!-- "Username achieved" row -->
                                        <StackPanel Orientation="Horizontal" Margin="5,8,0,0">
                                            <Border Height="26" Width="27" CornerRadius="2">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding DataContext.CurrentAvatarUrl,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                            <Rectangle Fill="#6DCFF6" Height="26" Width="1.5" />
                                            <TextBlock Text="{Binding DataContext.CurrentUsername,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       Margin="10,4,0,0" Foreground="#67c1f5"
                                                       FontSize="16" FontWeight="Bold" />
                                            <TextBlock Text="achieved" Margin="4,6,0,0"
                                                       Foreground="#87898C" FontSize="14" FontWeight="Bold" />
                                        </StackPanel>

                                        <!-- Achievement cards for this date -->
                                        <Border Background="#1F2429" Padding="15,10,15,10" Margin="20,10,0,0">
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <Border CornerRadius="2" Width="43" Height="43">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="Gold" BlurRadius="80"
                                                                                      ShadowDepth="0" Opacity="0.8" />
                                                                </Border.Effect>
                                                                <Border.Background>
                                                                    <ImageBrush ImageSource="{Binding IconImage.Bitmap}"
                                                                                Stretch="UniformToFill" />
                                                                </Border.Background>
                                                            </Border>
                                                            <StackPanel Orientation="Vertical" Margin="10,0,0,0">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Foreground="White" FontSize="15"
                                                                           FontWeight="Bold" Margin="0,4,0,0" />
                                                                <TextBlock Text="{Binding Description}"
                                                                           Foreground="#B1B1B5" FontSize="13" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Grid Grid.Column="2"
                           Margin="0,30,0,0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">

                            <TextBlock Text="ACHIEVEMENTS"
                                       Foreground="#AFB8BD"
                                       FontFamily="Bold"
                                       HorizontalAlignment="Left"
                                       Margin="5,0,0,5"
                                       FontWeight="Medium"
                                       FontSize="17" />
                        </Grid>

                        <Grid Grid.Row="1">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border>

                                <Border.Background>
                                    <LinearGradientBrush EndPoint="0.5,1"
                                       StartPoint="0.5,0">
                                        <GradientStop Color="#333840"
                                    Offset="0.547" />
                                        <GradientStop Color="#43484F"
                                    Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>

                                <Grid Margin="12,12,0,0">
                                    
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" >
                                        
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                                                <GradientStop Color="#2A2F36" Offset="0.537" />
                                                <GradientStop Color="#363A42" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="8,7,0,0">
                                                <TextBlock Foreground="#D4D4D4" FontWeight="Medium" FontSize="13.4">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="You've unlocked {0}/{1}">
                                                            <Binding Path="Detail.AchievementsUnlocked" />
                                                            <Binding Path="Detail.AchievementsTotal" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Detail.AchievementsPercentDisplay}"
                                                       Margin="5,0,0,0" Foreground="#848B91" FontSize="13.4" />
                                            </StackPanel>
                                            
                                            <ProgressBar Height="8" Margin="8,7,10,5"
                                                     Foreground="#2D73FF"
                                                     Maximum="{Binding Detail.AchievementsTotal}"
                                                     Value="{Binding Detail.AchievementsUnlocked}">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ProgressBar">
                                                                    <Border Background="Black" CornerRadius="2" ClipToBounds="True">
                                                                        <Grid x:Name="PART_Track">
                                                                            <Border x:Name="PART_Indicator"
                                                                                Background="{TemplateBinding Foreground}"
                                                                                CornerRadius="2"
                                                                                HorizontalAlignment="Left" />
                                                                        </Grid>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>
                                        </StackPanel>
                                    </Border>
                                  
                                    <StackPanel Grid.Row="1" Margin="0,8,12,0">
                                        <ItemsControl ItemsSource="{Binding UnlockedPreview}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <Border CornerRadius="2" Width="48" Height="48">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="Gold" BlurRadius="80" ShadowDepth="0" Opacity="0.8" />
                                                            </Border.Effect>
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="{Binding IconImage.Bitmap}" Stretch="UniformToFill" />
                                                            </Border.Background>
                                                        </Border>
                                                        <!-- Show name + desc only for first item -->
                                                        <StackPanel Orientation="Vertical" Margin="10,0,0,0"
                                                                Visibility="{Binding IsFirst, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                                   FontSize="15" FontWeight="Bold" Margin="0,7,0,0" />
                                                            <TextBlock Text="{Binding Description}" Foreground="#B1B1B5" FontSize="13" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <!-- +N more unlocked -->
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                                Visibility="{Binding HasUnlockedRemaining, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Button Background="#282E33" BorderBrush="Transparent"
                                                Width="52" Height="48" Padding="0" Foreground="#D4D4D4">
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="+" FontWeight="SemiBold" FontSize="16" Margin="0,2,1,0" />
                                                    <TextBlock Text="{Binding UnlockedRemaining}" FontWeight="SemiBold" FontSize="17" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Divider -->
                                    <Border Grid.Row="2" Height="1" Background="#6E6F73"
                                        Margin="0,12,12,0" CornerRadius="0.5" />

                                    <!-- Locked header -->
                                    <TextBlock Grid.Row="3" Text="Locked Achievements"
                                           Foreground="#C0C1C4" FontSize="13.4"
                                           Margin="0,8,0,0" />

                                    <!-- Locked icons row -->
                                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5,12,0">
                                        <ItemsControl ItemsSource="{Binding LockedPreview}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="2" Width="48" Height="48" Margin="0,0,8,0">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Gold" BlurRadius="80" ShadowDepth="0" Opacity="0.8" />
                                                        </Border.Effect>
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding IconImage.Bitmap}" Stretch="UniformToFill" />
                                                        </Border.Background>
                                                        <!-- Lock overlay -->
                                                        <Border CornerRadius="2" Margin="-0.2">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="#292727" Opacity="0.9" />
                                                            </Border.Background>
                                                            <materialIcons:MaterialIcon Kind="Lock"
                                                                                    Foreground="#C9C7C7"
                                                                                    Height="20" Width="20" />
                                                        </Border>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <!-- +N more locked -->
                                        <Button Background="#282E33" BorderBrush="Transparent"
                                            Width="52" Height="48" Padding="0" Foreground="#D4D4D4"
                                            Visibility="{Binding HasLockedRemaining, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="+" FontWeight="SemiBold" FontSize="16" Margin="0,1,1,0" />
                                                <TextBlock Text="{Binding LockedRemaining}" FontWeight="SemiBold" FontSize="17" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <!-- View Achievements link -->
                                    <StackPanel Grid.Row="5" HorizontalAlignment="Right"
                                            Margin="0,20,5,8">
                                        <Button Background="Transparent" BorderBrush="Transparent"
                                            Command="{Binding OpenStoreCommand}">
                                            <TextBlock Text="View Achievements" Foreground="#818A91" FontSize="13" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>