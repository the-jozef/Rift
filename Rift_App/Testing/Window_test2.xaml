<Window x:Class="Rift_App.Testing.Window_test2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Steam Store"
        Height="900"
        Width="1400"
        Background="#1B2838">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Top bar -->
            <RowDefinition Height="Auto" />
            <!-- Navigation tabs -->
            <RowDefinition Height="*" />
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ===== TOP BAR ===== -->
        <Grid Grid.Row="0"
              Grid.ColumnSpan="2"
              Background="#171A21"
              Height="70">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="20,0">

                <!-- INSTALL tlačidlo -->
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#5C7E10"
                        Foreground="White"
                        Width="160"
                        Height="45"
                        Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Download"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0" />
                        <StackPanel>
                            <TextBlock Text="INSTALL"
                                       FontWeight="Bold"
                                       FontSize="14" />
                            <TextBlock Text="430.89 MB"
                                       FontSize="10"
                                       Opacity="0.7" />
                        </StackPanel>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- Pravé ikony (Settings, Info, Wishlist) -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Foreground="Gray">
                    <materialDesign:PackIcon Kind="Cog" />
                </Button>
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Foreground="Gray">
                    <materialDesign:PackIcon Kind="InformationOutline" />
                </Button>
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Foreground="Gray">
                    <materialDesign:PackIcon Kind="HeartOutline" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== NAVIGATION TABS ===== -->
        <TabControl Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource MaterialDesignTabControl}"
                    Background="Transparent"
                    Foreground="White">
            <TabItem Header="Store Page" />
            <TabItem Header="Community Hub" />
            <TabItem Header="Discussions" />
            <TabItem Header="Guides" />
            <TabItem Header="Support" />
        </TabControl>

        <!-- ===== ĽAVÝ PANEL - Activity ===== -->
        <ScrollViewer Grid.Row="2"
                      Grid.Column="0"
                      Margin="20,10">
            <StackPanel>

                <TextBlock Text="ACTIVITY"
                           Foreground="#8F98A0"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="0,0,0,10" />

                <!-- TextBox "Say something..." -->
                <TextBox materialDesign:HintAssist.Hint="Say something about this game to your friends..."                   
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Foreground="White"
                         Margin="0,0,0,20" />

                <!-- ===== ItemsControl pre News eventy ===== -->
                <ItemsControl ItemsSource="{Binding NewsItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Dátum sekcia -->
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="{Binding DateFormatted}"
                                           Foreground="#8F98A0"
                                           FontWeight="Bold"
                                           FontSize="11"
                                           Margin="0,0,0,8" />
                                <Separator Background="#2A3F5F"
                                           Margin="0,0,0,10" />

                                <!-- Event karta -->
                                <materialDesign:Card Background="#1E2D3D"
                                                     Padding="0"
                                                     Margin="0,0,0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Thumbnail obrázok -->
                                        <Image Grid.Column="0"
                                               Source="{Binding ThumbnailUrl}"
                                               Height="120"
                                               Stretch="UniformToFill" />

                                        <!-- Text obsah -->
                                        <StackPanel Grid.Column="1"
                                                    Margin="15,10">
                                            <TextBlock Text="IN-GAME EVENT"
                                                       Foreground="#5C9BD6"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Margin="0,0,0,5" />
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding Contents}"
                                                       Foreground="#8F98A0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== PRAVÝ PANEL ===== -->
        <StackPanel Grid.Row="2"
                    Grid.Column="1"
                    Margin="10,10,20,10">

            <!-- NOTES -->
            <TextBlock Text="NOTES"
                       Foreground="#8F98A0"
                       FontSize="11"
                       FontWeight="Bold" />
            <materialDesign:Card Background="#1E2D3D"
                                 Margin="0,8,0,20"
                                 Padding="10">
                <TextBox materialDesign:HintAssist.Hint="New Note"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Foreground="White"
                         MinHeight="60" />
            </materialDesign:Card>

            <!-- RECORDINGS AND SCREENSHOTS -->
            <TextBlock Text="RECORDINGS AND SCREENSHOTS"
                       Foreground="#8F98A0"
                       FontSize="11"
                       FontWeight="Bold" />
            <materialDesign:Card Background="#1E2D3D"
                                 Margin="0,8,0,0"
                                 Padding="15">
                <StackPanel>
                    <TextBlock Text="You haven't taken any screenshots yet"
                               Foreground="#8F98A0"
                               FontSize="12"
                               Margin="0,0,0,5" />
                    <TextBlock Text="You can take a screenshot by pressing F12 while in game."
                               Foreground="#8F98A0"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <Button Content="Change My Screenshot Key"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="#5C9BD6"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0" />
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>

    </Grid>


</Window>
