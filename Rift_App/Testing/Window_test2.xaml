<Window x:Class="Rift_App.Testing.Window_test2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Steam Store"
        Height="900"
        Width="1400"
        Background="#1b2838"
        FontFamily="Arial"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>

        <!-- ═══════════════════════════════════════════
             STEAM COLOR PALETTE
        ═══════════════════════════════════════════ -->
        <SolidColorBrush x:Key="Steam.Bg"
                         Color="#1b2838" />
        <SolidColorBrush x:Key="Steam.Panel"
                         Color="#16202d" />
        <SolidColorBrush x:Key="Steam.Card"
                         Color="#2a475e" />
        <SolidColorBrush x:Key="Steam.Blue"
                         Color="#66c0f4" />
        <SolidColorBrush x:Key="Steam.Text"
                         Color="#c6d4df" />
        <SolidColorBrush x:Key="Steam.TextMuted"
                         Color="#8fa3b3" />
        <SolidColorBrush x:Key="Steam.GreenBadge"
                         Color="#4c6b22" />
        <SolidColorBrush x:Key="Steam.GreenText"
                         Color="#beee11" />
        <SolidColorBrush x:Key="Steam.DotActive"
                         Color="#66c0f4" />
        <SolidColorBrush x:Key="Steam.DotInactive"
                         Color="#3d6680" />
        <SolidColorBrush x:Key="Steam.RedBadge"
                         Color="#c94f2c" />
        <SolidColorBrush x:Key="Steam.NavBg"
                         Color="#171a21" />

        <!-- ═══════════════════════════════════════════
             SECTION HEADER STYLE
        ═══════════════════════════════════════════ -->
        <Style x:Key="SteamSectionHeader"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#c6d4df" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
        </Style>

        <!-- ═══════════════════════════════════════════
             BROWSE MORE BUTTON STYLE
        ═══════════════════════════════════════════ -->
        <Style x:Key="SteamBrowseButton"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#c6d4df" />
            <Setter Property="BorderBrush"
                    Value="#3d6680" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="12,4" />
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#3d6680" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════
             CAROUSEL NAV ARROW STYLE
        ═══════════════════════════════════════════ -->
        <Style x:Key="SteamArrowButton"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#00000060" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Width"
                    Value="36" />
            <Setter Property="Height"
                    Value="80" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#00000099" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════
             SMALL TAG / BADGE STYLE
        ═══════════════════════════════════════════ -->
        <Style x:Key="SteamTagGreen"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#4c6b22" />
            <Setter Property="CornerRadius"
                    Value="2" />
            <Setter Property="Padding"
                    Value="6,2" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
        </Style>
        <Style x:Key="SteamTagBlue"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#1e3a5f" />
            <Setter Property="CornerRadius"
                    Value="2" />
            <Setter Property="Padding"
                    Value="6,2" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
        </Style>
        <Style x:Key="SteamTagOrange"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#7a3a1a" />
            <Setter Property="CornerRadius"
                    Value="2" />
            <Setter Property="Padding"
                    Value="6,2" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
        </Style>

        <!-- ═══════════════════════════════════════════
             DISCOUNT BADGE (green %-off block)
        ═══════════════════════════════════════════ -->
        <Style x:Key="SteamDiscountBadge"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#4c6b22" />
            <Setter Property="CornerRadius"
                    Value="2" />
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
        </Style>

        <!-- ═══════════════════════════════════════════
             GAME CARD  (used in Discounts row)
        ═══════════════════════════════════════════ -->
        <Style x:Key="SteamGameCard"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#16202d" />
            <Setter Property="CornerRadius"
                    Value="3" />
            <Setter Property="Cursor"
                    Value="Hand" />
        </Style>

        <!-- ═══════════════════════════════════════════
             CATEGORY CARD
        ═══════════════════════════════════════════ -->
        <Style x:Key="SteamCategoryCard"
               TargetType="Border">
            <Setter Property="CornerRadius"
                    Value="3" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Height"
                    Value="130" />
        </Style>

        <!-- Placeholder image colors per game -->
        <SolidColorBrush x:Key="PlaceholderBlue"
                         Color="#1a3a5c" />
        <SolidColorBrush x:Key="PlaceholderGreen"
                         Color="#162a16" />
        <SolidColorBrush x:Key="PlaceholderPurple"
                         Color="#2a1a3e" />
        <SolidColorBrush x:Key="PlaceholderTeal"
                         Color="#0e2a2a" />
        <SolidColorBrush x:Key="PlaceholderNavy"
                         Color="#0a1628" />

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════
         TOP-LEVEL SCROLL CONTAINER
    ═══════════════════════════════════════════════════════════════ -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="#1b2838"
                  materialDesign:ScrollViewerAssist.IsAutoHideEnabled="True">

        <StackPanel>

            <!-- ═══════════════════════════════════════
                 SECTION 1 — FEATURED & RECOMMENDED
            ═══════════════════════════════════════ -->
            <StackPanel Margin="40,20,40,0">

                <TextBlock Text="Featured &amp; Recommended"
                           Style="{StaticResource SteamSectionHeader}"
                           Margin="0,0,0,10" />

                <!-- Main carousel container -->
                <Grid Height="270">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="310" />
                    </Grid.ColumnDefinitions>

                    <!-- ── Left: big feature image placeholder ── -->
                    <Border Grid.Column="0"
                            Background="{StaticResource PlaceholderBlue}"
                            CornerRadius="3,0,0,3"
                            ClipToBounds="True">
                        <!-- Replace Rectangle Fill with <Image Source="..."/> when ready -->
                        <Rectangle Fill="{StaticResource PlaceholderBlue}" />
                    </Border>

                    <!-- Carousel left arrow -->
                    <Button Grid.Column="0"
                            Style="{StaticResource SteamArrowButton}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="0">
                        <materialDesign:PackIcon Kind="ChevronLeft"
                                                 Width="22"
                                                 Height="22" />
                    </Button>

                    <!-- Carousel right arrow -->
                    <Button Grid.Column="0"
                            Style="{StaticResource SteamArrowButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ChevronRight"
                                                 Width="22"
                                                 Height="22" />
                    </Button>

                    <!-- ── Right: info panel ── -->
                    <Border Grid.Column="1"
                            Background="#16202d"
                            CornerRadius="0,3,3,0">
                        <StackPanel>

                            <!-- Game title -->
                            <TextBlock Text="Slay the Spire 2"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10" />

                            <!-- 4 thumbnail placeholders in 2×2 grid -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Row="0"
                                        Grid.Column="0"
                                        Height="82"
                                        Background="#2a475e"
                                        CornerRadius="2" />
                                <Border Grid.Row="0"
                                        Grid.Column="2"
                                        Height="82"
                                        Background="#3a2a5e"
                                        CornerRadius="2" />
                                <Border Grid.Row="2"
                                        Grid.Column="0"
                                        Height="82"
                                        Background="#1a3a2a"
                                        CornerRadius="2" />
                                <Border Grid.Row="2"
                                        Grid.Column="2"
                                        Height="82"
                                        Background="#3e1a2a"
                                        CornerRadius="2" />
                            </Grid>

                            <!-- Tags row -->
                            <WrapPanel Margin="0,8,0,0">
                                <Border Style="{StaticResource SteamTagGreen}">
                                    <TextBlock Text="Top Seller"
                                               Foreground="White"
                                               FontSize="11" />
                                </Border>
                                <Border Style="{StaticResource SteamTagBlue}">
                                    <TextBlock Text="Online Co-Op"
                                               Foreground="#66c0f4"
                                               FontSize="11" />
                                </Border>
                                <Border Style="{StaticResource SteamTagBlue}">
                                    <TextBlock Text="Co-op"
                                               Foreground="#66c0f4"
                                               FontSize="11" />
                                </Border>
                                <Border Style="{StaticResource SteamTagBlue}">
                                    <TextBlock Text="Multiplayer"
                                               Foreground="#66c0f4"
                                               FontSize="11" />
                                </Border>
                            </WrapPanel>

                            <!-- Price + platform icons -->
                            <DockPanel Margin="0,10,0,0">
                                <!-- Platform icons -->
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="MicrosoftWindows"
                                                             Foreground="#8fa3b3"
                                                             Width="18"
                                                             Height="18"
                                                             Margin="0,0,4,0" />
                                    <materialDesign:PackIcon Kind="Steam"
                                                             Foreground="#8fa3b3"
                                                             Width="18"
                                                             Height="18" />
                                </StackPanel>
                                <TextBlock Text="22,99€"
                                           Foreground="#c6d4df"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </DockPanel>

                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Carousel dot indicators -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#66c0f4"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                </StackPanel>

            </StackPanel>

            <!-- ═══════════════════════════════════════
                 SECTION 2 — EVENT BANNER
                 (Steam House and Home Fest)
            ═══════════════════════════════════════ -->
            <Border Margin="40,16,40,0"
                    Height="115"
                    CornerRadius="3"
                    Cursor="Hand"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,0">
                        <GradientStop Color="#0d2035"
                                      Offset="0" />
                        <GradientStop Color="#1a3a5c"
                                      Offset="0.5" />
                        <GradientStop Color="#0d2035"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Left decorative placeholder (would be isometric room art) -->
                    <Border Width="180"
                            HorizontalAlignment="Left"
                            Background="#1a3a5c"
                            Margin="160,0,0,0">
                        <TextBlock Text="🛋️"
                                   FontSize="40"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- Badge placeholder (would be "House and Home Fest" logo) -->
                    <Border Width="160"
                            HorizontalAlignment="Left"
                            Margin="0"
                            Background="#c94f2c"
                            CornerRadius="50"
                            VerticalAlignment="Center"
                            Height="90">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="STEAM"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="House &amp; Home"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="FEST"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Right text block -->
                    <Border HorizontalAlignment="Right"
                            Width="400"
                            Background="#000000AA"
                            Margin="0,0,30,0"
                            CornerRadius="3"
                            Padding="16,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="DISCOUNTS, DEMOS, AND MORE"
                                       Foreground="#f4a535"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="NOW  ·  APR 6 AT 10 AM PT"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════
                 SECTION 3 — DISCOUNTS & EVENTS
            ═══════════════════════════════════════ -->
            <StackPanel Margin="40,20,40,0">

                <!-- Header row -->
                <DockPanel Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right"
                            Content="BROWSE MORE"
                            Style="{StaticResource SteamBrowseButton}"
                            Height="28" />
                    <TextBlock Text="Discounts &amp; Events"
                               Style="{StaticResource SteamSectionHeader}" />
                </DockPanel>

                <!-- Left/Right arrows + card row -->
                <Grid>

                    <!-- Carousel cards -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="290" />
                        </Grid.ColumnDefinitions>

                        <!-- ── Card 1: Subnautica (Free Weekend) ── -->
                        <Border Grid.Column="0"
                                Style="{StaticResource SteamGameCard}">
                            <StackPanel>
                                <!-- Image placeholder -->
                                <Border Height="160"
                                        CornerRadius="3,3,0,0"
                                        Background="#0a2a3a"
                                        ClipToBounds="True">
                                    <TextBlock Text="Subnautica"
                                               Foreground="#66c0f4"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel>
                                    <!-- Badge -->
                                    <Border Background="{StaticResource Steam.RedBadge}"
                                            CornerRadius="2"
                                            Padding="7,2"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,5">
                                        <TextBlock Text="FREE WEEKEND"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="Bold" />
                                    </Border>
                                    <!-- Description -->
                                    <TextBlock Text="Play for free until 6 Apr @ 7:00pm."
                                               Foreground="#8fa3b3"
                                               FontSize="11"
                                               Margin="0,0,0,7" />
                                    <!-- Price row -->
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left"
                                                Style="{StaticResource SteamDiscountBadge}">
                                            <TextBlock Text="-75%"
                                                       Foreground="#beee11"
                                                       FontSize="15"
                                                       FontWeight="Bold" />
                                        </Border>
                                        <StackPanel Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="29,99€"
                                                       Foreground="#8fa3b3"
                                                       FontSize="10"
                                                       TextDecorations="Strikethrough" />
                                            <TextBlock Text="7,49€"
                                                       Foreground="White"
                                                       FontSize="13"
                                                       FontWeight="Bold" />
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Card 2: Gray Zone Warfare (Weekend Deal) ── -->
                        <Border Grid.Column="2"
                                Style="{StaticResource SteamGameCard}">
                            <StackPanel>
                                <Border Height="160"
                                        CornerRadius="3,3,0,0"
                                        Background="#0d1f0d"
                                        ClipToBounds="True">
                                    <TextBlock Text="Gray Zone Warfare"
                                               Foreground="#66c0f4"
                                               FontSize="17"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel>
                                    <Border Background="#1e5a8a"
                                            CornerRadius="2"
                                            Padding="7,2"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,5">
                                        <TextBlock Text="WEEKEND DEAL"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="Bold" />
                                    </Border>
                                    <TextBlock Text="Offer ends 9 Apr @ 7:00pm."
                                               Foreground="#8fa3b3"
                                               FontSize="11"
                                               Margin="0,0,0,7" />
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left"
                                                Style="{StaticResource SteamDiscountBadge}">
                                            <TextBlock Text="-33%"
                                                       Foreground="#beee11"
                                                       FontSize="15"
                                                       FontWeight="Bold" />
                                        </Border>
                                        <StackPanel Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="39,99€"
                                                       Foreground="#8fa3b3"
                                                       FontSize="10"
                                                       TextDecorations="Strikethrough" />
                                            <TextBlock Text="26,79€"
                                                       Foreground="White"
                                                       FontSize="13"
                                                       FontWeight="Bold" />
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Card 3: Two stacked "Today's Deal" mini-cards ── -->
                        <Border Grid.Column="4"
                                Style="{StaticResource SteamGameCard}">
                            <StackPanel>

                                <!-- Mini card: Breathedge -->
                                <Border Background="#1a1a2e"
                                        Height="80"
                                        CornerRadius="3,3,0,0"
                                        ClipToBounds="True">
                                    <TextBlock Text="Breathedge"
                                               Foreground="#66c0f4"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <DockPanel 
                                           Background="#16202d">
                                    <Border DockPanel.Dock="Right"
                                            Style="{StaticResource SteamDiscountBadge}"
                                            VerticalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock Text="-80%"
                                                       Foreground="#beee11"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="4,99€"
                                                       Foreground="White"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Today's deal!"
                                                   Foreground="#8fa3b3"
                                                   FontSize="11" />
                                        <TextBlock Text="24,95€"
                                                   Foreground="#8fa3b3"
                                                   FontSize="10"
                                                   TextDecorations="Strikethrough" />
                                    </StackPanel>
                                </DockPanel>

                                <!-- Divider -->
                                <Rectangle Height="2"
                                           Fill="#0d1117" />

                                <!-- Mini card: Lake of Creatures -->
                                <Border Background="#1a2a10"
                                        Height="80"
                                        ClipToBounds="True">
                                    <TextBlock Text="Lake of Creatures"
                                               Foreground="#66c0f4"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <DockPanel 
                                           Background="#16202d">
                                    <Border DockPanel.Dock="Right"
                                            Style="{StaticResource SteamDiscountBadge}"
                                            VerticalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock Text="-60%"
                                                       Foreground="#beee11"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="4,99€"
                                                       Foreground="White"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Today's deal!"
                                                   Foreground="#8fa3b3"
                                                   FontSize="11" />
                                        <TextBlock Text="12,49€"
                                                   Foreground="#8fa3b3"
                                                   FontSize="10"
                                                   TextDecorations="Strikethrough" />
                                    </StackPanel>
                                </DockPanel>

                            </StackPanel>
                        </Border>

                    </Grid>

                    <!-- Left arrow -->
                    <Button Style="{StaticResource SteamArrowButton}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="-18,0,0,0"
                            Height="60">
                        <materialDesign:PackIcon Kind="ChevronLeft"
                                                 Width="20"
                                                 Height="20" />
                    </Button>
                    <!-- Right arrow -->
                    <Button Style="{StaticResource SteamArrowButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,-18,0"
                            Height="60">
                        <materialDesign:PackIcon Kind="ChevronRight"
                                                 Width="20"
                                                 Height="20" />
                    </Button>

                </Grid>

                <!-- Carousel dot indicators -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#66c0f4"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                </StackPanel>

            </StackPanel>

            <!-- ═══════════════════════════════════════
                 SECTION 4 — BROWSE BY CATEGORY
            ═══════════════════════════════════════ -->
            <StackPanel Margin="40,24,40,36">

                <TextBlock Text="Browse by Category"
                           Style="{StaticResource SteamSectionHeader}"
                           Margin="0,0,0,10" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Role-Playing -->
                    <Border Grid.Column="0"
                            Style="{StaticResource SteamCategoryCard}"
                            ClipToBounds="True"
                            Cursor="Hand">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">
                                <GradientStop Color="#1a0d2e"
                                              Offset="0" />
                                <GradientStop Color="#2a1a5e"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <!-- placeholder for stacked game art -->
                            <Rectangle Opacity="0.3">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="0,1">
                                        <GradientStop Color="#3a2a6e"
                                                      Offset="0" />
                                        <GradientStop Color="Transparent"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Border VerticalAlignment="Bottom"
                                    Padding="0,0,0,12">
                                <TextBlock Text="ROLE-PLAYING"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- VR Titles -->
                    <Border Grid.Column="2"
                            Style="{StaticResource SteamCategoryCard}"
                            ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">
                                <GradientStop Color="#0a1e2e"
                                              Offset="0" />
                                <GradientStop Color="#1a3a5e"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Rectangle Opacity="0.3">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="0,1">
                                        <GradientStop Color="#1a4a6e"
                                                      Offset="0" />
                                        <GradientStop Color="Transparent"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Border VerticalAlignment="Bottom"
                                    Padding="0,0,0,12">
                                <TextBlock Text="VR TITLES"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Simulation -->
                    <Border Grid.Column="4"
                            Style="{StaticResource SteamCategoryCard}"
                            ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">
                                <GradientStop Color="#0a1e0a"
                                              Offset="0" />
                                <GradientStop Color="#1a3a1a"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Rectangle Opacity="0.3">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="0,1">
                                        <GradientStop Color="#1a4a1a"
                                                      Offset="0" />
                                        <GradientStop Color="Transparent"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Border VerticalAlignment="Bottom"
                                    Padding="0,0,0,12">
                                <TextBlock Text="SIMULATION"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Puzzle -->
                    <Border Grid.Column="6"
                            Style="{StaticResource SteamCategoryCard}"
                            ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">
                                <GradientStop Color="#1e0a0a"
                                              Offset="0" />
                                <GradientStop Color="#3e1a1a"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Rectangle Opacity="0.3">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="0,1">
                                        <GradientStop Color="#4e2a2a"
                                                      Offset="0" />
                                        <GradientStop Color="Transparent"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Border VerticalAlignment="Bottom"
                                    Padding="0,0,0,12">
                                <TextBlock Text="PUZZLE"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                </Grid>

                <!-- Dot indicators for categories -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#66c0f4"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                    <Ellipse Width="9"
                             Height="9"
                             Fill="#3d6680"
                             Margin="3,0" />
                </StackPanel>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
