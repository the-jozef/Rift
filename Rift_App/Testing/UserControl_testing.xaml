<UserControl
    x:Class="Rift_App.Testing.UserControl_testing"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rift_App.Testing"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Width="1000"
    Height="1500"
    mc:Ignorable="d">
    <Grid Background="Gray">

        <Grid Height="Auto" Margin="0,8,12,0">




            <StackPanel Orientation="Vertical">

                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="48"
                        Height="48"
                        ClipToBounds="True"
                        CornerRadius="2">

                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="70"
                                Opacity="0.5"
                                ShadowDepth="0"
                                Color="Gold" />
                        </Border.Effect>

                        <Image Source="/Image/Red.png" Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Margin="12,0,0,0" Orientation="Vertical">

                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="15"
                            Foreground="White"
                            Text="Name of game" />

                        <TextBlock
                            FontSize="13"
                            Foreground="#B1B1B5"
                            Text="Description of game" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="48"
                        Height="48"
                        ClipToBounds="True"
                        CornerRadius="2">

                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="70"
                                Opacity="0.5"
                                ShadowDepth="0"
                                Color="Gold" />
                        </Border.Effect>

                        <Image Source="/Image/Red.png" Stretch="UniformToFill" />
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="15,4,0,0" Orientation="Horizontal">

                <Button
                    Width="52"
                    Height="48"
                    Padding="0"
                    Background="#282E33"
                    BorderBrush="Transparent"
                    Foreground="#D4D4D4">

                    <StackPanel Margin="-2,2,0,0" Orientation="Horizontal">

                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="+" />

                        <TextBlock
                            Margin="1,0,0,0"
                            FontSize="17"
                            FontWeight="SemiBold"
                            Text="15" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>