<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>
	</PropertyGroup>

	<ItemGroup>
		<Compile Remove="44\**" />
		<Compile Remove="Service\**" />
		<EmbeddedResource Remove="44\**" />
		<EmbeddedResource Remove="Service\**" />
		<None Remove="44\**" />
		<None Remove="Service\**" />
		<Page Remove="44\**" />
		<Page Remove="Service\**" />
	</ItemGroup>

	<ItemGroup>
		<None Remove="Videos\Background_animation.mp4" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="Videos\Background_animation.mp4">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

	<ItemGroup>
		<!-- Password hashing -->
		<PackageReference Include="BCrypt.Net-Next" Version="4.1.0" />

		<!-- MVVM toolkit -->
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />

		<!-- Material Design UI -->
		<PackageReference Include="Material.Icons.WPF" Version="3.0.2" />
		<PackageReference Include="MaterialDesignThemes" Version="5.3.1" />

		<!-- JSON for API calls -->
		<PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
	</ItemGroup>

	<ItemGroup>
		<Resource Include="Image\Steam.jpg">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Resource>
		<Resource Include="Image\Red.png">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Resource>
		<Resource Include="Image\Rift_logo.png">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Resource>
	</ItemGroup>

	<ItemGroup>
		<Folder Include="AppController\" />
	</ItemGroup>

</Project>