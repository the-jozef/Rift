             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.ViewModels"
             mc:Ignorable="d">
    <Grid>
        <Border Grid.Row="0"
                Background="{StaticResource RiftStoreBackground}"
                CornerRadius="0,0,7.5,7.5">
            <Grid>
                <ScrollViewer Style="{StaticResource Rift_ScrollViewer}"
                              Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                              Background="#1b2838"
                              VerticalScrollBarVisibility="Auto"
                              VerticalAlignment="Bottom">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="290" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="290" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="150" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Column="0"
                                    Width="Auto"
                                    Height="Auto"
                                    Grid.Row="0">

                            <Button HorizontalAlignment="Right"
                                    Height="100"
                                    Width="50"
                                    Margin="0,165,0,0"
                                    BorderBrush="Transparent"
                                    Foreground="White">

                                <Button.Background>
                                    <LinearGradientBrush StartPoint="1.0,0"
                                                         EndPoint="0.0,0"
                                                         Opacity="0.25">
                                        <GradientStop Color="#E0000000"
                                                      Offset="0.959" />
                                        <GradientStop Color="#00000000"
                                                      Offset="0" />
                                    </LinearGradientBrush>
                                </Button.Background>

                                <materialDesign:PackIcon Kind="ChevronLeft"
                                                         Width="70"
                                                         Height="70"
                                                         Margin="-27,0,0,0" />
                            </Button>

                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Width="Auto"
                                    Height="Auto"
                                    Grid.Row="0">

                            <Button HorizontalAlignment="Left"
                                    Height="100"
                                    Width="50"
                                    Margin="0,165,0,0"
                                    BorderBrush="Transparent"
                                    Foreground="White">

                                <Button.Background>
                                    <LinearGradientBrush StartPoint="1.0,0"
                                                         EndPoint="0.0,0"
                                                         Opacity="0.25">
                                        <GradientStop Color="#00000000"
                                                      Offset="0.959" />
                                        <GradientStop Color="#E0000000"
                                                      Offset="0" />
                                    </LinearGradientBrush>
                                </Button.Background>

                                <materialDesign:PackIcon Kind="ChevronRight"
                                                         Width="70"
                                                         Height="70"
                                                         Margin="-27,0,0,0" />
                            </Button>

