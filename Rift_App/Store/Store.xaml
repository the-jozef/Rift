                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>

                                                                <Border Background="#394148"
                                                                        materialDesign:ElevationAssist.Elevation="Dp6"
                                                                        CornerRadius="2"
                                                                        Padding="6,2"
                                                                        Margin="0,0,4,0">

                                                                    <TextBlock Text="{Binding}"
                                                                               Foreground="White"
                                                                               FontSize="11" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
