                                    <LinearGradientBrush StartPoint="1.0,0"
                                                         EndPoint="0.0,0"
                                                         Opacity="0.25">
                                        <GradientStop Color="#E0000000"
                                                      Offset="0.959" />
                                        <GradientStop Color="#00000000"
                                                      Offset="0" />
                                    </LinearGradientBrush>
                                </Button.Background>

                                <materialDesign:PackIcon Kind="ChevronLeft"
