<UserControl x:Class="Rift_App.Store.Store"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Store"
             mc:Ignorable="d">
    <Grid>
        <Border CornerRadius="0,0,7.5,7.5">
            <Grid>
                <ScrollViewer Style="{StaticResource Rift_MenuBar_ScrollViewer_PopupBox_Account}"
                              Background="#1b2838"
                              VerticalScrollBarVisibility="Auto"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch">
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="290" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="290" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="150" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Column="0"
                              Grid.Row="0">

                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Height="100"
                                    Width="50"
                                    Margin="0,-24,0,0"
                                    BorderBrush="Transparent"
                                    Foreground="White"
                                    Padding="0"
                                    MinHeight="0"
                                    MinWidth="0"
                                    Command="{Binding PrevFeaturedCommand}">

                                <Button.Background>
                                    <LinearGradientBrush StartPoint="1.0,0"
                                                         EndPoint="0.0,0"
                                                         Opacity="0.25">
                                        <GradientStop Color="#E0000000"
                                                      Offset="0.959" />
                                        <GradientStop Color="#00000000"
                                                      Offset="0" />
                                    </LinearGradientBrush>
                                </Button.Background>

                                <materialDesign:PackIcon Kind="ChevronLeft"
                                                         Width="70"
                                                         Height="70"
                                                         Margin="-11,0,0,0" />
                            </Button>
                        </Grid>

                        <!-- ─── Pravý chevron ────────────────────────────────────────────── -->
                        <Grid Grid.Column="2"
                              Grid.Row="0">

                            <Button HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Height="100"
                                    Width="50"
                                    Margin="0,-24,0,0"
                                    BorderBrush="Transparent"
                                    Foreground="White"
                                    Padding="0"
                                    MinHeight="0"
                                    MinWidth="0"
                                    Command="{Binding NextFeaturedCommand}">

                                <Button.Background>
                                    <LinearGradientBrush StartPoint="1.0,0"
                                                         EndPoint="0.0,0"
                                                         Opacity="0.25">
                                        <GradientStop Color="#00000000"
                                                      Offset="0.959" />
                                        <GradientStop Color="#E0000000"
                                                      Offset="0" />
                                    </LinearGradientBrush>
                                </Button.Background>

                                <materialDesign:PackIcon Kind="ChevronRight"
                                                         Width="70"
                                                         Height="70"
                                                         Margin="-11,0,0,0" />
                            </Button>
                        </Grid>

                        <!-- ─── Hlavná featured sekcia ───────────────────────────────────── -->
                        <Grid Grid.Row="0"
                              Grid.Column="1">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="50" />
                            </Grid.RowDefinitions>

                            <!-- Nadpis -->
                            <Grid Grid.Row="0"
                                  Margin="0,25,0,0">
                                <TextBlock HorizontalAlignment="Left"
                                           Text="Featured &amp; Recommended"
                                           Foreground="White"
                                           FontSize="14"
                                           Margin="2,0,0,0" />
                            </Grid>

                            <!-- Hlavný panel — 2 stĺpce: veľký obrázok + detail -->
                            <Grid Grid.Row="1"
                                  Margin="0,10,0,0"
                                  Height="350">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="330" />
                                </Grid.ColumnDefinitions>

                                <!-- Veľký obrázok — large header image -->
                                <Grid Grid.Column="0">
                                    <Border CornerRadius="3,0,0,3"
                                            ClipToBounds="True"
                                            Width="630">
                                        <Border.Background>
                                            <ImageBrush Stretch="UniformToFill"
                                                        RenderOptions.BitmapScalingMode="HighQuality"
                                                        ImageSource="{Binding FeaturedMainImage.Bitmap}" />
                                        </Border.Background>
                                    </Border>
                                </Grid>

                                <!-- Detail panel — NE nastavuj DataContext tu, binding ide cez parent VM -->
                                <!-- Detail panel — do NOT set DataContext here, binding goes through parent VM -->
                                <Grid Grid.Column="1">
                                    <Border Background="#0B151E"
                                            CornerRadius="0,3,3,0">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Meno hry — game name -->
                                            <Grid Grid.Row="0">
                                                <TextBlock Text="{Binding CurrentFeaturedGame.Name}"
                                                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                           Foreground="White"
                                                           TextWrapping="Wrap"
                                                           Margin="20,20,70,0"
                                                           FontSize="23" />
                                            </Grid>

                                            <!-- 4 screenshoty 2x2 — 4 screenshots 2x2 -->
                                            <Grid Grid.Row="1"
                                                  Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="11" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="11" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="11" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Image Grid.Row="0"
                                                       Grid.Column="0"
                                                       Source="{Binding FeaturedScreenshot1.Bitmap}"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Left"
                                                       Width="155"
                                                       Height="70"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />

                                                <Image Grid.Row="0"
                                                       Grid.Column="2"
                                                       Source="{Binding FeaturedScreenshot2.Bitmap}"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Left"
                                                       Width="155"
                                                       Height="70"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />

                                                <Image Grid.Row="2"
                                                       Grid.Column="0"
                                                       Source="{Binding FeaturedScreenshot3.Bitmap}"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Left"
                                                       Width="155"
                                                       Height="70"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />

                                                <Image Grid.Row="2"
                                                       Grid.Column="2"
                                                       Source="{Binding FeaturedScreenshot4.Bitmap}"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Left"
                                                       Width="155"
                                                       Height="70"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                            </Grid>

                                            <!-- Status text — "Recommended" (zelená) alebo "Available Now" (biela) -->
                                            <!-- Status text — "Recommended" (green) or "Available Now" (white) -->
                                            <Grid Grid.Row="2"
                                                  Margin="0,12,0,0">
                                                <TextBlock FontSize="15"
                                                           Margin="14,0,20,2"
                                                           TextWrapping="Wrap">

                            <!-- Recommended — zelené -->
                            <Run Text="{Binding CurrentFeaturedGame.StatusText}"
                                                    Foreground="#4DC44D">
                                <Run.Style>
                                    <Style TargetType="Run">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentFeaturedGame.IsRecommended}"
                                                                    Value="False">
                                                <Setter Property="Foreground"
                                                                        Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Run.Style>
                            </Run>
                                                </TextBlock>
                                            </Grid>

                                            <!-- Tagy — max 5 — Tags — max 5 -->
                                            <Grid Grid.Row="3"
                                                  Margin="15,6,15,0">
                                                <ItemsControl ItemsSource="{Binding CurrentFeaturedGame.FeaturedTags}"
                                                              VerticalAlignment="Top">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#394148"
                                                                    CornerRadius="2"
                                                                    Padding="6,2"
                                                                    Margin="0,0,3,3">
                                                                <TextBlock Text="{Binding}"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="White"
                                                                           FontSize="11" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>

                                            <!-- Cena — 3 prípady: zľava / free / plná cena -->
                                            <!-- Price — 3 cases: discount / free / full price -->
                                            <Grid Grid.Row="4"
                                                  Margin="10,8,10,10">

                                                <!-- PRÍPAD 1: Zľava — discount badge + prečiarknutá cena + cena v zlave -->
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Left"
                                                            Visibility="{Binding CurrentFeaturedGame.HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">

                                                    <Border Background="#4c6b22"
                                                            CornerRadius="2,0,0,2"
                                                            Padding="6,2">
                                                        <TextBlock Text="{Binding CurrentFeaturedGame.DiscountPercent, StringFormat='-{0}%'}"
                                                                   FontFamily="Arial"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="14"
                                                                   Foreground="#a4d007"
                                                                   FontWeight="Bold" />
                                                    </Border>

                                                    <Border Background="#1C2A35"
                                                            CornerRadius="0,2,2,0"
                                                            Padding="6,2">
                                                        <StackPanel Orientation="Vertical">
                                                            <TextBlock Text="{Binding CurrentFeaturedGame.Price}"
                                                                       FontSize="11"
                                                                       TextDecorations="Strikethrough"
                                                                       Foreground="#738895"
                                                                       HorizontalAlignment="Right" />
                                                            <TextBlock Text="{Binding CurrentFeaturedGame.Price}"
                                                                       FontSize="13"
                                                                       Foreground="#a4d007"
                                                                       FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>

                                                <!-- PRÍPAD 2: Free to Play -->
                                                <TextBlock Text="Free To Play"
                                                           FontSize="14"
                                                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"
                                                           FontWeight="Medium"
                                                           Visibility="{Binding CurrentFeaturedGame.IsFree, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                <!-- PRÍPAD 3: Plná cena — full price (nie zľava, nie free) -->
                                                <TextBlock Text="{Binding CurrentFeaturedGame.Price}"
                                                           FontSize="14"
                                                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"
                                                           FontWeight="Medium">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <!-- Zobraz ak nie je free a nie je zľava -->
                                                                <!-- Show if not free and no discount -->
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding CurrentFeaturedGame.HasDiscount}"
                                                                                   Value="False" />
                                                                        <Condition Binding="{Binding CurrentFeaturedGame.IsFree}"
                                                                                   Value="False" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- Radio buttony — reagujú na FeaturedIndex aj ho menia -->
                            <!-- Radio buttons — react to FeaturedIndex and change it -->
                            <Grid Grid.Row="2"
                                  Margin="0,5,0,0">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Orientation="Horizontal">

                                    <StackPanel.Resources>
                                        <Style TargetType="RadioButton">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="RadioButton">
                                                        <Border x:Name="Dot"
                                                                Width="18"
                                                                Height="11"
                                                                CornerRadius="2"
                                                                Background="#4D657D" />
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked"
                                                                     Value="True">
                                                                <Setter TargetName="Dot"
                                                                        Property="Background"
                                                                        Value="#7A8C9E" />
                                                                <Setter TargetName="Dot"
                                                                        Property="Width"
                                                                        Value="20" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver"
                                                                     Value="True">
                                                                <Setter TargetName="Dot"
                                                                        Property="Background"
                                                                        Value="#64798E" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Margin"
                                                    Value="3,0" />
                                            <Setter Property="Cursor"
                                                    Value="Hand" />
                                        </Style>
                                    </StackPanel.Resources>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,8,0,0">

                                        <!-- Každý RadioButton:
                     IsChecked — svieti ak FeaturedIndex == jeho číslo
                     Command   — klik zmení featured na jeho index
                     GroupName — WPF vyrieši exclusive selection -->
                                        <RadioButton GroupName="FeaturedCarousel"
                                                     IsChecked="{Binding FeaturedIndex, Converter={StaticResource IndexEqualsConverter}, ConverterParameter=0, Mode=OneWay}"
                                                     Command="{Binding SelectFeaturedCommand}"
                                                     CommandParameter="0" />

                                        <RadioButton GroupName="FeaturedCarousel"
                                                     IsChecked="{Binding FeaturedIndex, Converter={StaticResource IndexEqualsConverter}, ConverterParameter=1, Mode=OneWay}"
                                                     Command="{Binding SelectFeaturedCommand}"
                                                     CommandParameter="1" />

                                        <RadioButton GroupName="FeaturedCarousel"
                                                     IsChecked="{Binding FeaturedIndex, Converter={StaticResource IndexEqualsConverter}, ConverterParameter=2, Mode=OneWay}"
                                                     Command="{Binding SelectFeaturedCommand}"
                                                     CommandParameter="2" />

                                        <RadioButton GroupName="FeaturedCarousel"
                                                     IsChecked="{Binding FeaturedIndex, Converter={StaticResource IndexEqualsConverter}, ConverterParameter=3, Mode=OneWay}"
                                                     Command="{Binding SelectFeaturedCommand}"
                                                     CommandParameter="3" />

                                        <RadioButton GroupName="FeaturedCarousel"
                                                     IsChecked="{Binding FeaturedIndex, Converter={StaticResource IndexEqualsConverter}, ConverterParameter=4, Mode=OneWay}"
                                                     Command="{Binding SelectFeaturedCommand}"
                                                     CommandParameter="4" />

                                        <RadioButton GroupName="FeaturedCarousel"
                                                     IsChecked="{Binding FeaturedIndex, Converter={StaticResource IndexEqualsConverter}, ConverterParameter=5, Mode=OneWay}"
                                                     Command="{Binding SelectFeaturedCommand}"
                                                     CommandParameter="5" />

                                        <RadioButton GroupName="FeaturedCarousel"
                                                     IsChecked="{Binding FeaturedIndex, Converter={StaticResource IndexEqualsConverter}, ConverterParameter=6, Mode=OneWay}"
                                                     Command="{Binding SelectFeaturedCommand}"
                                                     CommandParameter="6" />

                                        <RadioButton GroupName="FeaturedCarousel"
                                                     IsChecked="{Binding FeaturedIndex, Converter={StaticResource IndexEqualsConverter}, ConverterParameter=7, Mode=OneWay}"
                                                     Command="{Binding SelectFeaturedCommand}"
                                                     CommandParameter="7" />

                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1"
                              Grid.Column="0">

                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Height="100"
                                    Width="50"
                                    Margin="0,-24,-8,0"
                                    BorderBrush="Transparent"
                                    Foreground="White"
                                    Padding="0"
                                    MinHeight="0"
                                    MinWidth="0">

                                <Button.Background>
                                    <LinearGradientBrush StartPoint="1.0,0"
                                                         EndPoint="0.0,0"
                                                         Opacity="0.25">
                                        <GradientStop Color="#E0000000"
                                                      Offset="0.959" />
                                        <GradientStop Color="#00000000"
                                                      Offset="0" />
                                    </LinearGradientBrush>
                                </Button.Background>

                                <materialDesign:PackIcon Kind="ChevronLeft"
                                                         Width="70"
                                                         Height="70"
                                                         Margin="-11,0,0,0" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1"
                              Grid.Column="2">

                            <Button HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Height="100"
                                    Width="50"
                                    Margin="-8,-24,0,0"
                                    BorderBrush="Transparent"
                                    Foreground="White"
                                    Padding="0"
                                    MinHeight="0"
                                    MinWidth="0">

                                <Button.Background>
                                    <LinearGradientBrush StartPoint="1.0,0"
                                                         EndPoint="0.0,0"
                                                         Opacity="0.25">
                                        <GradientStop Color="#00000000"
                                                      Offset="0.959" />
                                        <GradientStop Color="#E0000000"
                                                      Offset="0" />
                                    </LinearGradientBrush>
                                </Button.Background>

                                <materialDesign:PackIcon Kind="ChevronRight"
                                                         Width="70"
                                                         Height="70"
                                                         Margin="-11,0,0,0" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1"
                              Grid.Column="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="13.5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="1">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="0,25,0,0">

                                    <TextBlock HorizontalAlignment="Left"
                                               Text="Discounts &amp; Events"
                                               Foreground="White"
                                               FontSize="14"
                                               Margin="2,0,0,0" />
                                </Grid>

                                <Grid Grid.Row="1"
                                      Margin="0,10,0,0">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Row="0"
                                          Grid.Column="0">

                                        <StackPanel Background="#1D698D"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical">

                                            <Image Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Source="/Image/Red.png"
                                                   HorizontalAlignment="Stretch"
                                                   Height="150" />

                                            <Grid HorizontalAlignment="Right"
                                                  Height="35"
                                                  Margin="0,5,4,5">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0">

                                                    <Border Background="#4c6b22"
                                                            CornerRadius="2,0,0,2"
                                                            Padding="5,0,5,0">

                                                        <TextBlock Text="-75%"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="27"
                                                                   Foreground="#a4d007"
                                                                   FontWeight="Bold" />
                                                    </Border>
                                                </Grid>

                                                <Grid Grid.Column="1">
                                                    <Border Padding="5,0,5,0"
                                                            Background="#173143">

                                                        <StackPanel Orientation="Vertical">

                                                            <TextBlock Text="39,99€"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Right"
                                                                       TextDecorations="Strikethrough"
                                                                       Foreground="#738895" />

                                                            <TextBlock Text="25,99€"
                                                                       FontSize="15"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="#a4d007"
                                                                       FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="0"
                                          Grid.Column="2">

                                        <StackPanel Background="#1D698D"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical">

                                            <Image Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Source="/Image/Red.png"
                                                   HorizontalAlignment="Stretch"
                                                   Height="150" />

                                            <Grid HorizontalAlignment="Right"
                                                  Height="35"
                                                  Margin="0,5,4,5">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0">

                                                    <Border Background="#4c6b22"
                                                            CornerRadius="2,0,0,2"
                                                            Padding="5,0,5,0">

                                                        <TextBlock Text="-75%"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="27"
                                                                   Foreground="#a4d007"
                                                                   FontWeight="Bold" />
                                                    </Border>
                                                </Grid>

                                                <Grid Grid.Column="1">
                                                    <Border Padding="5,0,5,0"
                                                            Background="#173143">

                                                        <StackPanel Orientation="Vertical">

                                                            <TextBlock Text="39,99€"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Right"
                                                                       TextDecorations="Strikethrough"
                                                                       Foreground="#738895" />

                                                            <TextBlock Text="25,99€"
                                                                       FontSize="15"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="#a4d007"
                                                                       FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="0"
                                          Grid.Column="4">

                                        <StackPanel Background="#1D698D"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical">

                                            <Image Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Source="/Image/Red.png"
                                                   HorizontalAlignment="Stretch"
                                                   Height="150" />

                                            <Grid HorizontalAlignment="Right"
                                                  Height="35"
                                                  Margin="0,5,4,5">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0">

                                                    <Border Background="#4c6b22"
                                                            CornerRadius="2,0,0,2"
                                                            Padding="5,0,5,0">

                                                        <TextBlock Text="-75%"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="27"
                                                                   Foreground="#a4d007"
                                                                   FontWeight="Bold" />
                                                    </Border>
                                                </Grid>

                                                <Grid Grid.Column="1">
                                                    <Border Padding="5,0,5,0"
                                                            Background="#173143">

                                                        <StackPanel Orientation="Vertical">

                                                            <TextBlock Text="39,99€"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Right"
                                                                       TextDecorations="Strikethrough"
                                                                       Foreground="#738895" />

                                                            <TextBlock Text="25,99€"
                                                                       FontSize="15"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="#a4d007"
                                                                       FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="2"
                                          Grid.Column="0">

                                        <StackPanel Background="#1D698D"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical">

                                            <Image Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Source="/Image/Red.png"
                                                   HorizontalAlignment="Stretch"
                                                   Height="150" />

                                            <Grid HorizontalAlignment="Right"
                                                  Height="35"
                                                  Margin="0,5,4,5">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0">

                                                    <Border Background="#4c6b22"
