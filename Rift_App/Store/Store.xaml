                                                      Grid.Column="2">

                                                    <Image Stretch="UniformToFill"
                                                           Source="/Image/Red.png"
                                                           HorizontalAlignment="Left"
                                                           Height="70"
                                                           Width="155" />
                                                </Grid>

                                                <Grid Grid.Row="2"
                                                      Grid.Column="0">

                                                    <Image Stretch="UniformToFill"
                                                           Source="/Image/Red.png"
                                                           HorizontalAlignment="Left"
                                                           Width="155"
                                                           Height="70" />
                                                </Grid>

                                                <Grid Grid.Row="2"
                                                      Grid.Column="2">

                                                    <Image Stretch="UniformToFill"
                                                           Source="/Image/Red.png"
                                                           HorizontalAlignment="Left"
                                                           Height="70"
                                                           Width="155" />
