                                                                        Property="Background"
                                                                        Value="#7A8C9E" />
                                                                <Setter TargetName="Dot"
                                                                        Property="Width"
                                                                        Value="20" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver"
                                                                     Value="True">
