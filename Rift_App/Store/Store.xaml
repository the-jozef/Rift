                                    <RadioButton GroupName="Carousel" />
                                    <RadioButton GroupName="Carousel" />
                                    <RadioButton GroupName="Carousel" />
                                    <RadioButton GroupName="Carousel" />
                                    <RadioButton GroupName="Carousel" />
                                    <RadioButton GroupName="Carousel" />
                                    <RadioButton GroupName="Carousel" />
                                </StackPanel>
                            </StackPanel>
