                                                                        Property="Background"
                                                                        Value="#64798E" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Margin"
                                                    Value="3,0" />
                                            <Setter Property="Cursor"
                                                    Value="Hand" />
                                        </Style>
                                    </StackPanel.Resources>

