                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="50" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock HorizontalAlignment="Left"
                                           Text="Featured &amp; Recommended"
                                           Foreground="White"
                                           FontSize="14"
                                           Margin="2,25,0,10" />
                            </StackPanel>

                            <materialDesign:Card VerticalAlignment="Bottom"
                                                 Width="951"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Background="Transparent"
                                                 materialDesign:ElevationAssist.Elevation="Dp24">
