<UserControl x:Class="Rift_App.Login_Register.AccountSelection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <MediaElement x:Name="BgVideo"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      IsMuted="True"
                      Stretch="UniformToFill"
                      IsHitTestVisible="False" />

        <Border CornerRadius="7.5,7.5,0,0"
                Background="Gray"
                IsHitTestVisible="False"
                Opacity="0.15"
                Panel.ZIndex="1" />

        <Grid>
            
            <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="60,40,0,0">

                        <Image Style="{StaticResource Rift_Logo_login}" />

                        <TextBlock Text="RIFT®"
                                   Foreground="White"
                                   FontSize="25"
                                   FontFamily="Arial"
                                   VerticalAlignment="Center" 
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="1">

                        <StackPanel Orientation="Vertical">

                            <TextBlock Text="Who's playing?"
                                       FontSize="27"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center" />

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,25,0,0">

                                <StackPanel Orientation="Vertical">

                                    <Button Background="Transparent"
                                            BorderBrush="Transparent"
                                            Width="140"
                                            Height="110">
                                        
                                        <Border BorderBrush="#505050"
                                                BorderThickness="2">

                                            <Image Source="/Image/Red.png"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                    </Button>

                                    <StackPanel HorizontalAlignment="Center"
                                                Margin="0,5,0,0">

                                        <TextBlock Text="Guest_test"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                   FontSize="17"
                                                   HorizontalAlignment="Center"/>

                                        <TextBlock Text="Account name: Guest_test"
                                                   Foreground="#8B929A"
                                                   FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                   FontSize="15" />
                                    </StackPanel>
                                </StackPanel>

                                <Button Width="120"
                                        Height="120"
                                        VerticalAlignment="Top"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Command="{Binding DataContext.ShowLoginCommand, 
RelativeSource={RelativeSource AncestorType=Window}}">

                                    <materialIcons:MaterialIcon Kind="Plus"
                                                                Width="45"
                                                                Height="45"
                                                                Foreground="White" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        <Border x:Name="VideoOverlay"
                Background="Black"
                IsHitTestVisible="False"
                Panel.ZIndex="99" />
    </Grid>
</UserControl>