<UserControl x:Class="Rift_App.Login_Register.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             mc:Ignorable="d"
             d:Height="435"
             d:Width="702">
    <UserControl.Resources>
        <Storyboard x:Key="PulseAnimation"
                    RepeatBehavior="Forever"
                    AutoReverse="True">

            <DoubleAnimation Storyboard.TargetName="Elipse1"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.99"
                             To="0.9"
                             Duration="0:0:0:1" />

            <DoubleAnimation Storyboard.TargetName="Elipse1"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.93"
                             To="0.88"
                             Duration="0:0:0:1" />

            <DoubleAnimation Storyboard.TargetName="Elipse2"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.99"
                             To="0.9"
                             Duration="0:0:0:1" />

            <DoubleAnimation Storyboard.TargetName="Elipse2"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.99"
                             To="0.9"
                             Duration="0:0:0:1" />
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PulseAnimation}" />
        </EventTrigger>
    </UserControl.Triggers>
    <Grid>
        <Border Grid.Row="0"
                Background="#1A1B1F"
                CornerRadius="7.5,7.5,0,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="66,28,0,0"
                                Width="Auto"
                                Height="57">
                        <Image Style="{StaticResource Rift_Logo_login}" />

                        <TextBlock Style="{StaticResource Rift_Title_login}" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Left"
                                    Margin="48,20,0,0">


                            <TextBlock Text="SIGN IN WITH ACCOUNT NAME"
                                       HorizontalAlignment="Left"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                       Foreground="#1999FF">
                            </TextBlock>

                            <TextBox   Width="300"
                                       Height="38"
                                       FontSize="15"
                                       Background="#32353C"
                                       Margin="0,5,0,0">

                            </TextBox>

                            <TextBlock Text="PASSWORD"
                                       HorizontalAlignment="Left"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                       Foreground="#AAAAAA"
                                       Margin="0,15,0,0">
                            </TextBlock>

                            <PasswordBox   Width="300"
                                           Height="38"
                                           FontSize="15"
                                           Background="#32353C"
                                           Margin="0,5,0,0">
                            </PasswordBox>

                            <Button Content="Sign in"
                                    Width="230"
                                    Height="50"
                                    Foreground="White"
                                    FontSize="16"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Margin="05,25,0,0">
                                <Button.Background>
                                    <LinearGradientBrush>
                                        <GradientStop Color="#FF40AEFF"
                                                      Offset="0.138" />
                                        <GradientStop Color="#FF2C76FF"
                                                      Offset="0.736" />
                                    </LinearGradientBrush>
                                </Button.Background>

                            </Button>
                        </StackPanel>
                    </Grid>

                </Grid>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="360" />
                        <RowDefinition Height="Auto" />

                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="318,0,0,0"
                                Width="33"
                                HorizontalAlignment="Left">

                        <Button Style="{StaticResource Rift_CLoseButton}"
                                Margin="0,0,0,0"
                                Height="30"
                                Width="33"
                                materialDesign:ButtonAssist.CornerRadius="0,7.5,0,0"
                                Command="{Binding CloseWindowCommand}">

                            <materialIcons:MaterialIcon Style="{StaticResource Rift_WindowState_Icons}"
                                                        Kind="Close"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>

                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Height="Auto"
                                Width="301"
                                Margin="50,0,0,0">

                        <TextBlock Text="Don't have a RIFT account?"
                                   Foreground="#B0B0B0"
                                   FontWeight="Regular"
                                   FontSize="12"
                                   Margin="0,0,10,0">


                        </TextBlock>
                        <Button Content="Create a Free Account"
                                Width="Auto"
                                Height="23"
                                Background="Transparent"
                                FontWeight="Regular"
                                FontSize="12"
                                Foreground="#B0B0B0">


                        </Button>
                    </StackPanel>




                    <Canvas Grid.Row="1">

                        <Ellipse Canvas.Left="100"
                                 Canvas.Top="70"
                                 Width="1.5"
                                 Height="1.5"
                                 Fill="#53AFFC" />
                        <Ellipse Canvas.Left="200"
                                 Canvas.Top="22"
                                 Width="2"
                                 Height="2"
                                 Fill="#53AFFC" />
                        <Ellipse Canvas.Left="220"
                                 Canvas.Top="80"
                                 Width="1"
                                 Height="1"
                                 Fill="#53AFFC" />

                        <Ellipse Canvas.Left="325"
                                 Canvas.Top="90"
                                 Width="1.5"
                                 Height="1.5"
                                 Fill="#53AFFC" />
                        <Ellipse Canvas.Left="290"
                                 Canvas.Top="50"
                                 Width="1"
                                 Height="1"
                                 Fill="#53AFFC" />
                        <Ellipse Canvas.Left="60"
                                 Canvas.Top="140"
                                 Width="1.5"
                                 Height="1.5"
                                 Fill="#53AFFC" />

                        <Ellipse Canvas.Left="30"
                                 Canvas.Top="200"
                                 Width="1"
                                 Height="1"
                                 Fill="#53AFFC" />


                        <Ellipse Canvas.Left="66"
                                 Canvas.Top="285"
                                 Width="1"
                                 Height="1"
                                 Fill="#53AFFC" />
                        <Ellipse Canvas.Left="120"
                                 Canvas.Top="250"
                                 Width="1.5"
                                 Height="1.5"
                                 Fill="#53AFFC" />
                        <Ellipse Canvas.Left="325"
                                 Canvas.Top="220"
                                 Width="2"
                                 Height="2"
                                 Fill="#53AFFC" />
                        <Ellipse Canvas.Left="318"
                                 Canvas.Top="283"
                                 Width="2"
                                 Height="2"
                                 Fill="#53AFFC" />
                        <Ellipse Canvas.Left="220"
                                 Canvas.Top="280"
                                 Width="2"
                                 Height="2"
                                 Fill="#53AFFC" />
                    </Canvas>
                    <Canvas Grid.Row="1">

                        <Ellipse Width="360"
                                 Height="320"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Opacity="0.15"
                                 RenderTransformOrigin="0.5,0.5"
                                 Canvas.Left="43">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#FF1E6FA8"
                                                  Offset="0" />
                                    <GradientStop Color="#FF0A3A5C"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.StrokeThickness>1</Ellipse.StrokeThickness>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse1"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse Width="310"
                                 Height="260"
                                 Opacity="0.15"
                                 RenderTransformOrigin="0.5,0.5"
                                 Canvas.Left="77"
                                 Canvas.Top="31"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#FF2E8FC8"
                                                  Offset="0" />
                                    <GradientStop Color="#FF0D4870"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.StrokeThickness>1</Ellipse.StrokeThickness>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse2"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="Ring1"
                                 Width="290"
                                 Height="240"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Opacity="0.22"
                                 RenderTransformOrigin="0.5,0.5"
                                 Canvas.Left="71"
                                 Canvas.Top="60">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#FF4AB8E8"
                                                  Offset="0" />
                                    <GradientStop Color="#FF1A6A9A"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.StrokeThickness>1.5</Ellipse.StrokeThickness>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="MyScale2"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse Width="250"
                                 Height="190"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Opacity="0.22"
                                 RenderTransformOrigin="0.5,0.5"
                                 Canvas.Left="91"
                                 Canvas.Top="87">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#FF4AB8E8"
                                                  Offset="0" />
                                    <GradientStop Color="#FF1A6A9A"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.StrokeThickness>1.5</Ellipse.StrokeThickness>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="k"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>


                        <Ellipse x:Name="GlowEllipse"
                                 Width="173"
                                 Height="151"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Opacity="0.5"
                                 RenderTransformOrigin="0.5,0.5"
                                 Canvas.Left="130"
                                 Canvas.Top="114">
                            <Ellipse.Fill>

                                <RadialGradientBrush GradientOrigin="0.45,0.40"
                                                     Center="0.45,0.40"
                                                     RadiusX="0.6"
                                                     RadiusY="0.6">
                                    <GradientStop Color="#FF8ADCF8"
                                                  Offset="0.00" />
                                    <GradientStop Color="#FF38A8DC"
                                                  Offset="0.084" />
                                    <GradientStop Color="#FF1060A0"
                                                  Offset="0.432" />
                                    <GradientStop Color="#FF062240"
                                                  Offset="0.69" />
                                    <GradientStop Color="#00000000"
                                                  Offset="1.00" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>

                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="GlowScaleX"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>

                            <Ellipse.Effect>
                                <BlurEffect Radius="28" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>


















                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
