<UserControl x:Class="Rift_App.Login_Register.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             mc:Ignorable="d"
             Height="517"
             Width="771">
    <Grid>
        <Border Grid.Row="0"
                Background="#1C1E22"
                CornerRadius="7.5,7.5,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="307" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Width="Auto"
                            Height="Auto">
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="700" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <StackPanel HorizontalAlignment="Left"
                                    Margin="20,0,0,0"
                                    Width="Auto"
                                    Orientation="Horizontal">
                            <Image Source="C:\Users\Moskalm25\source\repos\oki\Rift_App\Icons\Rift_logo.png"
                                   Width="40"
                                   Height="40">

                            </Image>
                            <Label Content="RIFT"
                                   HorizontalAlignment="Left"
                                   FontSize="24"
                                   Foreground="#E0E1E6"
                                   FontFamily="Noto Sans"
                                   FontWeight="Bold">

                            </Label>

                        </StackPanel>


                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,5,0,0"
                                    HorizontalAlignment="Right">
                            <materialIcons:MaterialIcon Kind="Close"
                                                        Width="30"
                                                        Margin="0,0,-25,0">

                            </materialIcons:MaterialIcon>
                        </StackPanel>




                    </Grid>

                </StackPanel>
                <StackPanel Grid.Row="1">
                    <StackPanel Margin="20,50,200,0"
                                HorizontalAlignment="left"
                                Orientation="Vertical"
                                Height="Auto"
                                Width="579">
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Width="565"
                                 materialDesign:HintAssist.Hint="Your name here..."
                                 materialDesign:HintAssist.Foreground="#1B77C2"
                                 FontSize="24"
                                 Background="#32353C"
                                 RenderTransformOrigin="0.5,0.5">
                            <TextBox.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <SkewTransform AngleY="0" />
                                    <RotateTransform />
                                    <TranslateTransform Y="0" />
                                </TransformGroup>
                            </TextBox.RenderTransform>
                        </TextBox>
                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,30,0,0"
                                 Width="565"
                                 materialDesign:HintAssist.Hint="Password"
                                 materialDesign:HintAssist.Foreground="#1B77C2"
                                 FontSize="24"
                                 Background="#32353C">

                        </TextBox>
                        <Button Content="Sign in"
                                FontSize="15"
                                Margin="0,20,0,0"
                                Height="50"
                                Width="300"
                                Foreground="#FFFBF7F7">
                            <Button.Background>
                                <LinearGradientBrush EndPoint="0.5,1"
                                                     StartPoint="0.5,0">
                                    <GradientStop Color="#FF487AF5"
                                                  Offset="0.951" />
                                    <GradientStop Color="#FF265ADA"
                                                  Offset="0.348" />
                                </LinearGradientBrush>
                            </Button.Background>


                        </Button>








                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <StackPanel Margin="0,120,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Height="35"
                                Width="137">
                        <Button Content="Create a Free Account"
                                Background="Transparent"
                                Foreground="White"
                                FontSize="10" />











                    </StackPanel>







                </StackPanel>



            </Grid>
        </Border>
    </Grid>
</UserControl>
