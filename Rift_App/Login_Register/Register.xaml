<UserControl x:Class="Rift_App.Login_Register.Register"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    
    <UserControl.Resources>
        <Storyboard x:Key="LoadingAnimation"
                    RepeatBehavior="Forever"
                    Duration="0:0:3.8">

            <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse1"
                                          Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                          Duration="0:0:6"
                                          BeginTime="0:0:0">
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:0" />
                <LinearColorKeyFrame Value="#40AEF1"
                                     KeyTime="0:0:0.8" />
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:1.6" />
            </ColorAnimationUsingKeyFrames>

            <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse2"
                                          Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                          Duration="0:0:6"
                                          BeginTime="0:0:0.6">
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:0" />
                <LinearColorKeyFrame Value="#40AEF1"
                                     KeyTime="0:0:0.8" />
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:1.6" />
            </ColorAnimationUsingKeyFrames>

            <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse3"
                                          Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                          Duration="0:0:6"
                                          BeginTime="0:0:1.2">
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:0" />
                <LinearColorKeyFrame Value="#40AEF1"
                                     KeyTime="0:0:0.8" />
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:1.6" />
            </ColorAnimationUsingKeyFrames>

            <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse4"
                                          Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                          Duration="0:0:6"
                                          BeginTime="0:0:1.8">
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:0" />
                <LinearColorKeyFrame Value="#40AEF1"
                                     KeyTime="0:0:0.8" />
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:1.6" />
            </ColorAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource LoadingAnimation}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Border Grid.Row="0"
                CornerRadius="7.5,7.5,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="1,0"
                                     EndPoint="0,1">
                    <GradientStop Color="#FF1D1D25"
                                  Offset="1" />
                    <GradientStop Color="#1D1D21" />
                    <GradientStop Color="#FF1E1E26"
                                  Offset="0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Width="Auto"
                                Height="Auto"
                                HorizontalAlignment="Left"
                                Margin="50,40,0,0">

                        <Image Style="{StaticResource Rift_Logo_login2}" />

                        <StackPanel Orientation="Vertical">

                            <TextBlock Style="{StaticResource Rift_Title_login}" 
                                       Margin="10,-1,0,0"
                                       FontSize="30"/>

                            <TextBlock Text="New Account"
                                       Foreground="#9E9E9E"
                                       FontSize="15" 
                                       Margin="9,-4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Orientation="Vertical"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Margin="62,50,0,0">

                        <TextBlock Text="Connect With Steam"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                   FontSize="23.5" />

                        <TextBlock Text="Link your Steam account to get started"
                                   Foreground="#9E9E9E"
                                   FontSize="13.4" 
                                   Margin="2,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Vertical"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Margin="52,60,0,0">

                        <Button Style="{StaticResource Rift_Steam_button}"
                                Width="220"
                                Height="43"
                                Command="{Binding SteamLoginCommand}">

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <materialIcons:MaterialIcon Style="{StaticResource Rift_Steam_Icon}" 
                                                            Width="25"
                                                            Height="25"/>
                                <TextBlock Style="{StaticResource Rift_Steam_Textblock}"
                                           FontSize="14.5"
                                           FontWeight="Regular"
                                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                           Text="Connect with Steam" />
                            </StackPanel>
                        </Button>

                        <Grid Margin="0,28,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="133.5" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,12,0"
                                    Style="{StaticResource Rift_Border_lines}">
                                <Border.Background>
                                    <LinearGradientBrush EndPoint="0.0,0"
                                                         StartPoint="1.0,0">
                                        <GradientStop Offset="1" />
                                        <GradientStop Color="#969696"
                                                      Offset="0.294" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource Rift_TextBlock_or}" 
                                       FontSize="13"
                                       Margin="12,-4,12,0"/>

                            <Border Grid.Column="2"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource Rift_Border_lines}">

                                <Border.Background>
                                    <LinearGradientBrush EndPoint="0.0,0"
                                                         StartPoint="1.0,0">
                                        <GradientStop Offset="0" />
                                        <GradientStop Color="#969696"
                                                      Offset="0.294" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <Button Background="Transparent"
                                Width="250"
                                Height="40"
                                Foreground="White"
                                BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <materialIcons:MaterialIcon Kind="ArrowLeft"
                                                            Height="14"
                                                            Width="14"
                                                            Margin="0,4,6,0" />
                                <TextBlock Text="Already have an account?"
                                           FontSize="15" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="120" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="120" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Width="33"
                                HorizontalAlignment="Right">

                        <Button Style="{StaticResource Rift_CLoseButton}"
                                Height="30"
                                Margin="0,0,0,0"
                                Width="33"
                                materialDesign:ButtonAssist.CornerRadius="0,7.5,0,0"
                                Command="{Binding DataContext.LoginLoadingCommand, 
RelativeSource={RelativeSource AncestorType=Window}}">

                            <materialIcons:MaterialIcon Style="{StaticResource Rift_WindowState_Icons}"
                                                        Kind="Close"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="Auto"
                                Height="Auto">

                        <StackPanel>
                            <Border Width="93"
                                    Height="93"
                                    CornerRadius="50"
                                    BorderBrush="#325C88"
                                    BorderThickness="0.5">

                                <Border.Effect>
                                    <DropShadowEffect Color="#3371B0"
                                                      BlurRadius="70"
                                                      ShadowDepth="0" />
                                </Border.Effect>

                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,1"
                                                         Opacity="0.8">
                                        <GradientStop Color="#FF1B2838"
                                                      Offset="0" />
                                        <GradientStop Color="#FF2A475E"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>

                                <materialIcons:MaterialIcon Kind="Steam"
                                                            Width="41"
                                                            Height="41"
                                                            Foreground="White"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                </materialIcons:MaterialIcon>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="10,0,10,0">

                            <Ellipse Width="12"
                                     Height="8"
                                     Margin="2"
                                     x:Name="Ellipse1"
                                     Opacity="0.7">
                                                                
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="Transparent" />
                                </Ellipse.Fill>
                                
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF007EFF"
                                                      BlurRadius="100"
                                                      ShadowDepth="0" />
                                </Ellipse.Effect>
                               
                            </Ellipse>

                            <Ellipse Width="12"
                                     Height="8"
                                     Margin="2"
                                     x:Name="Ellipse2"
                                     Opacity="0.8">

                                <Ellipse.Fill>

                                    <SolidColorBrush Color="Transparent" />
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF007EFF"
                                                      BlurRadius="100"
                                                      ShadowDepth="0" />
                                </Ellipse.Effect>
                            </Ellipse>

                            <Ellipse Width="12"
                                     Height="8"
                                     Margin="2"
                                     x:Name="Ellipse3"
                                     Opacity="0.8">

                                <Ellipse.Fill>
                                    <SolidColorBrush Color="Transparent" />
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF007EFF"
                                                      BlurRadius="100"
                                                      ShadowDepth="0" />
                                </Ellipse.Effect>
                            </Ellipse>

                            <Ellipse Width="12"
                                     Height="8"
                                     Margin="2"
                                     x:Name="Ellipse4"
                                     Opacity="0.8">

                                <Ellipse.Fill>
                                    <SolidColorBrush Color="Transparent" />
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF007EFF"
                                                      BlurRadius="100"
                                                      ShadowDepth="0" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </StackPanel>
                        
                        <StackPanel>

                            <Border Width="95"
                                    Height="95"
                                    CornerRadius="20">

                                <Border.Effect>
                                    <DropShadowEffect Color="#83289C"
                                                      BlurRadius="80"
                                                      ShadowDepth="1" />
                                </Border.Effect>
                            
                                <Image Style="{StaticResource Rift_Logo_login3}"/>

                            </Border>
                        </StackPanel>
                    </StackPanel>












                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>