<UserControl x:Class="Rift_App.Login_Register.Register"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             xmlns:converters="clr-namespace:Rift_App.Converters"
             xmlns:vm="clr-namespace:Rift_App.ViewModels"
             mc:Ignorable="d"
             Height="438"
             Width="705">

    <Grid>
        <Border Grid.Row="0"
                CornerRadius="7.5,7.5,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="1,0"
                                     EndPoint="0,1">
                    <GradientStop Color="#FF1D1D25"
                                  Offset="1" />
                    <GradientStop Color="#1D1D21" />
                    <GradientStop Color="#FF1E1E26"
                                  Offset="0" />
                </LinearGradientBrush>
            </Border.Background>


            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                
                <Grid.RowDefinitions>
                    <RowDefinition  Height="Auto" />
                    <RowDefinition  Height="Auto" />
                        <RowDefinition  Height="Auto" />
                        <RowDefinition  Height="Auto" />
                    <RowDefinition  Height="Auto" />
                </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Style="{StaticResource Rift_Title_stackpanel}"
                                Margin="50,35,0,0">

                        <Image Style="{StaticResource Rift_Logo_register}" />

                        <StackPanel Orientation="Vertical">

                            <TextBlock Style="{StaticResource Rift_Title_login}"
                                       Margin="10,-1,0,0"
                                       FontSize="30" />

                            <TextBlock Style="{StaticResource Rift_TextBlock_NewAccount}" 
                                       Text="Profile"
                                       FontSize="19"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Style="{StaticResource Rift_Stackpanel_Information}"
                                Margin="68,25,0,0">

                        <TextBlock Style="{StaticResource Rift_Textblock_Connection}"
                                   Text="Create your Account" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                            Style="{StaticResource Rift_Layout_Stackpanel}"
                            HorizontalAlignment="Left"
                            Margin="90,15,0,0">

                    <TextBlock Style="{StaticResource Rift_SignIn_Title}"
                               Text="Account name" />

                    <TextBox Style="{StaticResource Rift_SignIn_AccountName}"
                             Text="{Binding SetupUsername, UpdateSourceTrigger=PropertyChanged}"
                             x:Name="UsernameBox"/>

                    <TextBlock Style="{StaticResource Rift_Password_Title}" />

                        <PasswordBox Style="{StaticResource Rift_SignIn_PasswordBox}"
                                     x:Name="PasswordBox" />
                    </StackPanel>

                    <StackPanel Grid.Row="3"
                                Style="{StaticResource Rift_Stackpanel_Button Layout}"
                                Margin="90,20,0,0">

                        <Button Style="{StaticResource Rift_SignIn_Button}"
                                Command="{Binding SignInCommand}"
                                Content="Create Account"
                                Margin="10,0,0,0" />

                        <Grid Margin="0,23,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="133.5" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,12,0"
                                    Style="{StaticResource Rift_Border_lines}">
                                <Border.Background>
                                    <LinearGradientBrush EndPoint="0.0,0"
                                                         StartPoint="1.0,0">
                                        <GradientStop Offset="1" />
                                        <GradientStop Color="#969696"
                                                      Offset="0.294" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource Rift_TextBlock_or}"
                                       FontSize="13"
                                       Margin="12,-4,12,0" />

                            <Border Grid.Column="2"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource Rift_Border_lines}">

                                <Border.Background>
                                    <LinearGradientBrush EndPoint="0.0,0"
                                                         StartPoint="1.0,0">
                                        <GradientStop Offset="0" />
                                        <GradientStop Color="#969696"
                                                      Offset="0.294" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <Button Style="{StaticResource Rift_Return_Button}"
                                Margin="-10,0,0,0"
                                Content="Back"
                                FontSize="25" />
                    </StackPanel>
                </Grid>
                
                
                
                
                
                
                
                
                
                <StackPanel Grid.Column="1"
                            Margin="0,0,0,0"
                            Width="33"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right">

                    <Button Style="{StaticResource Rift_CLoseButton}"
                            Margin="0,0,0,0"
                            Height="30"
                            Width="33"
                            materialDesign:ButtonAssist.CornerRadius="0,7.5,0,0"
                            Command="{Binding CloseWindowCommand}">
                        <materialIcons:MaterialIcon Style="{StaticResource Rift_WindowState_Icons}"
                                                    Kind="Close"
                                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                    </Button>
                </StackPanel>
            </Grid>

        </Border>
    </Grid>
</UserControl>