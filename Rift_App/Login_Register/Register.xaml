<UserControl x:Class="Rift_App.Login_Register.Register"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid>
        <Border Background="#1C1E22"
                CornerRadius="7.5,7.5,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Margin="0,0,-9,-1">
                <StackPanel Margin="0,0,0,20">

                    <StackPanel Visibility="{Binding IsSetupMode,
Converter={StaticResource BooleanToVisibilityConverter}}"
                                Margin="34,20,34,20">
                        <TextBlock Text="VYTVOR SI RIFT PROFIL"
                                   Foreground="White"
                                   FontSize="24"
                                   Margin="0,0,0,6" />
                        <!-- Steam meno ako info -->
                        <TextBlock Foreground="#1999FF"
                                   FontSize="12"
                                   Margin="0,0,0,20">
<Run Text="Prihlaseny cez Steam: " />
<Run Text="{Binding CurrentSteamName}"
                            FontWeight="Bold" />
                        </TextBlock>
                        <!-- Rift username -->
                        <TextBlock Text="RIFT MENO"
                                   Foreground="#1999FF"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBox Height="38"
                                 Width="400"
                                 HorizontalAlignment="Left"
                                 Background="#32353C"
                                 Foreground="White"
                                 BorderThickness="0"
                                 FontSize="14"
                                 Margin="0,5,0,15"
                                 Text="{Binding SetupUsername, UpdateSourceTrigger=PropertyChanged}" />
                        <!-- Rift heslo -->
                        <TextBlock Text="HESLO"
                                   Foreground="#AAAAAA"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <PasswordBox x:Name="SetupPasswordBox"
                                     Height="38"
                                     Width="400"
                                     HorizontalAlignment="Left"
                                     Background="#32353C"
                                     Foreground="White"
                                     BorderThickness="0"
                                     FontSize="14"
                                     Margin="0,5,0,6"
                                     PasswordChanged="SetupPasswordBox_PasswordChanged" />
                        <!-- Chybova sprava -->
                        <TextBlock Text="{Binding SetupError}"
                                   Foreground="#FF4444"
                                   FontSize="11"
                                   Margin="0,0,0,10"
                                   Visibility="{Binding HasSetupError,
Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <!-- Tlacidla -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,10,0,0">
                            <Button Content="Vytvorit ucet"
                                    Width="180"
                                    Height="44"
                                    Foreground="White"
                                    FontSize="14"
                                    Command="{Binding FinishSetupCommand}"
                                    Margin="0,0,12,0">
                                <Button.Background>
                                    <LinearGradientBrush>
                                        <GradientStop Color="#FF40AEFF"
                                                      Offset="0" />
                                        <GradientStop Color="#FF2C76FF"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                            <Button Content="Zrusit"
                                    Width="100"
                                    Height="44"
                                    Background="#32353C"
                                    Foreground="#AAAAAA"
                                    BorderThickness="0"
                                    FontSize="14"
Command="{Binding CancelSetupCommand}"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Normalna cast - skryta ked je setup mod -->
                    <StackPanel Visibility="{Binding IsSetupMode,
Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <!-- ... tvoj existujuci Register obsah ... -->
                        <!-- Steam tlacidlo -->
                        <Button Width="300"
                                Height="50"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,10"
                                Command="{Binding SteamLoginCommand}">
                            <Button.Background>
                                <LinearGradientBrush>
                                    <GradientStop Color="#FF1B2838"
                                                  Offset="0" />
                                    <GradientStop Color="#FF2A475E"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Button.Background>
                            <TextBlock Text="Prihlasit cez Steam"
                                       Foreground="White"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>