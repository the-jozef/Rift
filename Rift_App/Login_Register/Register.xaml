<UserControl x:Class="Rift_App.Login_Register.Register"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid>
        <Border Grid.Row="0"
                CornerRadius="7.5,7.5,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1"
                                     StartPoint="0.5,0">
                    <GradientStop Color="#1E1E26" />
                    <GradientStop Color="#1A1B1F"
                                  Offset="0.788" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Style="{StaticResource Rift_LoginTitle_stackpanel}">

                        <Image Style="{StaticResource Rift_Logo_login}" />

                        <StackPanel Orientation="Vertical">

                            <TextBlock Style="{StaticResource Rift_Title_login}" />

                            <TextBlock Text="New Account"
                                       Foreground="#AAAAAA"
                                       FontSize="15" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Orientation="Vertical"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Margin="50,30,0,0">

                        <TextBlock Text="Connect With Steam"
                                   Foreground="White"
                                   FontSize="20" />

                        <TextBlock Text="Link your Steam account to get started"
                                   Foreground="#AAAAAA"
                                   FontSize="15" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Vertical"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Margin="50,30,0,0">

                        <Button Style="{StaticResource Rift_Steam_button}"
                                Command="{Binding SteamLoginCommand}">

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <materialIcons:MaterialIcon Style="{StaticResource Rift_Steam_Icon}" />
                                <TextBlock Style="{StaticResource Rift_Steam_Textblock}"
                                           Text="Connect with Steam" />
                            </StackPanel>
                        </Button>

                        <Grid Margin="0,20,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="133.5" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,12,0"
                                    Style="{StaticResource Rift_Border_lines}">
                                <Border.Background>
                                    <LinearGradientBrush EndPoint="0.0,0"
                                                         StartPoint="1.0,0">
                                        <GradientStop Offset="1" />
                                        <GradientStop Color="#969696"
                                                      Offset="0.294" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource Rift_TextBlock_or}" />

                            <Border Grid.Column="2"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource Rift_Border_lines}">

                                <Border.Background>
                                    <LinearGradientBrush EndPoint="0.0,0"
                                                         StartPoint="1.0,0">
                                        <GradientStop Offset="0" />
                                        <GradientStop Color="#969696"
                                                      Offset="0.294" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <Button Background="Gray">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <materialIcons:MaterialIcon Kind="ArrowLeft"
                                                            Height="14"
                                                            Width="14"
                                                            Margin="0,4,6,0" />
                                <TextBlock Text="Already have an account?"
                                           FontSize="15" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>



                    <materialDesign:Card Grid.Row="1"
                                        >
                        <materialDesign:Card.Background>
                            <LinearGradientBrush EndPoint="0.5,1"
                                                 StartPoint="0.5,0"
                                                 Opacity="0.1">
                                <GradientStop Color="#57B7FF" />
                            </LinearGradientBrush>
                        </materialDesign:Card.Background>

                        <StackPanel Orientation="Horizontal">
                            
                            <materialIcons:MaterialIcon Kind="Steam"
                                                        Width="20"
                                                        Height="20">
                            </materialIcons:MaterialIcon>

                            <TextBlock Text="Steam">


                            </TextBlock>
                        </StackPanel>
                    </materialDesign:Card>











                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>