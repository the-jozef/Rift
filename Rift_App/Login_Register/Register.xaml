<UserControl x:Class="Rift_App.Login_Register.Register"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid>
        <Border Background="#1C1E22"
                CornerRadius="7.5,7.5,0,0">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition  Height="Auto"/>
                    <RowDefinition  Height="Auto" />
                    <RowDefinition  Height="*" />
                    <RowDefinition  Height="*" />
                </Grid.RowDefinitions>


                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Vertical"
                                Margin="50,35,0,0">

                        <TextBlock Text="CREATE YOUR ACCOUNT"
                                   Foreground="White"
                                   FontSize="24"
                                   Margin="0,0,0,6" />

                        <StackPanel HorizontalAlignment="Left"
                                    Orientation="Horizontal"
                                    Margin="5,0,0,0">
                            <materialIcons:MaterialIcon Kind="CheckCircleOutline"
                                                        Width="20"
                                                        Height="20"
                                                        Foreground="Green" />

                            <TextBlock Width="Auto"
                                       Height="20"
                                       Text="Logged with Steam"
                                       Foreground="Green"
                                       FontSize="15"
                                       Margin="10,0,0,0">

                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="0,0,0,00"
                                Width="33"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right">

                        <Button Style="{StaticResource Rift_CLoseButton}"
                                Margin="0,0,0,0"
                                Height="30"
                                Width="33"
                                materialDesign:ButtonAssist.CornerRadius="0,7.5,0,0"
                                Command="{Binding CloseWindowCommand}">
                            <materialIcons:MaterialIcon Style="{StaticResource Rift_WindowState_Icons}"
                                                        Kind="Close"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>
                    </StackPanel>
                </Grid>


                <StackPanel Grid.Row="1"
                            Style="{StaticResource Rift_Layout_Stackpanel}"
                            HorizontalAlignment="Left"
                            Margin="90,25,0,0">

                    <TextBlock Style="{StaticResource Rift_SignIn_Title}"
                               Text="Account name"/>

                    <TextBox Style="{StaticResource Rift_SignIn_AccountName}"
                             Text="{Binding SetupUsername, UpdateSourceTrigger=PropertyChanged}"
                             x:Name="UsernameBox" />

                    <TextBlock Style="{StaticResource Rift_Password_Title}" />

                    <PasswordBox Style="{StaticResource Rift_SignIn_PasswordBox}"
                                 x:Name="PasswordBox"
                                  />

                  

                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Grid.Row="2"
                            Margin="120,0,0,0">
                    <Button Style="{StaticResource Rift_SignIn_Button}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Command="{Binding SignInCommand}" />

                    <Button Content="Cancel"
                            Width="100"
                            Height="44"
                            VerticalAlignment="Top"
                            Margin="0,23,0,0"
                            Background="#32353C"
                            Foreground="#AAAAAA"
                            BorderThickness="0"
                            FontSize="14"
                            Command="{Binding CancelSetupCommand}" />

                </StackPanel>

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button   Width="300"
                              Height="50"
                              HorizontalAlignment="Center"
                              Margin="0,10,0,10"
                              Background="Transparent"
                             Command="{Binding SteamLoginCommand}" >
                        <StackPanel Orientation="Horizontal">

                            <materialIcons:MaterialIcon Kind="
                                                     ArrowLeft"
                                                        Foreground="White"
                                                        Height="20"
                                                        Width="25">


                            </materialIcons:MaterialIcon>

                            <TextBlock Text="Back to store"
                                       Foreground="White"
                                       FontSize="20">
                                
                            </TextBlock>


                        </StackPanel>


                    </Button>
                    
                    
                </StackPanel>



                <StackPanel Grid.Row="3"
                            HorizontalAlignment="Right">
                    <TextBlock Text="{Binding SetupError}"
                           Foreground="#FF4444"
                           FontSize="11"
                           Margin="0,0,0,10" />
                             
                   
               
                <Button Width="50"
                        Height="20"
                        Command="{Binding DataContext.ShowLoginCommand, 
  RelativeSource={RelativeSource AncestorType=Window}}">

                </Button>
            </StackPanel>



            </Grid>
        </Border>
    </Grid>
</UserControl>