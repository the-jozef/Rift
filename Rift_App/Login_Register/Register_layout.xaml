<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">

    <!-- Title Stackpanel -->
    <Style x:Key="Rift_Title_stackpanel"
           TargetType="StackPanel">

        <Setter Property="Orientation"
                Value="Horizontal" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="Auto" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="60,40,0,0" />
    </Style>

    <!-- Logo -->
    <Style x:Key="Rift_Logo_register"
           TargetType="Image">

        <Setter Property="Source"
                Value="/Icons/Rift_logo.png" />
        <Setter Property="Width"
                Value="65" />
        <Setter Property="Height"
                Value="65" />
        <Setter Property="Margin"
                Value="0,-10,0,-10" />
        <Setter Property="Stretch"
                Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode"
                Value="HighQuality" />
        <Setter Property="materialDesign:ElevationAssist.Elevation"
                Value="Dp4" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry Center="32.5,32.5"
                                 RadiusX="32.5"
                                 RadiusY="32.5" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Textblock for New Account -->
    <Style x:Key="Rift_TextBlock_NewAccount"
           TargetType="TextBlock">

        <Setter Property="Text"
                Value="New Account" />
        <Setter Property="Margin"
                Value="9,-4,0,0" />
        <Setter Property="Foreground"
                Value="#9E9E9E" />
        <Setter Property="FontSize"
                Value="15" />
    </Style>

    <!-- Stackpanel for Information -->
    <Style x:Key="Rift_Stackpanel_Information"
           TargetType="StackPanel">

        <Setter Property="Orientation"
                Value="Vertical" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="Margin"
                Value="72,50,0,0" />
    </Style>

    <!-- Textblock for Connect with Steam -->
    <Style x:Key="Rift_Textblock_Connection"
           TargetType="TextBlock">

        <Setter Property="Text"
                Value="Connect With Steam" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="23.5" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
        <Setter Property="FontFamily"
                Value="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
    </Style>

    <!-- Textblock for Link Account -->
    <Style x:Key="Rift_Textblock_AccountLink"
           TargetType="TextBlock">

        <Setter Property="Text"
                Value="Link your Steam account to get started" />
        <Setter Property="Margin"
                Value="2,0,0,0" />
        <Setter Property="Foreground"
                Value="#9E9E9E" />
        <Setter Property="FontSize"
                Value="13.4" />
    </Style>

    <!-- Stackpanel for Button layout -->
    <Style x:Key="Rift_Stackpanel_Button Layout"
           TargetType="StackPanel">

        <Setter Property="Orientation"
                Value="Vertical" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="Margin"
                Value="52,60,0,0" />
    </Style>

    <!-- TextBlock for Steam sign up -->
    <Style x:Key="Rift_Steam_Textblock_register"
           TargetType="TextBlock">

        <Setter Property="Text"
                Value="Connect with Steam" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="14.5" />
        <Setter Property="FontWeight"
                Value="Regular" />
        <Setter Property="FontFamily"
                Value="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
    </Style>

    <!-- Button for Already have an Account -->
    <Style x:Key="Rift_Return_Button"
           TargetType="Button">

        <Setter Property="Content"
                Value="Already have an account ?" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="40" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="Margin"
                Value="7,0,0,0" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="FontWeight"
                Value="Medium" />
        <Setter Property="FontStretch"
                Value="Medium" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="OverridesDefaultStyle"
                Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <materialIcons:MaterialIcon x:Name="Icon"
                                                    Kind="ArrowLeft"
                                                    Height="14"
                                                    Width="14"
                                                    Margin="0,2,6,0" />
                        <TextBlock x:Name="text"
                               Text="{TemplateBinding Content}"
                               FontSize="{TemplateBinding FontSize}"
                               FontWeight="{TemplateBinding FontWeight}"
                               FontStretch="{TemplateBinding FontStretch}"
                               Foreground="{TemplateBinding Foreground}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="text"
                                    Property="Foreground"
                                    Value="#F5F2F2" />
                            <Setter TargetName="Icon"
                                    Property="Foreground"
                                    Value="#F5F2F2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Stackpanel for Logo -->
    <Style x:Key="Rift_Stackpanel_Logo"
           TargetType="StackPanel">

        <Setter Property="Orientation"
                Value="Horizontal" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="Auto" />
    </Style>

    <Style x:Key="Rift_Border_Steam"
           TargetType="Border">

        <Setter Property="Width"
                Value="93" />
        <Setter Property="Height"
                Value="93" />
        <Setter Property="BorderBrush"
                Value="#325C88" />
        <Setter Property="BorderThickness"
                Value="0.5" />
        <Setter Property="CornerRadius"
                Value="50" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#3371B0"
                                  BlurRadius="70"
                                  ShadowDepth="0" />
            </Setter.Value>
        </Setter>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1"
                                     Opacity="0.8">
                    <GradientStop Color="#FF1B2838"
                                  Offset="0" />
                    <GradientStop Color="#FF2A475E"
                                  Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Steam Icon in Border-->
    <Style x:Key="Rift_SteamIcon_border"
           TargetType="materialIcons:MaterialIcon">

        <Setter Property="Kind"
                Value="Steam" />
        <Setter Property="Width"
                Value="41" />
        <Setter Property="Height"
                Value="41" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Foreground"
                Value="White" />
    </Style>
    
    <!-- Ellipses fro loading -->
    <Style x:Key="Rift_Ellipse_Loading"
           TargetType="Ellipse">

        <Setter Property="Width"
                Value="12" />
        <Setter Property="Height"
                Value="8" />
        <Setter Property="Margin"
                Value="2" />
        <Setter Property="Opacity"
                Value="0.8" />
        <Setter Property="Fill">
            <Setter.Value>
                <SolidColorBrush Color="Transparent" />
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FF007EFF"
                                  BlurRadius="100"
                                  ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Border for RIFT logo -->
    <Style x:Key="Rift_Border_Logo"
           TargetType="Border">

        <Setter Property="Width"
                Value="95" />
        <Setter Property="Height"
                Value="95" />
        <Setter Property="CornerRadius"
                Value="20" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#83289C"
                                  BlurRadius="80"
                                  ShadowDepth="1" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Rift logo in Border -->

    <Style x:Key="Rift_Logo"
           TargetType="Image">

        <Setter Property="Source"
                Value="/Icons/Rift_logo.png" />
        <Setter Property="Width"
                Value="95" />
        <Setter Property="Height"
                Value="95" />
        <Setter Property="Margin"
                Value="0,-10,0,-10" />
        <Setter Property="Stretch"
                Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode"
                Value="HighQuality" />
        <Setter Property="materialDesign:ElevationAssist.Elevation"
                Value="Dp4" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry Center="47.5,47.5"
                                 RadiusX="47.5"
                                 RadiusY="47.5" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>