<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">
    
    
    <!-- Stackpanel Logo/Title -->
    <Style x:Key="Rift_LoginTitle_stackpanel"
           TargetType="StackPanel">

        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="57" />
        <Setter Property="Orientation"
                Value="Horizontal" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="50,36,0,0" />
    </Style>

    <!-- Logo -->
    <Style x:Key="Rift_Logo_login"
           TargetType="Image">

        <Setter Property="Source"
                Value="/Icons/Rift_logo.png" />
        <Setter Property="Width"
                Value="55" />
        <Setter Property="Height"
                Value="55" />
        <Setter Property="Margin"
                Value="0,-10,0,-10" />
        <Setter Property="Stretch"
                Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode"
                Value="HighQuality" />
        <Setter Property="materialDesign:ElevationAssist.Elevation"
                Value="Dp4" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry Center="27.5,27.5"
                                 RadiusX="27.5"
                                 RadiusY="27.5" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Title -->
    <Style x:Key="Rift_Title_login"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">
     
        <Setter Property="Text"
                Value="RIFT" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Margin"
                Value="10,0.5,0,0" />
        <Setter Property="Foreground"
                Value="#F0F1F2" />
        <Setter Property="FontSize"
                Value="30" />
        <Setter Property="FontFamily"
                Value="Arial" />
    </Style>

   <!-- Stackpanel Login_layout -->
    <Style x:Key="Rift_Layout_Stackpanel"
           TargetType="StackPanel">
        
        <Setter Property="Orientation"
                Value="Vertical" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Margin"
                Value="55,40,0,0" />
    </Style>

    <!-- Textblock for Title_sign in -->
    <Style x:Key="Rift_SignIn_Title"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">

        <Setter Property="Text"
                Value="SIGN IN WITH ACCOUNT NAME" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Foreground"
                Value="#1999FF" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontFamily"
                Value="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
    </Style>

    <!-- TextBox for sign in Account name -->
    <Style x:Key="Rift_SignIn_AccountName"
           TargetType="TextBox">
        
        <Setter Property="Width"
                Value="296" />
        <Setter Property="Height"
                Value="38" />
        <Setter Property="Padding"
                Value="5,0,0,0" />
        <Setter Property="Margin"
                Value="0,5,0,0" />
        <Setter Property="Background"
                Value="#32353C" />
        <Setter Property="BorderBrush"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />
        <Setter Property="OverridesDefaultStyle"
                Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="10,0,0,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="#393C44" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Textblock for Title_password -->
    <Style x:Key="Rift_Password_Title"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">

       
        <Setter Property="Text"
                Value="PASSWORD" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="0,15,0,0" />
        <Setter Property="Foreground"
                Value="#AAAAAA" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontFamily"
                Value="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
    </Style>

    <!-- Passwordbox for sign -->
    <Style x:Key="Rift_SignIn_PasswordBox"
           TargetType="PasswordBox">
             
        <Setter Property="Width"
                Value="296" />
        <Setter Property="Height"
                Value="38" />
        <Setter Property="Padding"
                Value="5,0,0,0" />
        <Setter Property="Margin"
                Value="0,5,0,0" />
        <Setter Property="Background"
                Value="#32353C" />
        <Setter Property="BorderBrush"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="PasswordChar"
                Value="●" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />
        <Setter Property="OverridesDefaultStyle"
                Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="10,0,0,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="#393C44" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Button for Sign in -->
    <Style x:Key="Rift_SignIn_Button"
           TargetType="Button">
        
        <Setter Property="Content"
                Value="Sign in" />
        <Setter Property="Width"
                Value="230" />
        <Setter Property="Height"
                Value="50" />
        <Setter Property="Margin"
                Value="05,25,0,0" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="16" />
        <Setter Property="HorizontalContentAlignment"
                Value="Center" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="OverridesDefaultStyle"
                Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            BorderThickness="0">
                        <Border.Background>
                            <LinearGradientBrush>
                                <GradientStop Color="#FF40AEFF"
                                              Offset="0.138" />
                                <GradientStop Color="#FF2C76FF"
                                              Offset="0.736" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush>
                                        <GradientStop Color="#FF58B7FD"
                                                      Offset="0.138" />
                                        <GradientStop Color="#FF2974FD"
                                                      Offset="0.736" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Stackpanel for Create new account -->
    <Style x:Key="Rift_CreateAccount_Stackpanel"
           TargetType="StackPanel">

        <Setter Property="Orientation"
                Value="Horizontal" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="Auto" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="50,0,0,0" />
    </Style>

<!-- TextBlock for Don't have RIFT account -->
    <Style x:Key="Rift_CreateAccount_TextBlock"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignBody1TextBlock}">
              
        <Setter Property="Text"
                Value="Don't have a RIFT account?" />
        <Setter Property="Margin"
                Value="0,0,10,0" />
        <Setter Property="Foreground"
                Value="#B0B0B0" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontWeight"
                Value="Medium" />
        <Setter Property="FontStretch"
                Value="Medium" />
    </Style>

    <!-- Button for Create new RIFT account -->
    <Style x:Key="Rift_CreateAccount_Button"
           TargetType="Button">
              
        <Setter Property="Content"
                Value="Create a Free Account" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="23" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="Foreground"
                Value="#B0B0B0" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontWeight"
                Value="Medium" />
        <Setter Property="FontStretch"
                Value="Medium" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="OverridesDefaultStyle"
                Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <TextBlock x:Name="text"
                               Text="{TemplateBinding Content}"
                               FontSize="{TemplateBinding FontSize}"
                               FontWeight="{TemplateBinding FontWeight}"
                               FontStretch="{TemplateBinding FontStretch}"
                               Foreground="{TemplateBinding Foreground}"
                               TextDecorations="Underline"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="text"
                                    Property="Foreground"
                                    Value="#C9C9C9" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Elipses -->
    <Style x:Key="Rift_Stars"
           TargetType="Ellipse">

        <Setter Property="Width"
                Value="1.5" />
        <Setter Property="Height"
                Value="1.5" />
        <Setter Property="Fill"
                Value="#53AFFC" />
    </Style>
</ResourceDictionary>