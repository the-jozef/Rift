<UserControl x:Class="Rift_App.Login_Register.Login_loading"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.Resources>

        <Storyboard x:Key="SpinAnim"
                    RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinnerEllipse"
                             Storyboard.TargetProperty="StrokeDashOffset"
                             From="0"
                             To="-99"
                             Duration="0:0:2.5" />
        </Storyboard>

        <Storyboard x:Key="GrowAnim"
                    RepeatBehavior="Forever">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SpinnerEllipse"
                                           Storyboard.TargetProperty="StrokeDashArray"
                                           Duration="0:0:5.0">

                <DiscreteObjectKeyFrame KeyTime="0:0:0.0">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>2 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:0.3">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>15 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:0.6">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>30 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:0.9">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>42 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:1.2">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>50 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:1.6">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>48 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:2.1">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>44 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:2.6">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>38 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:3.1">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>30 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:3.6">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>20 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:4.1">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>12 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:4.5">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>6 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:4.8">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>3 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

                <DiscreteObjectKeyFrame KeyTime="0:0:5.0">
                    <DiscreteObjectKeyFrame.Value>
                        <DoubleCollection>2 1000</DoubleCollection>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>

            </ObjectAnimationUsingKeyFrames>
        </Storyboard>

    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinAnim}" />
            <BeginStoryboard Storyboard="{StaticResource GrowAnim}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Border x:Name="VideoBorder"
                CornerRadius="7.5,7.5,0,0">
            <Border.Background>
                <VisualBrush Stretch="UniformToFill">
                    <VisualBrush.Visual>
                        <MediaElement x:Name="BgVideo"
                                      Source="Videos/Background_animation.mp4"
                                      LoadedBehavior="Manual"
                                      UnloadedBehavior="Stop"
                                      IsMuted="True"
                                      Stretch="UniformToFill"
                                      IsHitTestVisible="False" />
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.Background>
        </Border>

        <Border CornerRadius="7.5,7.5,0,0"
                Background="Gray"
                Opacity="0.15" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="280" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                
                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Width="130"
                            Height="160">

                    <Grid Width="130"
                          Height="130">

                        <Ellipse Width="130"
                                 Height="130"
                                 StrokeThickness="1.5">
                            <Ellipse.Stroke>
                                <SolidColorBrush Color="#199FFF"
                                                 Opacity="0.12" />
                            </Ellipse.Stroke>
                        </Ellipse>

                        <Ellipse x:Name="SpinnerEllipse"
                                 Width="130"
                                 Height="130"
                                 StrokeThickness="4"
                                 StrokeDashArray="2 1000"
                                 StrokeDashOffset="0"
                                 StrokeStartLineCap="Round"
                                 StrokeEndLineCap="Round">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#66CCFF"
                                                  Offset="0.0" />
                                    <GradientStop Color="#199FFF"
                                                  Offset="0.5" />
                                    <GradientStop Color="#0A4FA8"
                                                  Offset="1.0" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                        </Ellipse>

                        <Ellipse Width="105"
                                 Height="105"
                                 StrokeThickness="1.5">
                            <Ellipse.Stroke>
                                <SolidColorBrush Color="#83289C"
                                                 Opacity="0.35" />
                            </Ellipse.Stroke>
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="/Image/Rift_logo.png" />
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>