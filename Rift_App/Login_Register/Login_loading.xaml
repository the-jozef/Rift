<UserControl x:Class="Rift_App.Login_Register.Login_loading"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Border Grid.Row="0"
                CornerRadius="7.5,7.5,0,0"
                Background="#1C1E22">
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />

                </Grid.RowDefinitions>

                <TextBlock Grid.Row="2"
                           Width="Auto"
                           HorizontalAlignment="Center"
                           Height="Auto"
                           VerticalAlignment="Center"
                           Text="Loading..."
                           Foreground="White"
                           FontSize="20">

                </TextBlock>

                <StackPanel HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Grid.Row="3"
                            VerticalAlignment="Top"
                            Width="Auto"
                            Height="Auto">

                    <Image Source="/Icons/Red.png"
                           Width="20"
                           Height="20"
                           Margin="0,0,10,0"/>

                    <TextBlock Width="Auto"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Text="Guest_user"
                               Foreground="Gray"
                               FontSize="18" />


                </StackPanel>






                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="Auto"
                            Height="Auto">

                    <!-- Kontajner pre kruh a obrázok -->
                    <Grid Width="140"
                          Height="140">

                        <!-- Rotujúci kruh -->
                        <Ellipse Width="140"
                                 Height="140"
                                 StrokeThickness="4"
                                 Opacity="0.8">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0.5,0"
                                                     EndPoint="0.5,1">
                                    <GradientStop Color="Transparent"
                                                  Offset="0.526" />
                                    <GradientStop Color="#199FFF"
                                                  Offset="0.559" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="RingRotate"
                                                 CenterX="70"
                                                 CenterY="70" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <!-- Statický obrázok vo vnútri kruhu -->
                        <Image Source="/Icons/Rift_logo.png"
                               Width="80"
                               Height="80"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Grid>

                </StackPanel>

                <!-- Animácie -->
                <Grid.Triggers>
                    <!-- Rotácia kruhu -->
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="RingRotate"
                                                 Storyboard.TargetProperty="Angle"
                                                 From="0"
                                                 To="360"
                                                 Duration="0:0:2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
                
                
                
                

            </Grid>
        </Border>
    </Grid>
</UserControl>
