<UserControl x:Class="Rift_App.Login_Register.SteamConnection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Login_Register"
             xmlns:converters="clr-namespace:Rift_App.Converters"
             xmlns:vm="clr-namespace:Rift_App.ViewModels"
             mc:Ignorable="d"
             Height="438"
             Width="705">

    <UserControl.Resources>
        <Storyboard x:Key="LoadingAnimation"
                    RepeatBehavior="Forever"
                    Duration="0:0:3.8">

            <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse1"
                                          Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                          Duration="0:0:6"
                                          BeginTime="0:0:0">
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:0" />
                <LinearColorKeyFrame Value="#40AEF1"
                                     KeyTime="0:0:0.8" />
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:1.6" />
            </ColorAnimationUsingKeyFrames>

            <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse2"
                                          Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                          Duration="0:0:6"
                                          BeginTime="0:0:0.6">
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:0" />
                <LinearColorKeyFrame Value="#40AEF1"
                                     KeyTime="0:0:0.8" />
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:1.6" />
            </ColorAnimationUsingKeyFrames>

            <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse3"
                                          Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                          Duration="0:0:6"
                                          BeginTime="0:0:1.2">
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:0" />
                <LinearColorKeyFrame Value="#40AEF1"
                                     KeyTime="0:0:0.8" />
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:1.6" />
            </ColorAnimationUsingKeyFrames>

            <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse4"
                                          Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                          Duration="0:0:6"
                                          BeginTime="0:0:1.8">
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:0" />
                <LinearColorKeyFrame Value="#40AEF1"
                                     KeyTime="0:0:0.8" />
                <LinearColorKeyFrame Value="#FF1F1F1F"
                                     KeyTime="0:0:1.6" />
            </ColorAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource LoadingAnimation}" />
        </EventTrigger>
    </UserControl.Triggers>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Style="{StaticResource Rift_Title_stackpanel}">

                <Image Style="{StaticResource Rift_Logo_register}" />

                <StackPanel Orientation="Vertical">

                    <TextBlock Style="{StaticResource Rift_Title_login}"
                               Margin="10,-1,0,0"
                               FontSize="30" />

                    <TextBlock Style="{StaticResource Rift_TextBlock_NewAccount}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Style="{StaticResource Rift_Stackpanel_Information}">

                <TextBlock Style="{StaticResource Rift_Textblock_Connection}" />

                <TextBlock Style="{StaticResource Rift_Textblock_AccountLink}" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Style="{StaticResource Rift_Stackpanel_Button Layout}">

                <Button Style="{StaticResource Rift_Steam_button}"
                        Width="220"
                        Height="43"
                        Command="{Binding SteamLoginCommand}">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <materialIcons:MaterialIcon Style="{StaticResource Rift_Steam_Icon}"
                                                    Width="25"
                                                    Height="25" />
                        <TextBlock Style="{StaticResource Rift_Steam_Textblock_register}" />
                    </StackPanel>
                </Button>

                <Grid Margin="0,28,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="133.5" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,12,0"
                            Style="{StaticResource Rift_Border_lines}">
                        <Border.Background>
                            <LinearGradientBrush EndPoint="0.0,0"
                                                 StartPoint="1.0,0">
                                <GradientStop Offset="1" />
                                <GradientStop Color="#969696"
                                              Offset="0.294" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock Grid.Column="1"
                               Style="{StaticResource Rift_TextBlock_or}"
                               FontSize="13"
                               Margin="12,-4,12,0" />

                    <Border Grid.Column="2"
                            Margin="12,0,0,0"
                            Style="{StaticResource Rift_Border_lines}">

                        <Border.Background>
                            <LinearGradientBrush EndPoint="0.0,0"
                                                 StartPoint="1.0,0">
                                <GradientStop Offset="0" />
                                <GradientStop Color="#969696"
                                              Offset="0.294" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <Button Style="{StaticResource Rift_Return_Button}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="120" />
                <RowDefinition Height="*" />
                <RowDefinition Height="120" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Width="33"
                        HorizontalAlignment="Right">

                <Button Style="{StaticResource Rift_CLoseButton}"
                        Height="30"
                        Margin="0,0,0,0"
                        Width="33"
                        materialDesign:ButtonAssist.CornerRadius="0,7.5,0,0">

                    <materialIcons:MaterialIcon Style="{StaticResource Rift_WindowState_Icons}"
                                                Kind="Close"
                                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Style="{StaticResource Rift_Stackpanel_Logo}">

                <StackPanel>
                    <Border Style="{StaticResource Rift_Border_Steam}">

                        <materialIcons:MaterialIcon Style="{StaticResource Rift_SteamIcon_border}" />
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Margin="10,0,10,0">

                    <Ellipse Style="{StaticResource Rift_Ellipse_Loading}"
                             x:Name="Ellipse1" />

                    <Ellipse Style="{StaticResource Rift_Ellipse_Loading}"
                             x:Name="Ellipse2" />

                    <Ellipse Style="{StaticResource Rift_Ellipse_Loading}"
                             x:Name="Ellipse3" />

                    <Ellipse Style="{StaticResource Rift_Ellipse_Loading}"
                             x:Name="Ellipse4" />
                </StackPanel>

                <StackPanel>

                    <Border Style="{StaticResource Rift_Border_Logo}">

                        <Image Style="{StaticResource Rift_Logo}" />

                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
