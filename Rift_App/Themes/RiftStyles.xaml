    </Style>

    <Style x:Key="Rift_Button2"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Height"
                Value="Auto" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="Margin"
                Value="5,0,0,0" />

    </Style>

    <Style x:Key="Rift_Button3"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Height"
                Value="25" />
        <Setter Property="Width"
                Value="25" />
        <Setter Property="Background"
                Value="#FF31353A" />
        <Setter Property="Margin"
                Value="5,0,0,0" />

    </Style>

    <!-- Steam-like Search Bar -->
    <Style x:Key="RiftSearchBar"
           TargetType="TextBox"
           BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">

        <Setter Property="Height"
                Value="22" />
        <Setter Property="Width"
                Value="165" /> 
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="Margin"
                Value="6,0,0,0" />
        <Setter Property="Padding"
                Value="5,0,50,0" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="Background"
                Value="#415261" />
        <Setter Property="BorderBrush"
                Value="#343F4E" />
        <Setter Property="BorderThickness"
                Value="0.5" />
        <!-- Hint -->
        <Setter Property="materialDesign:HintAssist.Hint"
                Value="Search the Store" />
        <Setter Property="materialDesign:HintAssist.IsFloating"
                Value="False" />

        <!-- Focus efekt -->
        <Style.Triggers>

            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="BorderBrush"
                        Value="#2B6694" />
                <Setter Property="materialDesign:TextFieldAssist.OutlinedBorderActiveThickness"
                        Value="1" />
            </Trigger>

            <!-- Focused alone -->
            <Trigger Property="IsFocused"
                     Value="True">
                <Setter Property="BorderBrush"
                        Value="#1A9FFF" />
                <Setter Property="FontSize"
                        Value="14" />
                <Setter Property="materialDesign:TextFieldAssist.OutlinedBorderActiveThickness"
                        Value="0.8" />
                <Setter Property="Background"
                        Value="#21272E" />
            </Trigger>


            <!-- Focused AND mouse over — focused wins -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsFocused"
                               Value="True" />
                    <Condition Property="IsMouseOver"
                               Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="BorderBrush"
                        Value="#1A9FFF" />
                <Setter Property="materialDesign:TextFieldAssist.OutlinedBorderActiveThickness"
                        Value="0.8" />
                <Setter Property="Background"
                        Value="#21272E" />
                <Setter Property="FontSize"
                        Value="14" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="Rift_CLear_Button"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignIconButton}">
        <Setter Property="Width"
                Value="20" />
        <Setter Property="Height"
                Value="20" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <materialDesign:PackIcon x:Name="Icon"
                                             Kind="Close"
                                             Width="15"
                                             Height="15"
                                             Foreground="#4B4F55"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="Icon"
                                    Property="Width"
                                    Value="20" />
                            <Setter TargetName="Icon"
                                    Property="Height"
                                    Value="20" />
                            <Setter TargetName="Icon"
                                    Property="Foreground"
                                    Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



 
    
    
    
    
    
    
    
    
    
    
    
    


