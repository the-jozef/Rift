<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">
    <!-- TitleBar -->
    
    <!-- Stackpanel TitleBar -->
    <Style x:Key="Rift_TitleBar"
           TargetType="StackPanel">
        
        <Setter Property="Orientation"
                Value="Horizontal" /> 
    </Style>

    <!-- Logo -->
    <Style x:Key="Rift_Logo"
           TargetType="Image">

        <Setter Property="Source"
                Value="/Icons/Rift_logo.png" />
        <Setter Property="Width"
                Value="20" />
        <Setter Property="Height"
                Value="20" />
        <Setter Property="Margin"
                Value="0,-10,0,-10" />
        <Setter Property="Stretch"
                Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode"
                Value="HighQuality" />
        <Setter Property="materialDesign:ElevationAssist.Elevation"
                Value="Dp4" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry Center="10,10"
                                 RadiusX="10"
                                 RadiusY="10" />
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Title -->
    <Style x:Key="Rift_Title"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline6TextBlock }">
        
        <Setter Property="Text"
                Value="RIFT" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="6,0.5,0,0" />
        <Setter Property="Foreground"
                Value="{StaticResource RiftForeground}" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontFamily"
                Value="Arial" />
    </Style>

    <!-- StackPanel logo/name        To popupbox next time-->
    <Style x:Key="Rift_LogoHeader"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignFlatButton}">

        <Setter Property="Height"
                Value="20" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Margin"
                Value="11,0,0,0" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="Padding"
                Value="0" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <StackPanel Orientation="Horizontal"
                                Background="Transparent">
                        <Image x:Name="Logo"
                               Style="{StaticResource Rift_Logo}"
                               Opacity="1" />
                        <TextBlock x:Name="Title"
                                   Style="{StaticResource Rift_Title}" />
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="Logo"
                                    Property="Opacity"
                                    Value="0.8"/>
                            <Setter TargetName="Title"
                                    Property="Foreground"
                                    Value="White" />
                            
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Popupbox View/Games/Help -->
    <Style x:Key="Rift_PopupBox"
           TargetType="materialDesign:PopupBox"
           BasedOn="{StaticResource {x:Type materialDesign:PopupBox}}">

        <Setter Property="Padding"
                Value="0" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="Foreground"
                Value="Transparent" />
        <Setter Property="materialDesign:RippleAssist.IsDisabled"
                Value="True" />
        <Setter Property="PopupVerticalOffset"
                Value="-9" />
        <Setter Property="PopupHorizontalOffset"
                Value="2" />

        <Style.Resources>
            <Style TargetType="ToggleButton">
                <Setter Property="Background"
                        Value="Transparent" />
                <Setter Property="BorderBrush"
                        Value="Transparent" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter Property="Background"
                                Value="Transparent" />
                    </Trigger>
                    <Trigger Property="IsChecked"
                             Value="True">
                        <Setter Property="Background"
                                Value="Transparent" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Style.Resources>
    </Style>

    <!-- TextBlock in PopupBox -->
    <Style x:Key="Rift_PopupTextblock"
           TargetType="TextBlock">
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontFamily"
                Value="Arial" />
    </Style>
    
    <!-- ScrollViewer for PopupBox -->
    <Style x:Key="Rift_ScrollViewer"
           TargetType="ScrollViewer">
        
        <Setter Property="VerticalScrollBarVisibility"
                Value="Disabled" />
        <Setter Property="Background"
                Value="#3D4450" />
    </Style>
    
    <!-- StackPanel for PopupBox -->
    <Style x:Key="Rift_PopupStackPanel"
           TargetType="StackPanel">
        
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="Auto" />
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
    </Style>
    
    <!-- Popupbox items -->
    <Style x:Key="Rift_PopupItems"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignFlatButton}">
        
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="11" />
        <Setter Property="FontFamily"
                Value="Arial" />
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Foreground"
                        Value="#2E2E2E" />
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="White"
                                         Opacity="0.7" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- PopupBox Store/Library/Nickname  flashes-->
    <Style x:Key="Rift_PopupBox_options"
           TargetType="materialDesign:PopupBox"
           BasedOn="{StaticResource {x:Type materialDesign:PopupBox}}">
        
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="Foreground"
                Value="Transparent" />
        <Setter Property="materialDesign:RippleAssist.IsDisabled"
                Value="True" />
        <Setter Property="PopupMode"
                Value="MouseOverEager" />
        <Setter Property="StaysOpen"
                Value="True" />
        <Setter Property="PopupAnimation"
                Value="None" />
        <Setter Property="PopupVerticalOffset"
                Value="-5" />
        <Setter Property="PopupHorizontalOffset"
                Value="4" />
        <Style.Resources>
            <Style TargetType="ToggleButton">
                <Setter Property="Padding"
                        Value="0,0,30,8" />
                <Setter Property="Background"
                        Value="Transparent" />
                <Setter Property="BorderBrush"
                        Value="Transparent" />
                <Style.Triggers>
                    <Trigger Property="IsChecked"
                             Value="True">
                        <Setter Property="Background"
                                Value="Transparent" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Style.Resources>
    </Style>

    <!-- Textblock for options -->
    <Style x:Key="Rift_PopupTextblock_options"
           TargetType="TextBlock">
        <Setter Property="Margin"
                Value="0,0,0,2" />
        <Setter Property="VerticalAlignment"
                    Value="Center" />
        <Setter Property="HorizontalAlignment"
                    Value="Left" />
        <Setter Property="FontSize"
                    Value="18" />
        <Setter Property="FontFamily"
                    Value="Arial" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
    </Style>

    <!-- StackPanel for Account/Notifications -->
    <Style x:Key="Rift_StackPanel_Action"
           TargetType="StackPanel">
        <Setter Property="Margin"
                Value="0,6,0,7" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Orientation"
                Value="Horizontal" />
        <Setter Property="HorizontalAlignment"
                Value="Right" />
    </Style>
    
    <!-- Popup for Notifications -->
    <Style x:Key="Rift_Notifications_PopupBox"
           TargetType="materialDesign:PopupBox"
           BasedOn="{StaticResource {x:Type materialDesign:PopupBox}}">
        <Setter Property="Margin"
                Value="20,0,12,0" />
        <Setter Property="Width"
                Value="47" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="Background"
                Value="#23262E" />
        <Setter Property="materialDesign:RippleAssist.IsDisabled"
                Value="True" />
        <Setter Property="PopupAnimation"
                Value="None" />
        <Setter Property="StaysOpen"
                Value="False" />
        <Setter Property="PopupMode"
                Value="MouseOverEager" />
        <Setter Property="PopupVerticalOffset"
                Value="7" />
        <Setter Property="PopupHorizontalOffset"
                Value="-35" />
        <Style.Resources>
            <Style TargetType="ToggleButton">
                <Setter Property="Background"
                        Value="Transparent" />
                <Setter Property="BorderBrush"
                        Value="Transparent" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter Property="Background"
                                Value="#2A2F38" />
                        
                    </Trigger>
                    <Trigger Property="IsChecked"
                             Value="True">
                        <Setter Property="Background"
                                Value="#2A2F38" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Style.Resources>
    </Style>
    
    <!-- Popupbox items for Notifications -->
    <Style x:Key="Rift_Notification_Item"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignFlatButton}">

        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="25" />
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
        <Setter Property="Foreground"
                Value="#2E2E2E" />
        <Setter Property="FontSize"
                Value="12.5" />
        <Setter Property="FontFamily"
                Value="Arial" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="White"
                                 Opacity="0.7" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Popup for Account PopupBox_Account-->
    <Style x:Key="Rift_PopupBox_Account"
           TargetType="materialDesign:PopupBox"
           BasedOn="{StaticResource {x:Type materialDesign:PopupBox}}">

        <Setter Property="Margin"
                Value="0,0,45,0" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="materialDesign:RippleAssist.IsDisabled"
                Value="True" />
        <Setter Property="PlacementMode"
                Value="BottomAndAlignLeftEdges" />
        <Setter Property="StaysOpen"
                Value="False" />
        <Setter Property="PopupAnimation"
                Value="Slide" />
        <Setter Property="PopupVerticalOffset"
                Value="3" />
        <Setter Property="PopupHorizontalOffset"
                Value="1" />
    </Style>

    <!-- Border for Account_PopupBox-->
    <Style x:Key="Rift_Border_Account"
           TargetType="Border">
        <Setter Property="Padding"
                Value="12,6" />
        <Setter Property="MinWidth"
                Value="80" />
        <Setter Property="Background"
                Value="#23262E" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush  Color="#2A4A5D"
                                          Opacity="0.6" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Textblock for Account -->
    <Style x:Key="Rift_PopupTextblock_Account"
           TargetType="TextBlock">

        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="TextAlignment"
                Value="Center" />
        <Setter Property="Foreground"
                Value="#46B0FF" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontFamily"
                Value="Segoe UI" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
    </Style>
    
    <!-- Icon for ChevronDown after Account-->
    <Style x:Key="Rift_ChevronDown_Icon"
           TargetType="materialIcons:MaterialIcon">
        <Setter Property="Kind"
                Value="ChevronDown" />
        <Setter Property="Width"
                Value="7" />
        <Setter Property="Height"
                Value="7" />
        <Setter Property="Margin"
                Value="5,5,0,0" />
        <Setter Property="Foreground"
                Value="#46B0FF" />
    </Style>

    <!-- StackPanel for Minimalize/Maximalize $ close  -->
    <Style x:Key="Rift_StackPanel_WindowButtons"
           TargetType="StackPanel">
        
        <Setter Property="Margin"
                Value="0,0,0,5" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="HorizontalAlignment"
                Value="Right" />
        <Setter Property="Orientation"
                Value="Horizontal" />
    </Style>

    <!-- Button for Minimalize/Maximalize Window State -->
    <Style x:Key="Rift_StateWindow_Button"
           TargetType="Button">

        <Setter Property="Margin"
                Value="0,-5,0,0" />
        <Setter Property="Width"
                Value="32" />
        <Setter Property="Height"
                Value="30" />
        <Setter Property="Foreground"
                Value="#FF818181" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="border"
                                Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="White"
                                                     Opacity="0.2" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground"
                                    Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed"
                                 Value="True">
                            <Setter TargetName="border"
                                Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="White"
                                                     Opacity="0.2" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground"
                                    Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Close button -->
    <Style x:Key="Rift_CLoseButton"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignFlatButton}">

        <Setter Property="Margin"
                Value="5,0,0,0" />
        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="Auto" />
        <Setter Property="Foreground"
                Value="#FF818181" />
        <Setter Property="Background"
                Value="Transparent" />  
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding Path=(materialDesign:ButtonAssist.CornerRadius), 
                            RelativeSource={RelativeSource TemplatedParent}}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter 
                                    Property="Background"
                                    Value="#E22A27" />
                            <Setter Property="Foreground"
                                    Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="DarkRed" />
                            <Setter Property="Foreground"
                                    Value="White" />
                        </Trigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window State Icons -->
    <Style x:Key="Rift_WindowState_Icons"
           TargetType="materialIcons:MaterialIcon">

        <Setter Property="Width"
                Value="13" />
        <Setter Property="Height"
                Value="13" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Foreground"
                Value="#FF818181" />
    </Style>





    
    
    
    
    
    
    
<!-- Fix from here-->
    <Style x:Key="Rift_Button3"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Height"
                Value="25" />
        <Setter Property="Width"
                Value="25" />
        <Setter Property="Background"
                Value="#262C36" />
        <Setter Property="Margin"
                Value="5,0,0,0" />

    </Style>

    <!-- Steam-like Search Bar --> 
    <Style x:Key="RiftSearchBar"
           TargetType="TextBox"
           BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">

        <Setter Property="Height"
                Value="22" />
        <Setter Property="Width"
                Value="165" /> 
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="Margin"
                Value="6,0,0,0" />
        <Setter Property="Padding"
                Value="5,0,50,0" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="Background"
                Value="#415261" />
        <Setter Property="BorderBrush"
                Value="#343F4E" />
        <Setter Property="BorderThickness"
                Value="0.5" />
        <!-- Hint -->
        <Setter Property="materialDesign:HintAssist.Hint"
                Value="Search the Store" />
        <Setter Property="materialDesign:HintAssist.IsFloating"
                Value="False" />

        <!-- Focus efekt -->
        <Style.Triggers>

            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="BorderBrush"
                        Value="#2B6694" />
                <Setter Property="materialDesign:TextFieldAssist.OutlinedBorderActiveThickness"
                        Value="1" />
            </Trigger>

            <!-- Focused alone -->
            <Trigger Property="IsFocused"
                     Value="True">
                <Setter Property="BorderBrush"
                        Value="#1A9FFF" />
                <Setter Property="FontSize"
                        Value="14" />
                <Setter Property="materialDesign:TextFieldAssist.OutlinedBorderActiveThickness"
                        Value="0.8" />
                <Setter Property="Background"
                        Value="#21272E" />
            </Trigger>


            <!-- Focused AND mouse over — focused wins -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsFocused"
                               Value="True" />
                    <Condition Property="IsMouseOver"
                               Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="BorderBrush"
                        Value="#1A9FFF" />
                <Setter Property="materialDesign:TextFieldAssist.OutlinedBorderActiveThickness"
                        Value="0.8" />
                <Setter Property="Background"
                        Value="#21272E" />
                <Setter Property="FontSize"
                        Value="14" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>
    
    
    <Style x:Key="Rift_CLear_Button"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignIconButton}">
        <Setter Property="Width"
                Value="20" />
        <Setter Property="Height"
                Value="20" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <materialDesign:PackIcon x:Name="Icon"
                                             Kind="Close"
                                             Width="15"
                                             Height="15"
                                             Foreground="#4B4F55"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="Icon"
                                    Property="Width"
                                    Value="20" />
                            <Setter TargetName="Icon"
                                    Property="Height"
                                    Value="20" />
                            <Setter TargetName="Icon"
                                    Property="Foreground"
                                    Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>