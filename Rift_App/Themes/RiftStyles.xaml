<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <Style x:Key="Rift_Logo"
           TargetType="Image">
        
        <Setter Property="Width"
                Value="15" />
        <Setter Property="Height"
                Value="15" />
        <Setter Property="Source"
                Value="/Icons/Rift_logo.png" />
        <Setter Property="Margin"
                Value="5,-2,0,0" />
        <Setter Property="Stretch"
                Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode"
                Value="HighQuality" />
        <Setter Property="materialDesign:ElevationAssist.Elevation"
                Value="Dp4" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry Center="7.5,7.5"
                                 RadiusX="7.5"
                                 RadiusY="7.5" />
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="Rift_Title"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline6TextBlock }">
        <Setter Property="Text"
                Value="RIFT" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="5,0,0,0" />
        <Setter Property="FontSize"
                Value="10" />
        <Setter Property="Foreground"
                Value="{StaticResource RiftForeground}" />
        <Setter Property="FontFamily"
                Value="Regular" />
    </Style>
    <Style x:Key="Rift_PopupBox"
           TargetType="materialDesign:PopupBox">
        <Setter Property="PlacementMode"
                Value="BottomAndAlignLeftEdges" />
        <Setter Property="StaysOpen"
                Value="False" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="7,0,0,0" />
        <Setter Property="FontSize"
                Value="10" />
        <Setter Property="Foreground"
                Value="{StaticResource RiftForeground}" />
        <Setter Property="FontFamily"
                Value="Regular" />
    </Style>

    <Style x:Key="Rift_PopupStackPanel"
           TargetType="StackPanel">
        <Setter Property="Width"
                Value="100" />
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
    </Style>

    <Style x:Key="Rift_PopupItem"
           TargetType="Button"
           BasedOn="{StaticResource  MaterialDesignFlatButton}">
        <Setter Property="Padding"
                Value="8,4" />
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
        <Setter Property="FontSize"
                Value="11" />
        <Setter Property="Foreground"
                Value="{StaticResource RiftForeground}" />
        <Setter Property="FontFamily"
                Value="Regular" />
    </Style>
        <!-- tu od store -->
    <Style x:Key="Rift_PopupBox2"
           TargetType="materialDesign:PopupBox">
        <Setter Property="PlacementMode"
                Value="BottomAndAlignLeftEdges" />
        <Setter Property="StaysOpen"
                Value="False" />
        <Setter Property="VerticalAlignment"
                Value="Bottom" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="10,0,0,5" />
        <Setter Property="FontSize"
                Value="17" />
        <Setter Property="Foreground"
                Value="{StaticResource RiftAccent}" />
        <Setter Property="FontFamily"
                Value="Arial" />
    </Style>

    
    
    
    
    
    
    
    
    
    
    
    
    <Style x:Key="RiftTextBox"
           TargetType="TextBox"
           BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Width"
                Value="280" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="materialDesign:HintAssist.IsFloating"
                Value="True" />
        <Setter Property="Padding"
                Value="10,8" />
    </Style>

    <!-- 2. Rift PasswordBox -->
    <Style x:Key="RiftPasswordBox"
           TargetType="PasswordBox"
           BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
        <Setter Property="Width"
                Value="280" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="materialDesign:HintAssist.IsFloating"
                Value="True" />
        <Setter Property="Padding"
                Value="10,8" />
    </Style>

    <!-- 3. Rift Primary Button (hlavné modré tlačidlo) -->
    <Style x:Key="RiftPrimaryButton"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Height"
                Value="48" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="FontWeight"
                Value="Medium" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius"
                Value="6" />
    </Style>

    <!-- 4. Rift Secondary Button (outlined) -->
    <Style x:Key="RiftSecondaryButton"
           TargetType="Button"
           BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="Height"
                Value="48" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius"
                Value="6" />
    </Style>

    <!-- 5. Rift Card -->
    <Style x:Key="RiftCard"
           TargetType="materialDesign:Card">
        <Setter Property="UniformCornerRadius"
                Value="10" />
        <Setter Property="Padding"
                Value="24" />
        <Setter Property="materialDesign:ElevationAssist.Elevation"
                Value="Dp4" />
        <Setter Property="Background"
                Value="{StaticResource SteamCardBackground}" />
    </Style>

</ResourceDictionary>