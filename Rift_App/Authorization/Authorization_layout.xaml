<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">

    <!--    LOGIN   -->
    <!-- Stackpanel Logo/Title -->
    <Style x:Key="Rift_LoginTitle_stackpanel"
           TargetType="StackPanel">

        <Setter Property="Width"
                Value="Auto" />
        <Setter Property="Height"
                Value="57" />
        <Setter Property="Orientation"
                Value="Horizontal" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="50,36,0,0" />
    </Style>

    <!-- Logo -->
    <Style x:Key="Rift_Logo_login"
           TargetType="Image">

        <Setter Property="Source"
                Value="/Image/Rift_logo.png" />
        <Setter Property="Width"
                Value="55" />
        <Setter Property="Height"
                Value="55" />
        <Setter Property="Margin"
                Value="0,-10,0,-10" />
        <Setter Property="Stretch"
                Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode"
                Value="HighQuality" />
        <Setter Property="materialDesign:ElevationAssist.Elevation"
                Value="Dp4" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry Center="27.5,27.5"
                                 RadiusX="27.5"
                                 RadiusY="27.5" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Title -->
    <Style x:Key="Rift_Title_login"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">

        <Setter Property="Text"
                Value="RIFT" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Margin"
                Value="10,0.5,0,0" />
        <Setter Property="Foreground"
                Value="#F0F1F2" />
        <Setter Property="FontSize"
                Value="30" />
        <Setter Property="FontFamily"
                Value="Arial" />
    </Style>

    <!-- Stackpanel Login_layout -->
    <Style x:Key="Rift_Layout_Stackpanel"
           TargetType="StackPanel">

        <Setter Property="Orientation"
                Value="Vertical" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Margin"
                Value="55,35,0,0" />
    </Style>

    <!-- Textblock for Title_sign in -->
    <Style x:Key="Rift_SignIn_Title"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">

        <Setter Property="Text"
                Value="SIGN IN WITH ACCOUNT NAME" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Foreground"
                Value="#1999FF" />
        <Setter Property="FontSize"
                Value="13.5" />
        <Setter Property="FontFamily"
                Value="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
    </Style>

    <!-- TextBox for sign in Account name -->
    <Style x:Key="Rift_SignIn_AccountName"
           TargetType="TextBox">

        <Setter Property="Width"
                Value="296" />
        <Setter Property="Height"
                Value="38" />
        <Setter Property="Padding"
                Value="5,0,0,0" />
        <Setter Property="Margin"
                Value="0,5,0,0" />
        <Setter Property="Background"
                Value="#32353C" />
        <Setter Property="BorderBrush"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />
        <Setter Property="OverridesDefaultStyle"
                Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="10,0,0,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="#393C44" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Textblock for Title_password -->
    <Style x:Key="Rift_Password_Title"
           TargetType="TextBlock"
           BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">


        <Setter Property="Text"
                Value="PASSWORD" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="0,15,0,0" />
        <Setter Property="Foreground"
                Value="#AAAAAA" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="FontFamily"
                Value="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
    </Style>

    <!-- Passwordbox for sign -->
    <Style x:Key="Rift_SignIn_PasswordBox"
           TargetType="PasswordBox">

        <Setter Property="Width"
                Value="296" />
        <Setter Property="Height"
                Value="38" />
        <Setter Property="Padding"
                Value="5,0,0,0" />
        <Setter Property="Margin"
                Value="0,5,0,0" />
        <Setter Property="Background"
                Value="#32353C" />
        <Setter Property="BorderBrush"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="PasswordChar"
                Value="●" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />
        <Setter Property="OverridesDefaultStyle"
                Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="10,0,0,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="#393C44" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Button for Sign in -->
    <Style x:Key="Rift_SignIn_Button"
           TargetType="Button">

        <Setter Property="Content"
                Value="Sign in" />
        <Setter Property="Width"
                Value="200" />
        <Setter Property="Height"
                Value="35" />
        <Setter Property="Margin"
                Value="05,23,0,0" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="FontSize"
                Value="16" />
        <Setter Property="HorizontalContentAlignment"
                Value="Center" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="OverridesDefaultStyle"
                Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            BorderThickness="0">
                        <Border.Background>
                            <LinearGradientBrush>
                                <GradientStop Color="#FF40AEFF"
                                              Offset="0.138" />
                                <GradientStop Color="#FF2C76FF"
                                              Offset="0.736" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush>
                                        <GradientStop Color="#FF58B7FD"
                                                      Offset="0.138" />
                                        <GradientStop Color="#FF2974FD"
                                                      Offset="0.736" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Border for Lines between or -->
    <Style x:Key="Rift_Border_lines"
           TargetType="Border">

        <Setter Property="Height"
                Value="1" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
    </Style>

    <!-- Textblock for OR -->
    <Style x:Key="Rift_TextBlock_or"
           TargetType="TextBlock">

        <Setter Property="Text"
                Value="or" />
        <Setter Property="Height"
                Value="16" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Margin"
                Value="12,0,12,0" />
        <Setter Property="Foreground"
                Value="#A8A8A8" />
        <Setter Property="FontWeight"
                Value="Medium" />
    </Style>

    <!-- Button for steam sign in -->
    <Style x:Key="Rift_Steam_button"
           TargetType="Button">

        <Setter Property="Width"
                Value="200" />
        <Setter Property="Height"
                Value="40" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            BorderThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#FF1B2838"
                                              Offset="0" />
                                <GradientStop Color="#FF2A475E"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,0">
                                        <GradientStop Color="#FF192636"
                                                      Offset="0" />
                                        <GradientStop Color="#FF294258"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Steam Icon -->
    <Style x:Key="Rift_Steam_Icon"
           TargetType="materialIcons:MaterialIcon">

        <Setter Property="Kind"
