<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">

    <!--  Account Selection  -->

    <!--  Image in Background  -->
    <Style x:Key="Rift_AccountSelection_Image_Background" TargetType="Image">

        <Setter Property="Source" Value="/Image/Steam.jpg" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Panel.ZIndex" Value="0" />
    </Style>

    <!--  Video in Background  -->
    <Style x:Key="Rift_AccountSelection_Video_Background" TargetType="MediaElement">

        <Setter Property="LoadedBehavior" Value="Play" />
        <Setter Property="UnloadedBehavior" Value="Manual" />
        <Setter Property="Source" Value="Videos\Background_animation.mp4" />
        <Setter Property="IsMuted" Value="True" />
        <Setter Property="Stretch" Value="UniformToFill" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Panel.ZIndex" Value="1" />
    </Style>

    <!--  Border in Background  -->
    <Style x:Key="Rift_AccountSelection_Border_Background" TargetType="Border">

        <Setter Property="CornerRadius" Value="7.5,7.5,0,0" />
        <Setter Property="Background" Value="#505050" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Opacity" Value="0.13" />
        <Setter Property="Panel.ZIndex" Value="2" />
    </Style>

    <!--  StackPanel for Logo/Title  -->
    <Style x:Key="Rift_AccountSelection_StackPanel_Logo_Title" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="45,35,0,0" />
    </Style>

    <!--  Image in Logo/Title  -->
    <Style x:Key="Rift_AccountSelection_Image_Logo_Title" TargetType="Image">

        <Setter Property="Source" Value="/Image/Rift_logo.png" />
        <Setter Property="Width" Value="60" />
        <Setter Property="Height" Value="60" />
        <Setter Property="Stretch" Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry
                    Center="30,30"
                    RadiusX="30"
                    RadiusY="30" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--  TextBlock in Logo/Title  -->
    <Style x:Key="Rift_AccountSelection_Textblock_Logo_Title" TargetType="TextBlock">

        <Setter Property="Text" Value="RIFT" />
        <Setter Property="Foreground" Value="#E6E7E8" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="MotivaSans-Regular.ttf" />
        <Setter Property="Margin" Value="10,3,0,0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Window State Icons  -->
    <Style x:Key="Rift_AccountSelection_Icon_WindowState" TargetType="materialIcons:MaterialIcon">

        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="#FF818181" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Close button  -->
    <Style x:Key="Rift_AccountSelection_WindowState_Button_Close" TargetType="Button">

        <Setter Property="Foreground" Value="#FF818181" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Width" Value="33" />
        <Setter Property="Height" Value="30" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="0,7.5,0,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{Binding Path=(materialDesign:ButtonAssist.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E22A27" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="DarkRed" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  TextBlock for Title  -->
    <Style x:Key="Rift_AccountSelection_Textblock_Text" TargetType="TextBlock">

        <Setter Property="Text" Value="{DynamicResource account_selection_title}" />
        <Setter Property="FontSize" Value="27" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Stackpanel Content  -->
    <Style x:Key="Rift_AccountSelection_StackPanel_Content" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <!--  Button Account  -->
    <Style x:Key="Rift_AccountSelection_Button_Account" TargetType="Button">

        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="100" />
        <Setter Property="Height" Value="140" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Width="100" Height="140">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="100" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>

                        <Border
                            x:Name="AccountBorder"
                            Grid.Row="0"
                            Width="100"
                            Height="100"
                            VerticalAlignment="Center"
                            BorderThickness="0.5"
                            RenderTransformOrigin="0.5,0.5">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FF505050" />
                            </Border.BorderBrush>
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="AccountScale" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>

                            <Grid>
                                <Image
                                    Source="{Binding Tag.AvatarUrl, RelativeSource={RelativeSource TemplatedParent}}"
                                    Stretch="UniformToFill"
                                    WindowChrome.IsHitTestVisibleInChrome="True" />

                                <materialDesign:PopupBox
                                    x:Name="OptionsBox"
                                    Margin="0,0,5,5"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Opacity="0"
                                    PlacementMode="RightAndAlignTopEdges"
                                    Style="{StaticResource Rift_MenuBar_PopupBox_Options}"
                                    WindowChrome.IsHitTestVisibleInChrome="True">

                                    <materialDesign:PopupBox.ToggleContent>
                                        <Border
                                            Width="30"
                                            Height="20"
                                            Background="#CC000000"
                                            CornerRadius="4"
                                            Cursor="Hand">

                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                Foreground="White"
                                                Text="···"
                                                WindowChrome.IsHitTestVisibleInChrome="True" />
                                        </Border>
                                    </materialDesign:PopupBox.ToggleContent>

                                    <Button
                                        Margin="5,4,0,0"
                                        Command="{Binding DataContext.RemoveAccountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                        Content="{DynamicResource account_selection_remove}"
                                        Cursor="Hand"
                                        WindowChrome.IsHitTestVisibleInChrome="True">

                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#3D4450" />
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Padding" Value="4" />
                                                <Setter Property="FontSize" Value="11" />
                                                <Setter Property="FontFamily" Value="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
                                                <Setter Property="FontWeight" Value="Medium" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border
                                                                x:Name="Bg"
                                                                Padding="{TemplateBinding Padding}"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="4">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bg" Property="Background" Value="#26292E" />
                                                                    <Setter Property="Foreground" Value="Red" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </materialDesign:PopupBox>
                            </Grid>
                        </Border>

                        <TextBlock
                            x:Name="AccountNameLabel"
                            Grid.Row="1"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Opacity="0"
                            Text="{Binding Tag.Username, RelativeSource={RelativeSource TemplatedParent}}"
                            WindowChrome.IsHitTestVisibleInChrome="True" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="AccountScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.1"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="AccountScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.2"
                                            Duration="0:0:0.15" />

                                        <ThicknessAnimation
                                            Storyboard.TargetName="AccountNameLabel"
                                            Storyboard.TargetProperty="Margin"
                                            To="0,25,0,0"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="OptionsBox"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="AccountNameLabel"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="AccountScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="AccountScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.15" />
                                        <ColorAnimation
                                            Storyboard.TargetName="AccountBorder"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                            To="#FF505050"
                                            Duration="0:0:0.15" />

                                        <DoubleAnimation
                                            Storyboard.TargetName="OptionsBox"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="AccountNameLabel"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Button Add_Account  -->
    <Style x:Key="Rift_AccountSelection_Button_Add_Account" TargetType="Button">

        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="100" />
        <Setter Property="Height" Value="100" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="20,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">

                        <Border
                            x:Name="IconBorder"
                            Width="100"
                            Height="100"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="2">

                            <materialIcons:MaterialIcon
                                x:Name="PlusIcon"
                                Width="70"
                                Height="70"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Kind="Plus" />
                        </Border>

                        <TextBlock
                            x:Name="AddAccountLabel"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="12"
                            Foreground="White"
                            Opacity="0"
                            Text="{DynamicResource account_selection_add}" />
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="IconBorder"
                                            Storyboard.TargetProperty="Width"
                                            To="80"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="IconBorder"
                                            Storyboard.TargetProperty="Height"
                                            To="80"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="PlusIcon"
                                            Storyboard.TargetProperty="Width"
                                            To="55"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="PlusIcon"
                                            Storyboard.TargetProperty="Height"
                                            To="55"
                                            Duration="0:0:0.15" />
                                        <!--  Border to white  -->
                                        <ColorAnimation
                                            Storyboard.TargetName="IconBorder"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                            To="White"
                                            Duration="0:0:0.15" />
                                        <!--  Label fade in  -->
                                        <DoubleAnimation
                                            Storyboard.TargetName="AddAccountLabel"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--  Border back to original size  -->
                                        <DoubleAnimation
                                            Storyboard.TargetName="IconBorder"
                                            Storyboard.TargetProperty="Width"
                                            To="100"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="IconBorder"
                                            Storyboard.TargetProperty="Height"
                                            To="100"
                                            Duration="0:0:0.15" />
                                        <!--  Border back to transparent  -->
                                        <ColorAnimation
                                            Storyboard.TargetName="IconBorder"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                            To="Transparent"
                                            Duration="0:0:0.15" />
                                        <!--  Label fade out  -->
                                        <DoubleAnimation
                                            Storyboard.TargetName="AddAccountLabel"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Login  -->

    <!--  Ellipse animation  -->
    <Storyboard
        x:Key="PulseAnimation"
        AutoReverse="True"
        RepeatBehavior="Forever">
        <DoubleAnimation
            Storyboard.TargetName="Elipse1"
            Storyboard.TargetProperty="ScaleX"
            From="0.99"
            To="0.9"
            Duration="0:0:0:1" />
        <DoubleAnimation
            Storyboard.TargetName="Elipse1"
            Storyboard.TargetProperty="ScaleY"
            From="0.93"
            To="0.88"
            Duration="0:0:0:1" />
        <DoubleAnimation
            Storyboard.TargetName="Elipse2"
            Storyboard.TargetProperty="ScaleX"
            From="0.99"
            To="0.9"
            Duration="0:0:0:1" />
        <DoubleAnimation
            Storyboard.TargetName="Elipse2"
            Storyboard.TargetProperty="ScaleY"
            From="0.99"
            To="0.9"
            Duration="0:0:0:1" />
        <DoubleAnimation
            Storyboard.TargetName="Elipse3"
            Storyboard.TargetProperty="ScaleX"
            From="0.98"
            To="1.05"
            Duration="0:0:0:1" />
        <DoubleAnimation
            Storyboard.TargetName="Elipse3"
            Storyboard.TargetProperty="ScaleY"
            From="1"
            To="1.02"
            Duration="0:0:0:1" />
        <DoubleAnimation
            Storyboard.TargetName="Elipse4"
            Storyboard.TargetProperty="ScaleX"
            From="0.9"
            To="1"
            Duration="0:0:0:1" />
        <DoubleAnimation
            Storyboard.TargetName="Elipse4"
            Storyboard.TargetProperty="ScaleY"
            From="0.9"
            To="1.1"
            Duration="0:0:0:1" />
        <DoubleAnimation
            Storyboard.TargetName="Elipse5"
            Storyboard.TargetProperty="ScaleX"
            From="1"
            To="1.1"
            Duration="0:0:0:1" />
        <DoubleAnimation
            Storyboard.TargetName="Elipse5"
            Storyboard.TargetProperty="ScaleY"
            From="1"
            To="1.3"
            Duration="0:0:0:1" />
    </Storyboard>

    <!--  Main Border  -->
    <Style x:Key="Rift_Login_Main_Border" TargetType="Border">

        <Setter Property="CornerRadius" Value="7.5,7.5,0,0" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#1E1E26" />
                    <GradientStop Offset="0.788" Color="#1A1B1F" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Stackpanel Logo/Title  -->
    <Style x:Key="Rift_Login_StackPanel_Logo_Title" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="12,35,0,0" />
    </Style>

    <!--  Button in Login_Back_Arrow  -->
    <Style x:Key="Rift_Login_Button_Back_Arrow" TargetType="Button">

        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,-5,0" />
        <Setter Property="Height" Value="55" />
        <Setter Property="Width" Value="37" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <materialIcons:MaterialIcon
                        Width="50"
                        Height="50"
                        HorizontalAlignment="Center"
                        Foreground="#BFBDBD"
                        Kind="ChevronLeft" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Image in Login_Logo  -->
    <Style x:Key="Rift_Login_Image_Logo" TargetType="Image">

        <Setter Property="Source" Value="/Image/Rift_logo.png" />
        <Setter Property="Width" Value="60" />
        <Setter Property="Height" Value="60" />
        <Setter Property="Stretch" Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry
                    Center="30,30"
                    RadiusX="30"
                    RadiusY="30" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Stackpanel in Login_Title  -->
    <Style x:Key="Rift_Login_StackPanel_Title" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Vertical" />
        <Setter Property="Margin" Value="8,13,0,0" />
    </Style>
    <!--  TextBlock in Login_Title  -->
    <Style x:Key="Rift_Login_TextBlock_Title" TargetType="TextBlock">

        <Setter Property="Text" Value="RIFT" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Foreground" Value="#E6E7E8" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="Margin" Value="0,-10,0,0" />
        <Setter Property="FontFamily" Value="MotivaSans-Regular.ttf" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Textblock Profile  -->
    <Style x:Key="Rift_Login_TextBlock_Profile" TargetType="TextBlock">

        <Setter Property="Foreground" Value="#9E9E9E" />
        <Setter Property="Margin" Value="1,-5,0,0" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Text" Value="{DynamicResource login_title}" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Stackpanel Login_layout  -->
    <Style x:Key="Rift_Login_StackPanel_Layout" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Vertical" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <!--  Textblock for Title_sign in  -->
    <Style x:Key="Rift_Login_TextBlock_Layout" TargetType="TextBlock">

        <Setter Property="Text" Value="{DynamicResource login_signin_title}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Foreground" Value="#CD66FF" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  TextBox for sign in Account name  -->
    <Style x:Key="Rift_Login_TextBlock_Layout_AccountName" TargetType="TextBox">

        <Setter Property="Width" Value="250" />
        <Setter Property="Height" Value="35" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,5,0,0" />
        <Setter Property="Background" Value="#2F3138" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" Background="{TemplateBinding Background}">

                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,0,0,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="border" Property="Background" Value="#393C44" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Textblock for Title_password  -->
    <Style x:Key="Rift_Login_TextBlock_Layout_Password" TargetType="TextBlock">

        <Setter Property="Text" Value="{DynamicResource auth_password}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,15,0,0" />
        <Setter Property="Foreground" Value="#AAAAAA" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Passwordbox for sign  -->
    <Style x:Key="Rift_Login_Password_Layout_Password" TargetType="PasswordBox">

