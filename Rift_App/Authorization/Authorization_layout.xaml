                                                     <!-- Login -->
    <!-- Ellipse animation -->
    <Storyboard x:Key="PulseAnimation"
                RepeatBehavior="Forever"
                AutoReverse="True">
        <DoubleAnimation Storyboard.TargetName="Elipse1"
                         Storyboard.TargetProperty="ScaleX"
                         From="0.99"
                         To="0.9"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse1"
                         Storyboard.TargetProperty="ScaleY"
                         From="0.93"
                         To="0.88"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse2"
                         Storyboard.TargetProperty="ScaleX"
                         From="0.99"
                         To="0.9"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse2"
                         Storyboard.TargetProperty="ScaleY"
                         From="0.99"
                         To="0.9"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse3"
                         Storyboard.TargetProperty="ScaleX"
                         From="0.98"
                         To="1.05"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse3"
                         Storyboard.TargetProperty="ScaleY"
                         From="1"
                         To="1.02"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse4"
                         Storyboard.TargetProperty="ScaleX"
                         From="0.9"
                         To="1"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse4"
                         Storyboard.TargetProperty="ScaleY"
                         From="0.9"
                         To="1.1"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse5"
                         Storyboard.TargetProperty="ScaleX"
                         From="1"
                         To="1.1"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse5"
                         Storyboard.TargetProperty="ScaleY"
                         From="1"
                         To="1.3"
                         Duration="0:0:0:1" />
    </Storyboard>

