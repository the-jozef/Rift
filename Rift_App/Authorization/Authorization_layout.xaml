                    <GradientStop Offset="0.00" Color="#FFFFFF" />
                    <GradientStop Offset="0.084" Color="#A8DCFF" />
                    <GradientStop Offset="0.432" Color="#7B3FAF" />
                    <GradientStop Offset="0.80" Color="#3D1060" />
                    <GradientStop Offset="1.00" Color="#000000" />
                </RadialGradientBrush>
