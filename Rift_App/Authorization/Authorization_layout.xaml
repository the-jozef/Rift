        </Setter>
    </Style>

    <!-- Textblock for Title_password -->
    <Style x:Key="Rift_Login_TextBlock_Layout_Password"
           TargetType="TextBlock">

        <Setter Property="Text"
                Value="PASSWORD" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
