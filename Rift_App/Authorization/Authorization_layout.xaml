        <Setter Property="Foreground" Value="White" />
    </Style>

    <!--  Ellipses fro loading  -->
    <Style x:Key="Rift_SteamConnection_Ellipse_Loading" TargetType="Ellipse">

        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Opacity" Value="0.8" />
        <Setter Property="Fill">
            <Setter.Value>
                <SolidColorBrush Color="Transparent" />
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                    BlurRadius="100"
                    ShadowDepth="0"
                    Color="#FF007EFF" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Border for RIFT logo  -->
    <Style x:Key="Rift_SteamConnection_Border_Rift_Logo" TargetType="Border">

        <Setter Property="Width" Value="95" />
        <Setter Property="Height" Value="95" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Margin" Value="0,2,0,0" />

        <Setter Property="Background">
            <Setter.Value>

                <ImageBrush ImageSource="/Image/Rift_logo.png" Stretch="UniformToFill" />
            </Setter.Value>
        </Setter>
        <Setter Property="OpacityMask">
            <Setter.Value>
                <DrawingBrush>
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="Black">
                            <GeometryDrawing.Geometry>

                                <EllipseGeometry
                                    Center="60,60"
                                    RadiusX="60"
                                    RadiusY="60" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect
                    BlurRadius="80"
                    ShadowDepth="1"
                    Color="#83289C" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--  REGISTER  -->

    <!--  Main Border  -->
    <Style x:Key="Rift_Register_Main_Border" TargetType="Border">

        <Setter Property="CornerRadius" Value="7.5,7.5,0,0" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#1E1E26" />
                    <GradientStop Offset="0.788" Color="#1A1B1F" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Stackpanel Logo/Title  -->
    <Style x:Key="Rift_Register_StackPanel_Logo_Title" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="12,35,0,0" />
    </Style>

    <!--  Button in Register_Back_Arrow  -->
    <Style x:Key="Rift_Register_Button_Back_Arrow" TargetType="Button">

        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Margin" Value="0,0,-5,0" />
        <Setter Property="Height" Value="55" />
        <Setter Property="Width" Value="37" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <materialIcons:MaterialIcon
                        Width="50"
                        Height="50"
                        HorizontalAlignment="Center"
                        Foreground="#BFBDBD"
                        Kind="ChevronLeft" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Image in Register_Logo  -->
    <Style x:Key="Rift_Register_Image_Logo" TargetType="Image">

        <Setter Property="Source" Value="/Image/Rift_logo.png" />
        <Setter Property="Width" Value="60" />
        <Setter Property="Height" Value="60" />
        <Setter Property="Stretch" Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry
                    Center="30,30"
                    RadiusX="30"
                    RadiusY="30" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Stackpanel in Register_Title  -->
    <Style x:Key="Rift_Register_StackPanel_Title" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Vertical" />
        <Setter Property="Margin" Value="8,13,0,0" />
    </Style>

    <!--  TextBlock in Register_Title  -->
    <Style x:Key="Rift_Register_TextBlock_Title" TargetType="TextBlock">

        <Setter Property="Text" Value="RIFT" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Foreground" Value="#E6E7E8" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="Margin" Value="0,-10,0,0" />
        <Setter Property="FontFamily" Value="MotivaSans-Regular.ttf" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Textblock Profile  -->
    <Style x:Key="Rift_Register_TextBlock_Profile" TargetType="TextBlock">

        <Setter Property="Foreground" Value="#9E9E9E" />
        <Setter Property="Margin" Value="1,-5,0,0" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Text" Value="{DynamicResource auth_newaccount}" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Textblock for Create your Account  -->
    <Style x:Key="Rift_Register_Textblock_Create" TargetType="TextBlock">

        <Setter Property="Text" Value="{DynamicResource register_title}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="23.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Stackpanel Register_layout  -->
    <Style x:Key="Rift_Register_StackPanel_Layout" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Vertical" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <!--  Textblock for Title_Account_Name  -->
    <Style x:Key="Rift_Register_TextBlock_Layout" TargetType="TextBlock">

        <Setter Property="Text" Value="{DynamicResource register_username}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Foreground" Value="#CD66FF" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  TextBox for sign up Account name  -->
    <Style x:Key="Rift_Register_TextBlock_Layout_AccountName" TargetType="TextBox">

        <Setter Property="Width" Value="250" />
        <Setter Property="Height" Value="35" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="Background" Value="#2F3138" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" Background="{TemplateBinding Background}">

                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,0,0,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="border" Property="Background" Value="#393C44" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Textblock for Title_password  -->
    <Style x:Key="Rift_Register_TextBlock_Layout_Password" TargetType="TextBlock">

        <Setter Property="Text" Value="{DynamicResource auth_password}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,16,0,0" />
        <Setter Property="Foreground" Value="#AAAAAA" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <!--  Passwordbox for sign  -->
    <Style x:Key="Rift_Register_Password_Layout_Password" TargetType="PasswordBox">

        <Setter Property="Width" Value="250" />
        <Setter Property="Height" Value="35" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="Background" Value="#2F3138" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="PasswordChar" Value="●" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="border" Background="{TemplateBinding Background}">

                        <ScrollViewer x:Name="PART_ContentHost" Margin="10,0,0,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="border" Property="Background" Value="#393C44" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

