    <!-- Animations -->
    <Storyboard x:Key="LoadingAnimation"
                RepeatBehavior="Forever"
                Duration="0:0:3.8">

        <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse1"
                                      Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                      Duration="0:0:6"
                                      BeginTime="0:0:0">
            <LinearColorKeyFrame Value="#FF1F1F1F"
                                 KeyTime="0:0:0" />
            <LinearColorKeyFrame Value="#40AEF1"
                                 KeyTime="0:0:0.8" />
            <LinearColorKeyFrame Value="#FF1F1F1F"
                                 KeyTime="0:0:1.6" />
        </ColorAnimationUsingKeyFrames>

        <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse2"
                                      Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                      Duration="0:0:6"
                                      BeginTime="0:0:0.6">
            <LinearColorKeyFrame Value="#FF1F1F1F"
                                 KeyTime="0:0:0" />
            <LinearColorKeyFrame Value="#40AEF1"
                                 KeyTime="0:0:0.8" />
            <LinearColorKeyFrame Value="#FF1F1F1F"
                                 KeyTime="0:0:1.6" />
        </ColorAnimationUsingKeyFrames>

        <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse3"
                                      Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                      Duration="0:0:6"
                                      BeginTime="0:0:1.2">
            <LinearColorKeyFrame Value="#FF1F1F1F"
                                 KeyTime="0:0:0" />
            <LinearColorKeyFrame Value="#40AEF1"
                                 KeyTime="0:0:0.8" />
            <LinearColorKeyFrame Value="#FF1F1F1F"
                                 KeyTime="0:0:1.6" />
        </ColorAnimationUsingKeyFrames>

        <ColorAnimationUsingKeyFrames Storyboard.TargetName="Ellipse4"
                                      Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                      Duration="0:0:6"
                                      BeginTime="0:0:1.8">
            <LinearColorKeyFrame Value="#FF1F1F1F"
                                 KeyTime="0:0:0" />
            <LinearColorKeyFrame Value="#40AEF1"
                                 KeyTime="0:0:0.8" />
            <LinearColorKeyFrame Value="#FF1F1F1F"
                                 KeyTime="0:0:1.6" />
        </ColorAnimationUsingKeyFrames>
    </Storyboard>

