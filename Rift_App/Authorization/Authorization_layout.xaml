            <Setter.Value>

                <BlurEffect Radius="28" />

            </Setter.Value>
        </Setter>
    </Style>

    <!--  Steam Connection  -->

    <!--  Animations  -->
    <Storyboard
        x:Key="LoadingAnimation"
        RepeatBehavior="Forever"
        Duration="0:0:3.8">

        <ColorAnimationUsingKeyFrames
            BeginTime="0:0:0"
            Storyboard.TargetName="Ellipse1"
            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
            Duration="0:0:6">
            <LinearColorKeyFrame KeyTime="0:0:0" Value="#FF1F1F1F" />
            <LinearColorKeyFrame KeyTime="0:0:0.8" Value="#40AEF1" />
            <LinearColorKeyFrame KeyTime="0:0:1.6" Value="#FF1F1F1F" />
        </ColorAnimationUsingKeyFrames>

        <ColorAnimationUsingKeyFrames
            BeginTime="0:0:0.6"
            Storyboard.TargetName="Ellipse2"
            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
            Duration="0:0:6">
            <LinearColorKeyFrame KeyTime="0:0:0" Value="#FF1F1F1F" />
            <LinearColorKeyFrame KeyTime="0:0:0.8" Value="#40AEF1" />
            <LinearColorKeyFrame KeyTime="0:0:1.6" Value="#FF1F1F1F" />
        </ColorAnimationUsingKeyFrames>

        <ColorAnimationUsingKeyFrames
            BeginTime="0:0:1.2"
            Storyboard.TargetName="Ellipse3"
            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
            Duration="0:0:6">
            <LinearColorKeyFrame KeyTime="0:0:0" Value="#FF1F1F1F" />
            <LinearColorKeyFrame KeyTime="0:0:0.8" Value="#40AEF1" />
            <LinearColorKeyFrame KeyTime="0:0:1.6" Value="#FF1F1F1F" />
        </ColorAnimationUsingKeyFrames>

        <ColorAnimationUsingKeyFrames
            BeginTime="0:0:1.8"
            Storyboard.TargetName="Ellipse4"
            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
            Duration="0:0:6">
            <LinearColorKeyFrame KeyTime="0:0:0" Value="#FF1F1F1F" />
            <LinearColorKeyFrame KeyTime="0:0:0.8" Value="#40AEF1" />
            <LinearColorKeyFrame KeyTime="0:0:1.6" Value="#FF1F1F1F" />
        </ColorAnimationUsingKeyFrames>
    </Storyboard>

