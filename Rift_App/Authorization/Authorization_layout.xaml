<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">

    <!-- Account Selection -->
    <!-- Image in Background -->
    <Style x:Key="Rift_AccountSelection_Image_Background"
           TargetType="Image">

        <Setter Property="Source"
                Value="/Image/Steam.jpg" />
        <Setter Property="RenderOptions.BitmapScalingMode"
                Value="HighQuality" />
        <Setter Property="Opacity"
                Value="0.5" />
        <Setter Property="Panel.ZIndex"
                Value="0" />
    </Style>

    <!-- Video in Background -->
    <Style x:Key="Rift_AccountSelection_Video_Background"
           TargetType="MediaElement">

        <Setter Property="LoadedBehavior"
                Value="Play" />
        <Setter Property="UnloadedBehavior"
                Value="Manual" />
        <Setter Property="Source"
                Value="Videos\Background_animation.mp4" />
        <Setter Property="IsMuted"
                Value="True" />
        <Setter Property="Stretch"
                Value="UniformToFill" />
        <Setter Property="IsHitTestVisible"
                Value="False" />
        <Setter Property="Panel.ZIndex"
                Value="1" />
    </Style>

    <!-- Border in Background-->
    <Style x:Key="Rift_AccountSelection_Border_Background"
           TargetType="Border">

        <Setter Property="CornerRadius"
                Value="7.5,7.5,0,0" />
        <Setter Property="Background"
                Value="#505050" />
        <Setter Property="IsHitTestVisible"
                Value="False" />
        <Setter Property="Opacity"
                Value="0.15" />
        <Setter Property="Panel.ZIndex"
                Value="2" />
    </Style>

    <!-- StackPanel for Logo/Title -->
    <Style x:Key="Rift_AccountSelection_StackPanel_Logo_Title"
           TargetType="StackPanel">

        <Setter Property="Orientation"
                Value="Horizontal" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="Margin"
                Value="45,35,0,0" />
    </Style>

    <!-- Image in Logo/Title -->
    <Style x:Key="Rift_AccountSelection_Image_Logo_Title"
           TargetType="Image">

        <Setter Property="Source"
                Value="/Image/Rift_logo.png" />
        <Setter Property="Width"
                Value="60" />
        <Setter Property="Height"
                Value="60" />
        <Setter Property="Stretch"
                Value="UniformToFill" />
        <Setter Property="RenderOptions.BitmapScalingMode"
                Value="HighQuality" />
        <Setter Property="Clip">
            <Setter.Value>
                <EllipseGeometry Center="30,30"
                                 RadiusX="30"
                                 RadiusY="30" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBlock in Logo/Title -->
    <Style x:Key="Rift_AccountSelection_Textblock_Logo_Title"
           TargetType="TextBlock">

        <Setter Property="Text"
                Value="RIFT" />
        <Setter Property="Foreground"
                Value="#E6E7E8" />
        <Setter Property="FontSize"
                Value="32" />
        <Setter Property="FontWeight"
                Value="Medium" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="FontFamily"
                Value="MotivaSans-Regular.ttf" />
        <Setter Property="Margin"
                Value="10,3,0,0" />
    </Style>

    <!-- Window State Icons -->
    <Style x:Key="Rift_AccountSelection_Icon_WindowState"
           TargetType="materialIcons:MaterialIcon">

        <Setter Property="Width"
                Value="20" />
        <Setter Property="Height"
                Value="20" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Foreground"
                Value="#FF818181" />
    </Style>

    <!-- Close button -->
    <Style x:Key="Rift_AccountSelection_WindowState_Button_Close"
           TargetType="Button">

        <Setter Property="Foreground"
                Value="#FF818181" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderBrush"
                Value="Transparent" />
        <Setter Property="HorizontalAlignment"
                Value="Right" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="Width"
                Value="33" />
        <Setter Property="Height"
                Value="30" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius"
                Value="0,7.5,0,0" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="MinHeight"
                Value="0" />
        <Setter Property="MinWidth"
                Value="0" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding Path=(materialDesign:ButtonAssist.CornerRadius), 
                        RelativeSource={RelativeSource TemplatedParent}}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter Property="Background"
                                    Value="#E22A27" />
                            <Setter Property="Foreground"
                                    Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="DarkRed" />
                            <Setter Property="Foreground"
                                    Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBlock for -->
    <Style x:Key="Rift_AccountSelection_Textblock_Text"
           TargetType="TextBlock">

        <Setter Property="Text"
                Value="Who's playing?" />
        <Setter Property="FontSize"
                Value="27" />
        <Setter Property="FontWeight"
                Value="Bold" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
    </Style>

    <!-- Stackpanel Content -->
    <Style x:Key="Rift_AccountSelection_StackPanel_Content"
           TargetType="StackPanel">

        <Setter Property="Orientation"
                Value="Horizontal" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
    </Style>

    <!-- Button Account -->
    <Style x:Key="Rift_AccountSelection_Button_Account"
           TargetType="Button">

        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderBrush"
                Value="Transparent" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="MinHeight"
                Value="0" />
        <Setter Property="MinWidth"
                Value="0" />
        <Setter Property="Width"
                Value="100" />
        <Setter Property="Height"
                Value="140" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Width="100"
                          Height="140">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="100" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>

                        <Border x:Name="AccountBorder"
                                Grid.Row="0"
                                Width="100"
                                Height="100"
                                BorderThickness="0.5"
                                RenderTransformOrigin="0.5,0.5"
                                VerticalAlignment="Top">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FF505050" />
                            </Border.BorderBrush>
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="AccountScale"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Border.RenderTransform>

                            <Grid>
                                <Image Source="/Image/Red.png"
                                       Stretch="UniformToFill" />

                                <materialDesign:PopupBox x:Name="OptionsBox"
                                                         Style="{StaticResource Rift_MenuBar_PopupBox_Options}"
                                                         HorizontalAlignment="Right"
                                                         VerticalAlignment="Bottom"
                                                         Margin="0,0,5,5"
                                                         Opacity="0"
                                                         PlacementMode="RightAndAlignTopEdges">

                                    <materialDesign:PopupBox.ToggleContent>
                                        <Border Width="30"
                                                Height="20"
                                                Background="#CC000000"                                             
                                                CornerRadius="4"
                                                Cursor="Hand">
                                            
                                            <TextBlock Text="···"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </materialDesign:PopupBox.ToggleContent>

                                    <Button Content="Remove this Account?"
                                            Cursor="Hand"
                                            Margin="5,4,0,0"
                                            Command=""
                                            CommandParameter="{TemplateBinding Tag}">
                                        
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background"
                                                        Value="#3D4450" />
                                                <Setter Property="Foreground"
                                                        Value="White" />
                                                <Setter Property="BorderThickness"
                                                        Value="0" />
                                                <Setter Property="Padding"
                                                        Value="4" />
                                                <Setter Property="FontSize"
                                                        Value="11" />
                                                <Setter Property="FontFamily"
                                                        Value="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
                                                <Setter Property="FontWeight"
                                                        Value="Medium" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bg"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="4"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver"
                                                                         Value="True">
                                                                    <Setter TargetName="Bg"
                                                                            Property="Background"
                                                                            Value="#26292E" />
                                                                    <Setter Property="Foreground"
                                                                            Value="Red" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </materialDesign:PopupBox>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="AccountNameLabel"
                                   Grid.Row="1"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="0,6,0,0"
                                   Opacity="0" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- Zväčšenie -->
                                        <DoubleAnimation Storyboard.TargetName="AccountScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.1"
                                                         Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="AccountScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.2"
                                                         Duration="0:0:0.15" />

                                        <!-- Text posuň dole aby nebol medzi -->
                                        <ThicknessAnimation Storyboard.TargetName="AccountNameLabel"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="0,25,0,0"
                                                            Duration="0:0:0.15" />
                                        <!-- "..." fade in -->
                                        <DoubleAnimation Storyboard.TargetName="OptionsBox"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.15" />
                                        <!-- Text fade in -->
                                        <DoubleAnimation Storyboard.TargetName="AccountNameLabel"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccountScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="AccountScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.15" />
                                        <ColorAnimation Storyboard.TargetName="AccountBorder"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#FF505050"
                                                        Duration="0:0:0.15" />
                                       
                                        <DoubleAnimation Storyboard.TargetName="OptionsBox"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="AccountNameLabel"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Button Add_Account -->
    <Style x:Key="Rift_AccountSelection_Button_Add_Account"
           TargetType="Button">

        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderBrush"
                Value="Transparent" />
        <Setter Property="Padding"
                Value="0" />
        <Setter Property="MinHeight"
                Value="0" />
        <Setter Property="MinWidth"
                Value="0" />
        <Setter Property="Width"
                Value="100" />
        <Setter Property="Height"
                Value="100" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="Margin"
                Value="20,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Center">

                        <Border x:Name="IconBorder"
                                Width="100"
                                Height="100"
                                BorderThickness="2"
                                BorderBrush="Transparent"
                                Background="Transparent">
                            
                            <materialIcons:MaterialIcon x:Name="PlusIcon"
                                                        Kind="Plus"
                                                        Width="70"
                                                        Height="70"
                                                        Foreground="White"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                        </Border>

                        <TextBlock x:Name="AddAccountLabel"
                                   Text="Add Account"
                                   Foreground="White"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"
                                   Opacity="0" />
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IconBorder"
                                                         Storyboard.TargetProperty="Width"
                                                         To="80"
                                                         Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="IconBorder"
                                                         Storyboard.TargetProperty="Height"
                                                         To="80"
                                                         Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="PlusIcon"
                                                         Storyboard.TargetProperty="Width"
                                                         To="55"
                                                         Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="PlusIcon"
                                                         Storyboard.TargetProperty="Height"
                                                         To="55"
                                                         Duration="0:0:0.15" />
                                        <!-- Border to white -->
                                        <ColorAnimation Storyboard.TargetName="IconBorder"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="White"
                                                        Duration="0:0:0.15" />
                                        <!-- Label fade in -->
                                        <DoubleAnimation Storyboard.TargetName="AddAccountLabel"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- Border back to original size -->
                                        <DoubleAnimation Storyboard.TargetName="IconBorder"
                                                         Storyboard.TargetProperty="Width"
                                                         To="100"
                                                         Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="IconBorder"
                                                         Storyboard.TargetProperty="Height"
                                                         To="100"
                                                         Duration="0:0:0.15" />
                                        <!-- Border back to transparent -->
                                        <ColorAnimation Storyboard.TargetName="IconBorder"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="Transparent"
                                                        Duration="0:0:0.15" />
                                        <!-- Label fade out -->
                                        <DoubleAnimation Storyboard.TargetName="AddAccountLabel"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Login -->
    <!-- Ellipse animation -->
    <Storyboard x:Key="PulseAnimation"
                RepeatBehavior="Forever"
                AutoReverse="True">
        <DoubleAnimation Storyboard.TargetName="Elipse1"
                         Storyboard.TargetProperty="ScaleX"
                         From="0.99"
                         To="0.9"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse1"
                         Storyboard.TargetProperty="ScaleY"
                         From="0.93"
                         To="0.88"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse2"
                         Storyboard.TargetProperty="ScaleX"
                         From="0.99"
                         To="0.9"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse2"
                         Storyboard.TargetProperty="ScaleY"
                         From="0.99"
                         To="0.9"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse3"
                         Storyboard.TargetProperty="ScaleX"
                         From="0.98"
                         To="1.05"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse3"
                         Storyboard.TargetProperty="ScaleY"
                         From="1"
                         To="1.02"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse4"
                         Storyboard.TargetProperty="ScaleX"
                         From="0.9"
                         To="1"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse4"
                         Storyboard.TargetProperty="ScaleY"
                         From="0.9"
                         To="1.1"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse5"
                         Storyboard.TargetProperty="ScaleX"
                         From="1"
                         To="1.1"
                         Duration="0:0:0:1" />
        <DoubleAnimation Storyboard.TargetName="Elipse5"
                         Storyboard.TargetProperty="ScaleY"
                         From="1"
                         To="1.3"
                         Duration="0:0:0:1" />
    </Storyboard>

