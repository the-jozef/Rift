<UserControl x:Class="Rift_App.Authorization.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Authorization"
             mc:Ignorable="d"
             d:Height="435"
             d:Width="702">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PulseAnimation}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Border Style="{StaticResource Rift_Login_Main_Border}">

            <Grid>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <StackPanel Style="{StaticResource Rift_Login_StackPanel_Logo_Title}">
                            
                            <Button Style="{StaticResource Rift_Login_Button_Back_Arrow}"
                                    Command="{Binding ShowAccountSelectionCommand}" />
                            
                            <Image Style="{StaticResource Rift_Login_Image_Logo}" />
                            
                            <StackPanel Style="{StaticResource Rift_Login_StackPanel_Title}">
                                
                                <TextBlock Style="{StaticResource Rift_Login_TextBlock_Title}" />
                                
                                <TextBlock Style="{StaticResource Rift_Login_TextBlock_Profile}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Margin="60,30,0,0">

                            <StackPanel Style="{StaticResource Rift_Login_StackPanel_Layout}">

                                <TextBlock Style="{StaticResource Rift_Login_TextBlock_Layout}" />

                                <TextBox Style="{StaticResource Rift_Login_TextBlock_Layout_AccountName}"
                                         x:Name="UsernameBox"
                                         Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource Rift_Login_TextBlock_Layout_Password}" />

                                <PasswordBox Style="{StaticResource Rift_Login_Password_Layout_Password}"
                                             x:Name="PasswordBox"
                                             PasswordChanged="PasswordBox_PasswordChanged" />
                                
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="#FF6B6B"
                                           FontSize="11"
                                           Margin="2,6,0,0"
                                           MaxHeight="64"
                                           Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <Button Style="{StaticResource Rift_Login_Button_Layout_SignIn}"
                                        Command="{Binding LoginRiftCommand}" />

                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1"
                              Margin="47,20,0,0">
                            
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="133.5" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0"
                                    Style="{StaticResource Rift_Login_Border_Left_Line}" />
                            
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource Rift_Login_TextBlock_or}" />
                            
                            <Border Grid.Column="2"
                                    Style="{StaticResource Rift_Login_Border_Right_Line}" />
                        </Grid>

                        <Grid Grid.Row="2"
                              Margin="91,20,0,0">
                            
                            <Button Style="{StaticResource Rift_Login_Button_SteamConnection}"
                                    Command="{Binding LoginSteamCommand}" />
                        </Grid>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="355" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Button Style="{StaticResource Rift_Login_WindowState_Button_Close}"
                                Command="{Binding ShowAccountSelectionCommand}">
                            
                            <materialIcons:MaterialIcon Style="{StaticResource Rift_Login_Icon_WindowState}"
                                                        Kind="Close" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="2">
                        
                        <StackPanel Style="{StaticResource Rift_Login_StackPanel_CreateAccount}">
                            
                            <TextBlock Style="{StaticResource Rift_Login_TextBlock_CreateAccount}" />
                            
                            <Button Style="{StaticResource Rift_Login_Button_CreateAccount}"
                                    Command="{Binding ShowSteamConnectionCommand}" />
                        </StackPanel>
                    </Grid>

                    <Canvas Grid.Row="1">
                        
                        <Ellipse Canvas.Left="100"
                                 Canvas.Top="70"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="200"
                                 Canvas.Top="22"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="220"
                                 Canvas.Top="80"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="325"
                                 Canvas.Top="90"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="290"
                                 Canvas.Top="50"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="60"
                                 Canvas.Top="140"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="30"
                                 Canvas.Top="200"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="66"
                                 Canvas.Top="285"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="120"
                                 Canvas.Top="250"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="325"
                                 Canvas.Top="220"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="318"
                                 Canvas.Top="283"
                                 Style="{StaticResource Rift_Login_Stars}" />
                        <Ellipse Canvas.Left="220"
                                 Canvas.Top="280"
                                 Style="{StaticResource Rift_Login_Stars}" />
                    </Canvas>

                    <Canvas Grid.Row="1">
                        
                        <Ellipse Width="360"
                                 Height="320"
                                 Opacity="0.15"
                                 Canvas.Left="43"
                                 Style="{StaticResource Rift_Login_Rings}">

                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse1"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        
                        <Ellipse Width="310"
                                 Height="260"
                                 Opacity="0.15"
                                 Canvas.Left="77"
                                 Canvas.Top="31"
                                 Style="{StaticResource Rift_Login_Rings}">
                            
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse2"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        
                        <Ellipse Width="290"
                                 Height="240"
                                 Opacity="0.22"
                                 Canvas.Left="71"
                                 Canvas.Top="60"
                                 Style="{StaticResource Rift_Login_Rings}">
                            
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse3"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        
                        <Ellipse Width="250"
                                 Height="190"
                                 Opacity="0.22"
                                 Canvas.Left="91"
                                 Canvas.Top="87"
                                 Style="{StaticResource Rift_Login_Rings}">
                            
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse4"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        
                        <Ellipse Style="{StaticResource Rift_Login_Planet}"
                                 Canvas.Left="130"
                                 Canvas.Top="114">
                            
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse5"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Canvas>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>