<UserControl x:Class="Rift_App.Authorization.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Authorization"
             mc:Ignorable="d"
             d:Height="435"
             d:Width="702">

    <UserControl.Resources>
        <Storyboard x:Key="PulseAnimation"
                    RepeatBehavior="Forever"
                    AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Elipse1"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.99"
                             To="0.9"
                             Duration="0:0:0:1" />
            <DoubleAnimation Storyboard.TargetName="Elipse1"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.93"
                             To="0.88"
                             Duration="0:0:0:1" />
            <DoubleAnimation Storyboard.TargetName="Elipse2"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.99"
                             To="0.9"
                             Duration="0:0:0:1" />
            <DoubleAnimation Storyboard.TargetName="Elipse2"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.99"
                             To="0.9"
                             Duration="0:0:0:1" />
            <DoubleAnimation Storyboard.TargetName="Elipse3"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.98"
                             To="1.05"
                             Duration="0:0:0:1" />
            <DoubleAnimation Storyboard.TargetName="Elipse3"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="1.02"
                             Duration="0:0:0:1" />
            <DoubleAnimation Storyboard.TargetName="Elipse4"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.9"
                             To="1"
                             Duration="0:0:0:1" />
            <DoubleAnimation Storyboard.TargetName="Elipse4"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.9"
                             To="1.1"
                             Duration="0:0:0:1" />
            <DoubleAnimation Storyboard.TargetName="Elipse5"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="1.1"
                             Duration="0:0:0:1" />
            <DoubleAnimation Storyboard.TargetName="Elipse5"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="1.3"
                             Duration="0:0:0:1" />
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PulseAnimation}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Border Grid.Row="0"
                CornerRadius="7.5,7.5,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1"
                                     StartPoint="0.5,0">
                    <GradientStop Color="#1E1E26" />
                    <GradientStop Color="#1A1B1F"
                                  Offset="0.788" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />

                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource Rift_LoginTitle_stackpanel}"
                                Margin="40,35,0,0">

                        <Button Background="Transparent"
                                BorderBrush="Transparent"
                                Height="55"
                                Width="37"
                                Command="{Binding ShowAccountSelectionCommand}">

                            <materialIcons:MaterialIcon Kind="ChevronLeft"
                                                        Foreground="#BFBDBD"
                                                        Height="60"
                                                        Width="60"
                                                        Margin="-35,-6,0,0" />
                        </Button>

                        <Image Style="{StaticResource Rift_Logo_register}" />
                        
                        <TextBlock Style="{StaticResource Rift_Title_login}" />
                        
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <StackPanel Style="{StaticResource Rift_Layout_Stackpanel}">

                            <TextBlock Style="{StaticResource Rift_SignIn_Title}" />

                            <TextBox Style="{StaticResource Rift_SignIn_AccountName}"
                                     x:Name="UsernameBox"
                                     Text="{Binding Username}" />

                            <TextBlock Style="{StaticResource Rift_Password_Title}" />

                            <PasswordBox Style="{StaticResource Rift_SignIn_PasswordBox}"
                                         x:Name="PasswordBox"
                                         PasswordChanged="PasswordBox_PasswordChanged" />

                            <Button Style="{StaticResource Rift_SignIn_Button}"
                                    Command="{Binding LoginRiftCommand}" />
                            <!-- Command="{Binding SignInCommand}"-->



                            <Grid Margin="0,20,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="133.5" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="130" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource Rift_Border_lines}">
                                    <Border.Background>
                                        <LinearGradientBrush EndPoint="0.0,0"
                                                             StartPoint="1.0,0">
                                            <GradientStop Offset="1" />
                                            <GradientStop Color="#969696"
                                                          Offset="0.294" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource Rift_TextBlock_or}" />

                                <Border Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Style="{StaticResource Rift_Border_lines}">

                                    <Border.Background>
                                        <LinearGradientBrush EndPoint="0.0,0"
                                                             StartPoint="1.0,0">
                                            <GradientStop Offset="0" />
                                            <GradientStop Color="#969696"
                                                          Offset="0.294" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>

                            <Button Style="{StaticResource Rift_Steam_button}"
                                    Command="{Binding LoginSteamCommand}">

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <materialIcons:MaterialIcon Style="{StaticResource Rift_Steam_Icon}" />
                                    <TextBlock Style="{StaticResource Rift_Steam_Textblock}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="355" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Height="25"
                            Width="115"
                            HorizontalAlignment="Right"
                            Margin="0,0,50,0"
                            Background="#32353C"
                            Foreground="#AAAAAA"
                            BorderThickness="0"
                            FontSize="11"
                            Content="Odhlasit sa (test)"
                            Command="{Binding LogoutCommand}" />

                    <StackPanel Grid.Row="0"
                                Margin="318,0,0,0"
                                Width="33"
                                HorizontalAlignment="Left">

                        <Button Style="{StaticResource Rift_MenuBar_WindowState_Button_Close}"
                                Margin="0,0,0,0"
                                Height="30"
                                Width="33"
                                materialDesign:ButtonAssist.CornerRadius="0,7.5,0,0"
                                Command="{Binding ShowAccountSelectionCommand}">

                            <materialIcons:MaterialIcon Style="{StaticResource Rift_MenuBar_Icon_PopupBox_Account}"
                                                        Kind="Close"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Style="{StaticResource Rift_CreateAccount_Stackpanel}">
                        <TextBlock Style="{StaticResource Rift_CreateAccount_TextBlock}" />
                        <Button Style="{StaticResource Rift_CreateAccount_Button}"
                                Command="{Binding ShowSteamConnectionCommand}"  />
                    </StackPanel>

                    <Canvas Grid.Row="1">
                        <Ellipse Canvas.Left="100"
                                 Canvas.Top="70"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="200"
                                 Canvas.Top="22"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="220"
                                 Canvas.Top="80"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="325"
                                 Canvas.Top="90"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="290"
                                 Canvas.Top="50"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="60"
                                 Canvas.Top="140"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="30"
                                 Canvas.Top="200"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="66"
                                 Canvas.Top="285"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="120"
                                 Canvas.Top="250"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="325"
                                 Canvas.Top="220"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="318"
                                 Canvas.Top="283"
                                 Style="{StaticResource Rift_Stars}" />
                        <Ellipse Canvas.Left="220"
                                 Canvas.Top="280"
                                 Style="{StaticResource Rift_Stars}" />
                    </Canvas>

                    <Canvas Grid.Row="1">
                        <Ellipse Width="360"
                                 Height="320"
                                 Opacity="0.15"
                                 Canvas.Left="43">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#FF1E6FA8"
                                                  Offset="0" />
                                    <GradientStop Color="#FF0A3A5C"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse1"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse Width="310"
                                 Height="260"
                                 Opacity="0.15"
                                 Canvas.Left="77"
                                 Canvas.Top="31">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#FF2E8FC8"
                                                  Offset="0" />
                                    <GradientStop Color="#FF0D4870"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse2"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse Width="290"
                                 Height="240"
                                 Opacity="0.22"
                                 Canvas.Left="71"
                                 Canvas.Top="60">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#FF4AB8E8"
                                                  Offset="0" />
                                    <GradientStop Color="#FF1A6A9A"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse3"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse Width="250"
                                 Height="190"
                                 Opacity="0.22"
                                 Canvas.Left="91"
                                 Canvas.Top="87">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,1">
                                    <GradientStop Color="#FF4AB8E8"
                                                  Offset="0" />
                                    <GradientStop Color="#FF1A6A9A"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse4"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse Width="173"
                                 Height="151"
                                 Opacity="0.5"
                                 Canvas.Left="130"
                                 Canvas.Top="114">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.45,0.40"
                                                     Center="0.45,0.40"
                                                     RadiusX="0.6"
                                                     RadiusY="0.6">
                                    <GradientStop Color="#FF8ADCF8"
                                                  Offset="0.00" />
                                    <GradientStop Color="#FF38A8DC"
                                                  Offset="0.084" />
                                    <GradientStop Color="#FF1060A0"
                                                  Offset="0.432" />
                                    <GradientStop Color="#FF062240"
                                                  Offset="0.69" />
                                    <GradientStop Color="#00000000"
                                                  Offset="1.00" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Elipse5"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <BlurEffect Radius="28" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>