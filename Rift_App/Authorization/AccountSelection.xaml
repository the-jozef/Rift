<UserControl
    x:Class="Rift_App.Authorization.AccountSelection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rift_App.Authorization"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>

        <Image Style="{StaticResource Rift_AccountSelection_Image_Background}" />

        <MediaElement x:Name="BgVideo" Style="{StaticResource Rift_AccountSelection_Video_Background}" />

        <Border Style="{StaticResource Rift_AccountSelection_Border_Background}" />

        <Grid Panel.ZIndex="3">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">

                <StackPanel Style="{StaticResource Rift_AccountSelection_StackPanel_Logo_Title}">

                    <Image Style="{StaticResource Rift_AccountSelection_Image_Logo_Title}" />

                    <TextBlock Style="{StaticResource Rift_AccountSelection_Textblock_Logo_Title}" />
                </StackPanel>

                <Button Command="{Binding WindowState.CloseCommand}" Style="{StaticResource Rift_AccountSelection_WindowState_Button_Close}">

                    <materialIcons:MaterialIcon Kind="Close" Style="{StaticResource Rift_AccountSelection_Icon_WindowState}" />
                </Button>
            </Grid>

            <Grid Grid.Row="2" Margin="0,40,0,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Column="0">

                    <TextBlock Style="{StaticResource Rift_AccountSelection_Textblock_Text}" />

                </Grid>

                <Grid Grid.Row="1" Margin="0,30,0,0">

                    <ScrollViewer
                        HorizontalScrollBarVisibility="Auto"
                        Style="{StaticResource SteamScrollViewerStyle}"
                        VerticalScrollBarVisibility="Disabled">

                        <StackPanel Style="{StaticResource Rift_AccountSelection_StackPanel_Content}">

                            <ItemsControl ItemsSource="{Binding DeviceAccounts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Button
                                            Margin="0,0,20,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.SelectAccountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource Rift_AccountSelection_Button_Account}"
                                            Tag="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Command="{Binding ShowLoginCommand}" Style="{StaticResource Rift_AccountSelection_Button_Add_Account}" />

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>