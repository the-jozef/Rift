<UserControl x:Class="Rift_App.Authorization.AccountSelection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Authorization"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>

        <Image Style="{StaticResource Rift_AccountSelection_Image_Background}"/>
        
        <MediaElement x:Name="BgVideo"
                      Style="{StaticResource Rift_AccountSelection_Video_Background}"/>

        <Border Style="{StaticResource Rift_AccountSelection_Border_Background}"/>

        <Grid Panel.ZIndex="3">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">

                <StackPanel Style="{StaticResource Rift_AccountSelection_StackPanel_Logo_Title}">

                    <Image Style="{StaticResource Rift_AccountSelection_Image_Logo_Title}"/>

                    <TextBlock Style="{StaticResource Rift_AccountSelection_Textblock_Logo_Title}" />
                </StackPanel>

                <Button Style="{StaticResource Rift_AccountSelection_WindowState_Button_Close}"
                        Command="{Binding WindowState.CloseCommand}">

                    <materialIcons:MaterialIcon Style="{StaticResource Rift_AccountSelection_Icon_WindowState}"
                                                Kind="Close"/>
                </Button>
            </Grid>

            <Grid Grid.Row="2"
                  Margin="0,40,0,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Column="0">
                    
                    <TextBlock Style="{StaticResource Rift_AccountSelection_Textblock_Text}" />
                    
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,30,0,0">

                    <ScrollViewer Style="{StaticResource SteamScrollViewerStyle}"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  x:Name="MediaScroll">

                        <StackPanel Style="{StaticResource Rift_AccountSelection_StackPanel_Content}">

                            <Button Style="{StaticResource Rift_AccountSelection_Button_Account}"
                                    Command="{Binding SelectAccountCommand}"
                                    Tag="1414" />
             
                            <Button Style="{StaticResource Rift_AccountSelection_Button_Add_Account}"
                                    Command="{Binding ShowLoginCommand}"/>                            
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>