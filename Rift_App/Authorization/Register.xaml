<UserControl x:Class="Rift_App.Authorization.Register"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Authorization"
             xmlns:converters="clr-namespace:Rift_App.Converters"
             xmlns:vm="clr-namespace:Rift_App.ViewModels"
             mc:Ignorable="d"
             Height="438"
             Width="705">

    <Grid>
        <Border Grid.Row="0"
                CornerRadius="7.5,7.5,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="1,0"
                                     EndPoint="0,1">
                    <GradientStop Color="#FF1D1D25"
                                  Offset="1" />
                    <GradientStop Color="#1D1D21" />
                    <GradientStop Color="#FF1E1E26"
                                  Offset="0" />
                </LinearGradientBrush>
            </Border.Background>


            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">

                    <Grid.RowDefinitions>
                        <RowDefinition  Height="Auto" />
                        <RowDefinition  Height="Auto" />
                        <RowDefinition  Height="Auto" />
                        <RowDefinition  Height="Auto" />
                        <RowDefinition  Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Style="{StaticResource Rift_Title_stackpanel}"
                                Margin="36,35,0,0">

                        <Button Background="Transparent"
                                BorderBrush="Transparent"
                                Height="55"
                                Width="38"
                                Command="{Binding DataContext.ShowLoginCommand, 
RelativeSource={RelativeSource AncestorType=Window}}">

                            <materialIcons:MaterialIcon Kind="ChevronLeft"
                                                        Foreground="#BFBDBD"
                                                        Height="68"
                                                        Width="68"
                                                        Margin="-38,-10,0,0" />
                        </Button>

                        <Image Style="{StaticResource Rift_Logo_register}" />

                        <StackPanel Orientation="Vertical">

                            <TextBlock Style="{StaticResource Rift_Title_login}"
                                       Margin="10,-1,0,0"
                                       FontSize="30" />

                            <TextBlock Style="{StaticResource Rift_TextBlock_NewAccount}"
                                       Text="Profile"
                                       FontSize="19" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Style="{StaticResource Rift_Stackpanel_Information}"
                                Margin="68,35,0,0">

                        <TextBlock Style="{StaticResource Rift_Textblock_Connection}"
                                   Text="Create your Account" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Style="{StaticResource Rift_Layout_Stackpanel}"
                                HorizontalAlignment="Left"
                                Margin="85,22,0,0">

                        <TextBlock Style="{StaticResource Rift_SignIn_Title}"
                                   Text="Account name" />

                        <TextBox Style="{StaticResource Rift_SignIn_AccountName}"
                                 Text="{Binding SetupUsername, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="UsernameBox"
                                 Width="275" />

                        <TextBlock Style="{StaticResource Rift_Password_Title}" />

                        <PasswordBox Style="{StaticResource Rift_SignIn_PasswordBox}"
                                     x:Name="PasswordBox"
                                     Width="275" />
                    </StackPanel>

                    <StackPanel Grid.Row="3"
                                Style="{StaticResource Rift_Stackpanel_Button Layout}"
                                Margin="120,25,0,0">

                        <Button Style="{StaticResource Rift_SignIn_Button_test}"
                                Command="{Binding SignInCommand}"
                                Content="Create Account"
                                Margin="2,0,0,0" />

                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>


                    <StackPanel Margin="0,0,0,0"
                                Width="33"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right">

                        <Button Style="{StaticResource Rift_CLoseButton}"
                                Margin="0,0,0,0"
                                Height="30"
                                Width="33"
                                materialDesign:ButtonAssist.CornerRadius="0,7.5,0,0"
                                Command="{Binding WindowState.CloseCommand}">
                            <materialIcons:MaterialIcon Style="{StaticResource Rift_WindowState_Icons}"
                                                        Kind="Close"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <StackPanel Orientation="Vertical"
                                    Width="Auto"
                                    Height="Auto"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,50,0,0">

                            <TextBlock Text="Join RIFT"
                                       Foreground="White"
                                       FontSize="25"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />

                            <TextBlock Text="Experience Everything you need"
                                       Foreground="#B0B0B0"
                                       FontSize="15" />
                        </StackPanel>

                        <StackPanel Width="Auto"
                                    Height="Auto"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,20,0,0">

                            <Border Background="#20222E"
                                    Padding="5"
                                    CornerRadius="5"
                                    BorderBrush="#282C38"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">

                                    <StackPanel HorizontalAlignment="Left"
                                                VerticalAlignment="Center">

                                        <Border Background="#9C0FD6"
                                                Width="30"
                                                Height="30"
                                                CornerRadius="7">

                                            <materialIcons:MaterialIcon Kind="ShieldOutline"
                                                                        Foreground="White"
                                                                        Height="20"
                                                                        Width="20" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Orientation="Vertical"
                                                Margin="10,0,0,0">

                                        <TextBlock Text="Secure &amp; Protected"
                                                   FontSize="15"
                                                   Foreground="White" />

                                        <TextBlock Text="Advanced encryption"
                                                   Foreground="#B0B0B0"
                                                   FontSize="10"
                                                   Margin="2,0,0,0" />

                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="#20222E"
                                    Padding="5"
                                    CornerRadius="5"
                                    BorderBrush="#282C38"
                                    BorderThickness="1"
                                    Margin="0,10,0,0">

                                <StackPanel Orientation="Horizontal">

                                    <StackPanel HorizontalAlignment="Left">

                                        <Border Background="#9C0FD6"
                                                Width="30"
                                                Height="30"
                                                CornerRadius="7">

                                            <materialIcons:MaterialIcon Kind="GamepadVariantOutline"
                                                                        Foreground="White"
                                                                        Height="20"
                                                                        Width="20" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Orientation="Vertical"
                                                Margin="10,0,0,0">

                                        <TextBlock Text="Your entire Steam library"
                                                   FontSize="15"
                                                   Foreground="White" />

                                        <TextBlock Text="Games in one place"
                                                   Foreground="#B0B0B0"
                                                   FontSize="10"
                                                   Margin="2,0,0,0" />

                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="#20222E"
                                    Padding="5"
                                    CornerRadius="5"
                                    BorderBrush="#282C38"
                                    BorderThickness="1"
                                    Margin="0,10,0,0">

                                <StackPanel Orientation="Horizontal">

                                    <StackPanel HorizontalAlignment="Left">

                                        <Border Background="#9C0FD6"
                                                Width="30"
                                                Height="30"
                                                CornerRadius="7">

                                            <materialIcons:MaterialIcon Kind="AutoAwesomeOutline"
                                                                        Foreground="White"
                                                                        Height="20"
                                                                        Width="20" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Orientation="Vertical"
                                                Margin="10,0,0,0">

                                        <TextBlock Text="Clean and modern design"
                                                   FontSize="15"
                                                   Foreground="White" />

                                        <TextBlock Text="Simple, modern and minimal,"
                                                   Foreground="#B0B0B0"
                                                   FontSize="10"
                                                   Margin="2,0,0,0" />

                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,12,1">
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>