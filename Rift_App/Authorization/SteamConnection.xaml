<UserControl x:Class="Rift_App.Authorization.SteamConnection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Authorization"
             xmlns:converters="clr-namespace:Rift_App.Converters"
             xmlns:vm="clr-namespace:Rift_App.ViewModels"
             mc:Ignorable="d"
             Height="438"
             Width="705">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource LoadingAnimation}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Border Style="{StaticResource Rift_SteamConnection_Main_Border}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">

                        <StackPanel Style="{StaticResource Rift_SteamConnection_StackPanel_Logo_Title}">

                            <Button Style="{StaticResource Rift_SteamConnection_Button_Back_Arrow}"
                                    Command="{Binding ShowAccountSelectionCommand}" />

                            <Image Style="{StaticResource Rift_SteamConnection_Image_Logo}" />

                            <StackPanel Style="{StaticResource Rift_SteamConnection_StackPanel_Title}">

                                <TextBlock Style="{StaticResource Rift_SteamConnection_TextBlock_Title}" />

                                <TextBlock Style="{StaticResource Rift_SteamConnection_TextBlock_Profile}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="75,60,0,0">

                        <StackPanel Orientation="Vertical">
                            <TextBlock Style="{StaticResource Rift_SteamConnection_Textblock_Connection}" />

                            <TextBlock Style="{StaticResource Rift_SteamConnection_Textblock_AccountLink}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="90,50,0,0">

                        <Button Style="{StaticResource Rift_SteamConnection_Button_SteamConnection}"
                                Command="{Binding ConnectSteamCommand}" />
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">

                        <Button Style="{StaticResource Rift_SteamConnection_WindowState_Button_Close}"
                                Command="{Binding ShowAccountSelectionCommand}">

                            <materialIcons:MaterialIcon Style="{StaticResource Rift_SteamConnection_Icon_WindowState}"
                                                        Kind="Close" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1">
                        
                        
                        
                        
                        
                        
                        

                        <StackPanel Grid.Row="1"
                                    Style="{StaticResource Rift_SteamConnection_StackPanel_Loading_Logos}">

                            <StackPanel>
                                <Border Style="{StaticResource Rift_Border_Steam}">

                                    <materialIcons:MaterialIcon Style="{StaticResource Rift_SteamIcon_border}" />
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        Margin="10,0,10,0">

                                <Ellipse Style="{StaticResource Rift_Ellipse_Loading}"
                                         x:Name="Ellipse1" />

                                <Ellipse Style="{StaticResource Rift_Ellipse_Loading}"
                                         x:Name="Ellipse2" />

                                <Ellipse Style="{StaticResource Rift_Ellipse_Loading}"
                                         x:Name="Ellipse3" />

                                <Ellipse Style="{StaticResource Rift_Ellipse_Loading}"
                                         x:Name="Ellipse4" />
                            </StackPanel>

                            <StackPanel>

                                <Border Style="{StaticResource Rift_Border_Logo}">

                                    <Image Style="{StaticResource Rift_Logo}" />

                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>