<UserControl x:Class="Rift_App.Controls.RiftTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Controls"
             mc:Ignorable="d">
    <Grid>
        <Border Grid.Row="0"
                Background="{StaticResource RiftCardBackground}"
                CornerRadius="7.5,7.5,0,0">

            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Padding"
                            Value="0,0,0,0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}"
                                     Value="Maximized">
                            <Setter Property="Padding"
                                    Value="0,7,0,0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid Height="70">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel     Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource Rift_TitleBar}">

                    <Button Style="{StaticResource Rift_LogoHeader}" />

                    <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox}"
                                             Margin="20,0.5,0,0">
                        <materialDesign:PopupBox.ToggleContent>
                            <TextBlock Text="View">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource Rift_PopupTextblock}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource RiftForeground}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, 
                                                         RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                         Value="True">
                                                <Setter Property="Foreground"
                                                        Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </materialDesign:PopupBox.ToggleContent>
                        <ScrollViewer Style="{StaticResource Rift_ScrollViewer}">
                            <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                <Button Content="Library"
                                        Style="{StaticResource Rift_PopupItems}" />
                                <Button Content="Store"
                                        Style="{StaticResource Rift_PopupItems}" />
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:PopupBox>

                    <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox}"
                                             Margin="15,0.5,0,0">
                        <materialDesign:PopupBox.ToggleContent>
                            <TextBlock Text="Games">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource Rift_PopupTextblock}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource RiftForeground}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, 
                                                         RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                         Value="True">
                                                <Setter Property="Foreground"
                                                        Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </materialDesign:PopupBox.ToggleContent>
                        <ScrollViewer Style="{StaticResource Rift_ScrollViewer}">
                            <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                <Button Content="View Games Library"
                                        Style="{StaticResource Rift_PopupItems}" />
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:PopupBox>

                    <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox}"
                                             Margin="16,0.5,0,0">
                        <materialDesign:PopupBox.ToggleContent>
                            <TextBlock Text="Help">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock"
                                           BasedOn="{StaticResource Rift_PopupTextblock}">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource RiftForeground}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, 
                                                         RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                         Value="True">
                                                <Setter Property="Foreground"
                                                        Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </materialDesign:PopupBox.ToggleContent>
                        <ScrollViewer Style="{StaticResource Rift_ScrollViewer}">
                            <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                <Button Content="Rift Support"
                                        Style="{StaticResource Rift_PopupItems}" />
                                <Button Content="About RIFT"
                                        Style="{StaticResource Rift_PopupItems}" />
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:PopupBox>
                </StackPanel>

                <Grid Grid.Column="0"
                      Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1"
                                Grid.Row="1"
                                Orientation="Horizontal"
                                Grid.RowSpan="2">

                        <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox_options}"
                                                 Margin="30,0,0,0">
                            <materialDesign:PopupBox.ToggleContent>
                                <TextBlock Text="STORE">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource Rift_PopupTextblock_options}">
                                            <Setter Property="Foreground"
                                                    Value="#C4C7CC" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, 
              RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="White" />

                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </materialDesign:PopupBox.ToggleContent>
                            <Border Background="#3D4450"
                                    SnapsToDevicePixels="True"
                                    UseLayoutRounding="True">
                                <ScrollViewer Style="{StaticResource Rift_ScrollViewer}">
                                    <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                        <Button Content="Featured"
                                                Style="{StaticResource Rift_PopupItems}" />
                                        <Button Content="Wishlist"
                                                Style="{StaticResource Rift_PopupItems}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </materialDesign:PopupBox>

                        <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox_options}"
                                                 Margin="20,0,0,0">
                            <materialDesign:PopupBox.ToggleContent>
                                <TextBlock Text="LIBRARY">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource Rift_PopupTextblock_options}">
                                            <Setter Property="Foreground"
                                                    Value="#C4C7CC" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, 
                                     RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </materialDesign:PopupBox.ToggleContent>
                            <ScrollViewer Style="{StaticResource Rift_ScrollViewer}">
                                <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                    <Button Content="Home"
                                            Style="{StaticResource Rift_PopupItems}" />
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:PopupBox>

                        <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox_options}"
                                                 Margin="20,0,0,0">
                            <materialDesign:PopupBox.ToggleContent>
                                <TextBlock Text="NICKNAME">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource Rift_PopupTextblock_options}">
                                            <Setter Property="Foreground"
                                                    Value="#C4C7CC" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, 
              RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </materialDesign:PopupBox.ToggleContent>
                            <ScrollViewer Style="{StaticResource Rift_ScrollViewer}">
                                <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                    <Button Content="Profile"
                                            Style="{StaticResource Rift_PopupItems}" />
                                    <Button Content="Library"
                                            Style="{StaticResource Rift_PopupItems}" />
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:PopupBox>

                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1"
                      Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />

                    </Grid.ColumnDefinitions>

                    <StackPanel Style="{StaticResource Rift_StackPanel_Action}"
                                Grid.Column="1"
                                Grid.Row="0">

                        <materialDesign:PopupBox Style="{StaticResource Rift_Notifications_PopupBox}">
                            <materialDesign:PopupBox.ToggleContent>
                                <materialIcons:MaterialIcon Kind="Bell">
                                    <materialIcons:MaterialIcon.Style>
                                        <Style TargetType="materialIcons:MaterialIcon">
                                            <Setter Property="Foreground"
                                                    Value="#959AA3" />
                                            <Setter Property="Margin"
                                                    Value="17.5,0,0,0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, 
                            RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="#C7C9D1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialIcons:MaterialIcon.Style>
                                </materialIcons:MaterialIcon>
                            </materialDesign:PopupBox.ToggleContent>
                            <ScrollViewer Style="{StaticResource Rift_ScrollViewer}">
                                <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                    <Button Content="View Notifications"
                                            Style="{StaticResource Rift_Notification_Item}" />
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:PopupBox>

                        <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox_Account}">
                            <materialDesign:PopupBox.ToggleContent>
                                <Border Style="{StaticResource Rift_Border_Account}">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Guest_test"
                                                   Style="{StaticResource Rift_PopupTextblock_Account}" />
                                        <materialIcons:MaterialIcon Style="{StaticResource Rift_ChevronDown_Icon}"/>
                                    </StackPanel>
                                </Border>
                            </materialDesign:PopupBox.ToggleContent>
                            <ScrollViewer Style="{StaticResource Rift_ScrollViewer}">
                                <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                    <Button Content="View my profile"
                                            Style="{StaticResource Rift_PopupItems}" />
                                    <Button Content="Change Account"
                                            Style="{StaticResource Rift_PopupItems}"
                                            Command="{Binding OpenAuthCommand}"/>
                                    <Button Content="Sign out of account..."
                                            Style="{StaticResource Rift_PopupItems}" />
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:PopupBox>

                    </StackPanel>
                    <StackPanel Style="{StaticResource Rift_StackPanel_WindowButtons}"
                                Grid.Column="2"
                                Grid.Row="0">

                        <Button Style="{StaticResource Rift_StateWindow_Button}"
                                Command="{Binding MinimizeWindowCommand}">
                            <materialIcons:MaterialIcon Style="{StaticResource Rift_WindowState_Icons}"
                                                        Kind="Minimize"
                                                        Foreground="{Binding Foreground, 
                                                        RelativeSource={RelativeSource AncestorType=Button}}">
                            </materialIcons:MaterialIcon>
                        </Button>

                        <Button Style="{StaticResource Rift_StateWindow_Button}"
                                Command="{Binding MaximizeWindowCommand}">
                            <materialIcons:MaterialIcon Style="{StaticResource Rift_WindowState_Icons}"
                                                        Kind="WindowMaximize"
                                                        Foreground="{Binding Foreground, 
                                    RelativeSource={RelativeSource AncestorType=Button}}">
                            </materialIcons:MaterialIcon>
                        </Button>

                        
                        <Button Style="{StaticResource Rift_CLoseButton}"
                                Margin="0,-5,0,0"
                                Height="30"
                                Width="33"
                                materialDesign:ButtonAssist.CornerRadius="0,7.5,0,0"
                                Command="{Binding CloseWindowCommand}">

                            <materialIcons:MaterialIcon Style="{StaticResource Rift_WindowState_Icons}"
                                                        Kind="Close"
                                                        Foreground="{Binding Foreground,RelativeSource={RelativeSource AncestorType=Button}}">
                            </materialIcons:MaterialIcon>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
