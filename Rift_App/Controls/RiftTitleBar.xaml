<UserControl x:Class="Rift_App.Controls.RiftTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="90"
             d:DesignWidth="798">
    <Grid>
        <Border Grid.Row="0"
                Background="{StaticResource RiftCardBackground}"
                CornerRadius="7.5,7.5,0,0">
            
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Padding"
                            Value="0,0,0,0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}"
                                     Value="Maximized">
                            <Setter Property="Padding"
                                    Value="0,7,0,0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid Height="90">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel     Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource Rift_TitleBar}">

                    <Button Style="{StaticResource Rift_LogoHeader}">
                    </Button>

                    <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox}">
                        <materialDesign:PopupBox.ToggleContent>
                            <TextBlock Text="View"
                                       VerticalAlignment="Center" />
                        </materialDesign:PopupBox.ToggleContent>
                        <ScrollViewer MaxHeight="200"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                <Button Content="Library"
                                        Style="{StaticResource Rift_PopupItem}" />
                                <Button Content="Games"
                                        Style="{StaticResource Rift_PopupItem}" />
                                <Button Content="Store"
                                        Style="{StaticResource Rift_PopupItem}" />
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:PopupBox>
                    
                    
                    
                    <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox}">
                        <materialDesign:PopupBox.ToggleContent>
                            <TextBlock Text="Games"
                                       VerticalAlignment="Center" />
                        </materialDesign:PopupBox.ToggleContent>
                        <ScrollViewer MaxHeight="200"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                <Button Content="Game Library"
                                        Style="{StaticResource Rift_PopupItem}" />
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:PopupBox>
                    <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox}">
                        <materialDesign:PopupBox.ToggleContent>
                            <TextBlock Text="Help"
                                       VerticalAlignment="Center" />
                        </materialDesign:PopupBox.ToggleContent>
                        <ScrollViewer MaxHeight="200"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                <Button Content="Support"
                                        Style="{StaticResource Rift_PopupItem}" />
                                <Button Content="About RIFT"
                                        Style="{StaticResource Rift_PopupItem}" />
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:PopupBox>
                </StackPanel>
                <Grid Grid.Column="0"
                      Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1"
                                Grid.Row="1"
                                Orientation="Horizontal"
                                Grid.RowSpan="2">
                        <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox2}">
                            <materialDesign:PopupBox.ToggleContent>
                                <TextBlock Text="STORE" />
                            </materialDesign:PopupBox.ToggleContent>
                            <ScrollViewer MaxHeight="200"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                    <Button Content="Support"
                                            Style="{StaticResource Rift_PopupItem}" />
                                    <Button Content="About RIFT"
                                            Style="{StaticResource Rift_PopupItem}" />
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:PopupBox>
                        <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox2}">
                            <materialDesign:PopupBox.ToggleContent>
                                <TextBlock Text="LIBRARY"
                                           VerticalAlignment="Center" />
                            </materialDesign:PopupBox.ToggleContent>
                            <ScrollViewer MaxHeight="200"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                    <Button Content="Support"
                                            Style="{StaticResource Rift_PopupItem}" />
                                    <Button Content="About RIFT"
                                            Style="{StaticResource Rift_PopupItem}" />
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:PopupBox>
                        <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox2}">
                            <materialDesign:PopupBox.ToggleContent>
                                <TextBlock Text="COMMUNITY"
                                           VerticalAlignment="Center" />
                            </materialDesign:PopupBox.ToggleContent>
                            <ScrollViewer MaxHeight="200"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                    <Button Content="Support"
                                            Style="{StaticResource Rift_PopupItem}" />
                                    <Button Content="About RIFT"
                                            Style="{StaticResource Rift_PopupItem}" />
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:PopupBox>
                        <!-- Repair nickname for game name or guest name-->
                        <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox2}">
                            <materialDesign:PopupBox.ToggleContent>
                                <TextBlock Text="NICKNAME"
                                           VerticalAlignment="Center" />
                            </materialDesign:PopupBox.ToggleContent>
                            <ScrollViewer MaxHeight="200"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                    <Button Content="Support"
                                            Style="{StaticResource Rift_PopupItem}" />
                                    <Button Content="About RIFT"
                                            Style="{StaticResource Rift_PopupItem}" />
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:PopupBox>
                    </StackPanel>
                </Grid>
                <Grid Grid.Column="1"
                      Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="139" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1"
                                Grid.Row="0"
                                Style="{StaticResource Rift_StackPanel_right_up}">
                        <Button Style="{StaticResource Rift_Button3}"
                                Width="44">
                            <materialIcons:MaterialIcon Style="{StaticResource Rift_Icons}"
                                                        Kind="Bell">
                            </materialIcons:MaterialIcon>
                        </Button>
                        <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox}"
                                                 Height="14"
                                                 Width="51">
                            <materialDesign:PopupBox.ToggleContent>
                                <TextBlock Text="Nickname" />
                            </materialDesign:PopupBox.ToggleContent>
                            <ScrollViewer MaxHeight="200"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                    <Button Content="Game Library"
                                            Style="{StaticResource Rift_PopupItem}" />
                                </StackPanel>
                            </ScrollViewer>
                        </materialDesign:PopupBox>
                        <Button Style="{StaticResource Rift_Button2}"
                                Height="25"
                                Width="42">
                            <materialIcons:MaterialIcon Style="{StaticResource Rift_Icons2}"
                                                        Kind="Minimize">
                            </materialIcons:MaterialIcon>
                        </Button>
                        <Button Style="{StaticResource Rift_Button2}"
                                Height="25"
                                Width="42"
                                Command="{Binding MaximizeWindowCommand}">
                            <materialIcons:MaterialIcon Style="{StaticResource Rift_Icons2}"
                                                        Kind="WindowMaximize">
                            </materialIcons:MaterialIcon>
                        </Button>

                        <Button Style="{StaticResource Rift_Button2}"
                                Height="25"
                                Width="42"
                                materialDesign:ButtonAssist.CornerRadius="0,7.8,0,0"
                                Command="{Binding CloseWindowCommand}">
                            <materialIcons:MaterialIcon Style="{StaticResource Rift_Icons2}"
                                                        Kind="Close">
                            </materialIcons:MaterialIcon>
                        </Button>

                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
