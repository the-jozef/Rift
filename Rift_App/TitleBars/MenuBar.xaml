<UserControl x:Class="Rift_App.TitleBars.MenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.TitleBars"
             mc:Ignorable="d">

    <Grid>
        <Border Style="{StaticResource Rift_Menubar_MainBorder}">

            <Grid Height="80">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Margin="10,0,0,0">

                            <Button Style="{StaticResource Rift_MenuBar_LogoHeader}"
                                    WindowChrome.IsHitTestVisibleInChrome="True" />
                        </Grid>

                        <Grid Grid.Column="1"
                              Margin="20,0,0,1.4">

                            <materialDesign:PopupBox Style="{StaticResource Rift_Menubar_PopupBox_Tools}"
                                                     WindowChrome.IsHitTestVisibleInChrome="True">

                                <materialDesign:PopupBox.ToggleContent>
                                    <TextBlock Text="View"
                                               Style="{StaticResource Rift_Menubar_Textblock_PopupBox_Tools}" />

                                </materialDesign:PopupBox.ToggleContent>

                                <ScrollViewer Style="{StaticResource Rift_MenuBar_ScrollViewer_PopupBox_Tools_Options_Notifications}">

                                    <StackPanel>
                                        <Button Content="Library"
                                                Command="{Binding ShowLibraryCommand}"
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />
                                        <Button Content="Store"
                                                Command="{Binding ShowStoreCommand}"
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </materialDesign:PopupBox>
                        </Grid>

                        <Grid Grid.Column="2"
                              Margin="15,0,0,1.4">

                            <materialDesign:PopupBox Style="{StaticResource Rift_Menubar_PopupBox_Tools}"
                                                     WindowChrome.IsHitTestVisibleInChrome="True">

                                <materialDesign:PopupBox.ToggleContent>
                                    <TextBlock Text="Games"
                                               Style="{StaticResource Rift_Menubar_Textblock_PopupBox_Tools}" />

                                </materialDesign:PopupBox.ToggleContent>

                                <ScrollViewer Style="{StaticResource Rift_MenuBar_ScrollViewer_PopupBox_Tools_Options_Notifications}">

                                    <StackPanel>
                                        <Button Content="View Games Library"
                                                Command=""
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />
                                        <Button Content="View Store"
                                                Command=""
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </materialDesign:PopupBox>
                        </Grid>

                        <Grid Grid.Column="3"
                              Margin="16,0,0,1.4">

                            <materialDesign:PopupBox Style="{StaticResource Rift_Menubar_PopupBox_Tools}"
                                                     WindowChrome.IsHitTestVisibleInChrome="True">

                                <materialDesign:PopupBox.ToggleContent>
                                    <TextBlock Text="Help"
                                               Style="{StaticResource Rift_Menubar_Textblock_PopupBox_Tools}" />

                                </materialDesign:PopupBox.ToggleContent>

                                <ScrollViewer Style="{StaticResource Rift_MenuBar_ScrollViewer_PopupBox_Tools_Options_Notifications}">

                                    <StackPanel>
                                        <Button Content="Rift Support"
                                                Command=""
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />

                                        <Button Content="About RIFT"
                                                Command=""
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />

                                    </StackPanel>
                                </ScrollViewer>
                            </materialDesign:PopupBox>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Margin="30,0,0,0">

                            <materialDesign:PopupBox Style="{StaticResource Rift_MenuBar_PopupBox_Options}"
                                                     WindowChrome.IsHitTestVisibleInChrome="True">

                                <materialDesign:PopupBox.ToggleContent>
                                    <TextBlock Text="STORE"
                                               Style="{StaticResource Rift_MenuBar_Textblock_PopupBox_Options}" />

                                </materialDesign:PopupBox.ToggleContent>

                                <ScrollViewer Style="{StaticResource Rift_MenuBar_ScrollViewer_PopupBox_Tools_Options_Notifications}">

                                    <StackPanel>
                                        <Button Content="Featured"
                                                Command=""
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />
                                        <Button Content="Wishlist"
                                                Command=""
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </materialDesign:PopupBox>
                        </Grid>

                        <Grid Grid.Column="1"
                              Margin="20,0,0,0">

                            <materialDesign:PopupBox Style="{StaticResource Rift_MenuBar_PopupBox_Options}"
                                                     WindowChrome.IsHitTestVisibleInChrome="True">

                                <materialDesign:PopupBox.ToggleContent>
                                    <TextBlock Text="LIBRARY"
                                               Style="{StaticResource Rift_MenuBar_Textblock_PopupBox_Options}" />

                                </materialDesign:PopupBox.ToggleContent>

                                <ScrollViewer Style="{StaticResource Rift_MenuBar_ScrollViewer_PopupBox_Tools_Options_Notifications}">

                                    <StackPanel>
                                        <Button Content="Home"
                                                Command=""
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </materialDesign:PopupBox>
                        </Grid>

                        <Grid Grid.Column="2"
                              Margin="20,0,0,0">

                            <materialDesign:PopupBox Style="{StaticResource Rift_MenuBar_PopupBox_Options}"
                                                     WindowChrome.IsHitTestVisibleInChrome="True">

                                <materialDesign:PopupBox.ToggleContent>
                                    <TextBlock Text="NICKNAME"
                                               Style="{StaticResource Rift_MenuBar_Textblock_PopupBox_Options}" />

                                </materialDesign:PopupBox.ToggleContent>

                                <ScrollViewer Style="{StaticResource Rift_MenuBar_ScrollViewer_PopupBox_Tools_Options_Notifications}">

                                    <StackPanel>
                                        <Button Content="Profile"
                                                Command=""
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />
                                        <Button Content="Library"
                                                Command=""
                                                Style="{StaticResource Rift_MenuBar_Items_PopupBox_Tools_Options}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </materialDesign:PopupBox>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">

                            <StackPanel Orientation="Horizontal">

                                <materialDesign:PopupBox Style="{StaticResource Rift_MenuBar_PopupBox_Notifications}"
                                                         WindowChrome.IsHitTestVisibleInChrome="True" >

                                    <materialDesign:PopupBox.ToggleContent>
                                        <materialIcons:MaterialIcon Style="{StaticResource Rift_MenuBar_Icon_PopupBox_Notifications}" />

                                    </materialDesign:PopupBox.ToggleContent>

                                    <ScrollViewer Style="{StaticResource Rift_MenuBar_ScrollViewer_PopupBox_Tools_Options_Notifications}">

                                        <StackPanel>
                                            <Button Content="View Notifications"
                                                    Command=""
                                                    Style="{StaticResource Rift_MenuBar_Items_PopupBox_Notifications}" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </materialDesign:PopupBox>

                                <materialDesign:PopupBox Style="{StaticResource Rift_MenuBar_PopupBox_Account}"
                                                         WindowChrome.IsHitTestVisibleInChrome="True" >

                                    <materialDesign:PopupBox.ToggleContent>
                                        <Border Style="{StaticResource Rift_MenuBar_Border_PopupBox_Account}">

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                
                                                <TextBlock Style="{StaticResource Rift_MenuBar_Textblock_PopupBox_Account}" 
                                                           Text="Dynamo_s.r.o"/>

                                                <materialIcons:MaterialIcon Style="{StaticResource Rift_MenuBar_Icon_PopupBox_Account}" />
                                            </StackPanel>
                                        </Border>
                                    </materialDesign:PopupBox.ToggleContent>

                                    <ScrollViewer Style="{StaticResource Rift_MenuBar_ScrollViewer_PopupBox_Account}">

                                        <StackPanel>
                                            <Button Content="View my profile"
                                                    Command="{Binding ShowAccountCommand}"
                                                    Style="{StaticResource Rift_MenuBar_Items_PopupBox_Account}" />

                                            <Button Content="Change Account"
                                                    Command="{Binding SwitchAccountCommand}"
                                                    Style="{StaticResource Rift_MenuBar_Items_PopupBox_Account}" />

                                            <Button Content="Sign out of account..."
                                                    Command=""
                                                    Style="{StaticResource Rift_MenuBar_Items_PopupBox_Account}" />

                                            <Button  Content="Test GamePage"
                                                     Command=""
                                                     Style="{StaticResource Rift_MenuBar_Items_PopupBox_Account}" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </materialDesign:PopupBox>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Column="1">

                            <StackPanel Orientation="Horizontal">

                                <Button Style="{StaticResource Rift_MenuBar_WindowState_Button_Maxi_Min}"
                                        Command="{Binding WindowState.MinimizeCommand}"
                                        WindowChrome.IsHitTestVisibleInChrome="True">

                                    <materialIcons:MaterialIcon Style="{StaticResource Rift_MenuBar_Icon_WindowState}"
                                                                Kind="Minimize"
                                                                Foreground="{Binding Foreground,RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Button>

                                <Button Style="{StaticResource Rift_MenuBar_WindowState_Button_Maxi_Min}"
                                        Command="{Binding WindowState.MaximizeCommand}"
                                        WindowChrome.IsHitTestVisibleInChrome="True">

                                    <materialIcons:MaterialIcon Style="{StaticResource Rift_MenuBar_Icon_WindowState}"
                                                                Kind="WindowMaximize"
                                                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Button>

                                <Button Style="{StaticResource Rift_MenuBar_WindowState_Button_Close}"
                                        Command="{Binding WindowState.CloseCommand}"
                                        WindowChrome.IsHitTestVisibleInChrome="True">

                                    <materialIcons:MaterialIcon Style="{StaticResource Rift_MenuBar_Icon_WindowState}"
                                                                Kind="Close"
                                                                Foreground="{Binding Foreground,RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>