<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">

    <!--  MenuBar  -->
    <!--  Main boder  -->
    <Style x:Key="Rift_Menubar_MainBorder" TargetType="Border">

        <Setter Property="Background" Value="#171D25" />
        <Setter Property="CornerRadius" Value="6.1,6.1,0,0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                <Setter Property="Padding" Value="4,7,5,0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--  Button Logo/Title  -->
    <Style x:Key="Rift_MenuBar_LogoHeader" TargetType="Button">

        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <StackPanel Orientation="Horizontal">

                        <Image
                            x:Name="Logo"
                            Width="30"
                            Height="30"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="/Image/Rift_logo.png"
                            Stretch="UniformToFill">

                            <Image.Clip>
                                <EllipseGeometry
                                    Center="15,15"
                                    RadiusX="15"
                                    RadiusY="15" />
                            </Image.Clip>
                        </Image>

                        <TextBlock
                            x:Name="Title"
                            VerticalAlignment="Center"
                            FontFamily="Arial"
                            FontSize="14"
                            Foreground="#ABB0BA"
                            Text="RIFT" />
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="Logo" Property="Opacity" Value="0.8" />
                            <Setter TargetName="Title" Property="Foreground" Value="White" />
                            <Setter TargetName="Title" Property="Opacity" Value="0.7" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Popupbox View/Games/Help  -->
    <Style x:Key="Rift_Menubar_PopupBox_Tools" TargetType="materialDesign:PopupBox">

        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="materialDesign:RippleAssist.IsDisabled" Value="True" />
        <Setter Property="PopupVerticalOffset" Value="0" />
        <Setter Property="PopupHorizontalOffset" Value="2" />
        <Style.Resources>
            <Style TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Cursor" Value="Hand" />

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border
                                Padding="4,2"
                                Background="Transparent"
                                BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>
    </Style>

    <!--  Textblock in PopupBox_Tools  -->
    <Style x:Key="Rift_Menubar_Textblock_PopupBox_Tools" TargetType="TextBlock">

        <Setter Property="Foreground" Value="#8B929A" />
        <Setter Property="FontSize" Value="13.2" />
        <Setter Property="FontFamily" Value="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />

        <Style.Triggers />
    </Style>

    <!--  StackPanel in PopupBox  /both  -->
    <Style x:Key="Rift_MenuBar_StackPanel_PopupBox_Tools_Options_Notifications" TargetType="StackPanel">

        <Setter Property="Background" Value="#3D4450" />
    </Style>

    <!--  Items in PopupBox_Tools/  -->
    <Style x:Key="Rift_MenuBar_Items_PopupBox_Tools_Options" TargetType="Button">

        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Arial" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderThickness="0">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#4A5160" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#555C6A" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  PopupBox Store/Library/Nickname  -->
    <Style x:Key="Rift_MenuBar_PopupBox_Options" TargetType="materialDesign:PopupBox">

        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="materialDesign:RippleAssist.IsDisabled" Value="True" />
        <Setter Property="PopupMode" Value="Click" />
        <Setter Property="StaysOpen" Value="True" />
        <Setter Property="PopupAnimation" Value="None" />
        <Setter Property="PopupVerticalOffset" Value="-5" />
        <Setter Property="PopupHorizontalOffset" Value="4" />

        <Style.Resources>
            <Style TargetType="ToggleButton">

                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />

                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Background" Value="Transparent" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Style.Resources>
    </Style>

    <!--  Textblock in PopupBox_Options  -->
    <Style x:Key="Rift_MenuBar_Textblock_PopupBox_Options" TargetType="TextBlock">

        <Setter Property="Foreground" Value="#C4C7CC" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontFamily" Value="Arial" />
        <Setter Property="FontWeight" Value="SemiBold" />

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                <Setter Property="Foreground" Value="White" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--  PopupBox for Notifications  -->
    <Style x:Key="Rift_MenuBar_PopupBox_Notifications" TargetType="materialDesign:PopupBox">

        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="6,0,0,6" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Background" Value="#272A33" />
        <Setter Property="materialDesign:RippleAssist.IsDisabled" Value="True" />
        <Setter Property="PopupAnimation" Value="None" />
        <Setter Property="StaysOpen" Value="False" />
        <Setter Property="PopupMode" Value="MouseOverEager" />
        <Setter Property="PopupVerticalOffset" Value="6" />
        <Setter Property="PopupHorizontalOffset" Value="-23" />
        <Setter Property="Height" Value="23" />

        <Style.Resources>
            <Style TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2A2F38" />

                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Background" Value="#2A2F38" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Style.Resources>
    </Style>

    <!--  Textblock in PopupBox_Notifications  -->
    <Style x:Key="Rift_MenuBar_Icon_PopupBox_Notifications" TargetType="materialIcons:MaterialIcon">

        <Setter Property="Kind" Value="Bell" />
        <Setter Property="Margin" Value="14,0,13,0" />
        <Setter Property="Foreground" Value="#959AA3" />
        <Setter Property="Width" Value="15" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Height" Value="15" />
        <Setter Property="FontFamily" Value="Arial" />
        <Setter Property="FontWeight" Value="SemiBold" />

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}" Value="True">
                <Setter Property="Foreground" Value="#C7C9D1" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--  Items in PopupBox_Notifications  -->
    <Style x:Key="Rift_MenuBar_Items_PopupBox_Notifications" TargetType="Button">

        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="#2E2E2E" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="FontFamily" Value="Arial" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Opacity="0.7" Color="White" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--  PopupBox Account  -->
    <Style x:Key="Rift_MenuBar_PopupBox_Account" TargetType="materialDesign:PopupBox">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="12,0,50,0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="90" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="materialDesign:RippleAssist.IsDisabled" Value="True" />
        <Setter Property="PlacementMode" Value="BottomAndAlignLeftEdges" />
        <Setter Property="StaysOpen" Value="False" />
        <Setter Property="PopupAnimation" Value="Slide" />
        <Setter Property="PopupVerticalOffset" Value="3" />
        <Setter Property="PopupHorizontalOffset" Value="1" />
    </Style>

    <!--  Border in PopupBox_Account  -->
    <Style x:Key="Rift_MenuBar_Border_PopupBox_Account" TargetType="Border">

        <Setter Property="Background" Value="#272A33" />
        <Setter Property="MinWidth" Value="90" />
        <Setter Property="Height" Value="23" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#263442" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Textblock in PopupBox_Account  -->
    <Style x:Key="Rift_MenuBar_Textblock_PopupBox_Account" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#46B0FF" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="5,1,0,0" />
        <Setter Property="FontFamily" Value="Arial" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <!--  Icon in PopupBox_Account  -->
    <Style x:Key="Rift_MenuBar_Icon_PopupBox_Account" TargetType="materialIcons:MaterialIcon">

        <Setter Property="Kind" Value="ChevronDown" />
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Margin" Value="2,2,0,0" />
        <Setter Property="Foreground" Value="#46B0FF" />
    </Style>

    <!--  StackPanel in PopupBox_Account  -->
    <Style x:Key="Rift_MenuBar_StackPanel_PopupBox_Account" TargetType="StackPanel">

        <Setter Property="Background" Value="#3D4450" />
        <Setter Property="Orientation" Value="Vertical" />
    </Style>

    <!--  Separator in PopupBox_Account  -->
    <Style x:Key="Rift_MenuBar_Separator_PopupBox_Account" TargetType="Separator">
        <Setter Property="Background" Value="#4A5160" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

    <!--  Items (Buttons) in PopupBox_Account  -->
    <Style x:Key="Rift_MenuBar_Items_PopupBox_Account" TargetType="Button">

        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Arial" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderThickness="0">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#4A5160" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#555C6A" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Window State Icons  -->
    <Style x:Key="Rift_MenuBar_Icon_WindowState" TargetType="materialIcons:MaterialIcon">

        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="#FF818181" />
    </Style>

    <Style x:Key="Rift_MenuBar_WindowState_Button_Maxi_Min" TargetType="Button">

        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Foreground" Value="#FF818181" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#33FFFFFF" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#55FFFFFF" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Close button  -->
    <Style x:Key="Rift_MenuBar_WindowState_Button_Close" TargetType="Button">

        <Setter Property="Foreground" Value="#FF818181" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Width" Value="33" />
        <Setter Property="Height" Value="30" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="0,7.5,0,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{Binding Path=(materialDesign:ButtonAssist.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E22A27" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="DarkRed" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  SearchBar  -->



    <!--  Fix from here  -->
    <Style
        x:Key="Rift_Button3"
        BasedOn="{StaticResource MaterialDesignFlatButton}"
        TargetType="Button">
        <Setter Property="Height" Value="25" />
        <Setter Property="Width" Value="25" />
        <Setter Property="Background" Value="#262C36" />
        <Setter Property="Margin" Value="5,0,0,0" />

    </Style>

    <!--  Steam-like Search Bar  -->
    <Style
        x:Key="RiftSearchBar"
        BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
        TargetType="TextBox">


        <Setter Property="MinWidth" Value="235" />
        <Setter Property="MaxWidth" Value="235" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Margin" Value="6,0,0,0" />
        <Setter Property="Padding" Value="5,0,0,0" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0.5" />

        <Setter Property="materialDesign:HintAssist.Hint" Value="Search the Store" />
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="False" />
    </Style>


    <Style x:Key="Rift_CLear_Button" TargetType="Button">

        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <materialDesign:PackIcon
                        x:Name="Icon"
                        Width="26"
                        Height="26"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="#4B4F55"
                        Kind="Close" />

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Icon" Property="Width" Value="28" />
                            <Setter TargetName="Icon" Property="Height" Value="28" />
                            <Setter TargetName="Icon" Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Scrollviewers  -->

    <!--  LibraryGamePage  -->
    <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">

        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">

                    <Border
                        x:Name="ThumbBorder"
                        Width="8"
                        Height="70"
                        Margin="1,-35"
                        VerticalAlignment="Center"
                        Background="#FF5A6068"
                        CornerRadius="3" />

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#FF7A8088" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#FF7A8088" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarPageButtonStyle" TargetType="RepeatButton">

        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimScrollBarStyle" TargetType="ScrollBar">

        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Margin="0,35">

                        <Border
                            Width="10"
                            Margin="0,-35"
                            Background="#FF3A3E44"
                            CornerRadius="3"
                            Opacity="0.2" />

                        <Track x:Name="PART_Track" IsDirectionReversed="True">

                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource ScrollBarPageButtonStyle}" />
                            </Track.DecreaseRepeatButton>

                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                            </Track.Thumb>

                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource ScrollBarPageButtonStyle}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>

                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimScrollViewerStyle" TargetType="ScrollViewer">

        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">

                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                        </Grid.ColumnDefinitions>

                        <ScrollContentPresenter
                            Grid.Column="0"
                            Margin="0"
                            CanContentScroll="{TemplateBinding CanContentScroll}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}" />

                        <ScrollBar
                            x:Name="PART_VerticalScrollBar"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            Maximum="{TemplateBinding ScrollableHeight}"
                            Style="{StaticResource SlimScrollBarStyle}"
                            ViewportSize="0"
                            Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                            Value="{TemplateBinding VerticalOffset}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  LibraryGames  -->
    <Style x:Key="ScrollBarThumbStyle2" TargetType="Thumb">

        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">

                    <Border
                        x:Name="ThumbBorder"
                        Width="8"
                        Height="80"
                        Margin="1,-40"
                        VerticalAlignment="Center"
                        Background="#FF5A6068"
                        CornerRadius="3" />

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#FF7A8088" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#FF7A8088" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarPageButtonStyle2" TargetType="RepeatButton">

        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimScrollBarStyle2" TargetType="ScrollBar">

        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Margin="0,40">

                        <Border
                            Width="10"
                            Margin="0,-40"
                            CornerRadius="3" />

                        <Track x:Name="PART_Track" IsDirectionReversed="True">

                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource ScrollBarPageButtonStyle2}" />
                            </Track.DecreaseRepeatButton>

