<UserControl
    x:Class="Rift_App.TitleBars.SearchBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rift_App.TitleBars"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="#132333">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="990" />
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">

                <Button
                    Margin="18,0,0,0"
                    Padding="5,5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Command="{Binding RefreshCommand}"
                    Cursor="Hand"
                    Foreground="White"
                    ToolTip="{DynamicResource tooltip_refresh}">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="Root"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4">

                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#1A3A52" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#0F2A3D" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                    <StackPanel Orientation="Horizontal">

                        <materialIcons:MaterialIcon
                            Width="16"
                            Height="16"
                            Margin="0,1,0,0"
                            Foreground="#99C5DE"
                            Kind="Refresh" />

                        <TextBlock
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="#99C5DE"
                            Text="{DynamicResource seachbar_refresh}" />
                    </StackPanel>
                </Button>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">

                    <Border
                        Width="280"
                        Height="33"
                        Background="#22282F"
                        BorderBrush="#1B5680"
                        BorderThickness="1"
                        CornerRadius="4">

                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBox
                                    x:Name="SearchBox"
                                    Style="{StaticResource RiftSearchBar}"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource Rift_CLear_Button}"
                                    Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource StringToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid>

                <Popup
                    x:Name="SearchPopup"
                    AllowsTransparency="True"
                    IsOpen="{Binding ShowDropdown}"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=SearchBox}"
                    StaysOpen="False">

                    <Border Background="#313641">

                        <StackPanel Margin="0,5,0,15">

                            <TextBlock
                                Margin="12,8,12,4"
                                FontSize="13"
                                Foreground="#7A8A9A"
                                Text="{DynamicResource seachbar_searching}"
                                Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Results}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Button
                                            Height="Auto"
                                            MinWidth="400"
                                            Margin="10,8,10,0"
                                            Padding="0"
                                            HorizontalContentAlignment="Stretch"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Command="{Binding DataContext.SelectResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand">

                                            <Border Background="#464D5A">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0">

                                                        <Border
                                                            Width="155"
                                                            Height="70"
                                                            Margin="3"
                                                            Background="#969696"
                                                            ClipToBounds="True">

                                                            <Grid>

                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="12"
                                                                    Foreground="White"
                                                                    Text="{DynamicResource search_image_error}"
                                                                    Visibility="{Binding DisplayImageUrl, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Invert}" />

                                                                <Image
                                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                                    Source="{Binding Image.Bitmap}"
                                                                    Stretch="UniformToFill" />
                                                            </Grid>
                                                        </Border>
                                                    </Grid>

                                                    <Grid Grid.Column="1">

                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>

                                                        <Grid Grid.Row="0">

                                                            <TextBlock
                                                                Width="220"
                                                                Margin="8,14,8,0"
                                                                VerticalAlignment="Top"
                                                                FontSize="15"
                                                                Foreground="White"
                                                                Text="{Binding Name}"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </Grid>

                                                        <Grid Grid.Row="1">

                                                            <StackPanel
                                                                Margin="10,0,0,0"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Center"
                                                                Orientation="Horizontal">

                                                                <Border
                                                                    Padding="5,2,5,2"
                                                                    VerticalAlignment="Center"
                                                                    Background="#46593C"
                                                                    CornerRadius="3"
                                                                    Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">

                                                                    <TextBlock
                                                                        FontSize="14"
                                                                        FontWeight="Bold"
                                                                        Foreground="#BBE912"
                                                                        Text="{Binding DiscountDisplay}" />
                                                                </Border>

                                                                <StackPanel Orientation="Vertical">

                                                                    <TextBlock
                                                                        Margin="8,0,5,0"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="11.6"
                                                                        Foreground="#7A8A9A"
                                                                        Text="{Binding OriginalPrice}"
                                                                        TextDecorations="Strikethrough"
                                                                        Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                                    <TextBlock
                                                                        VerticalAlignment="Center"
                                                                        FontSize="14"
                                                                        FontWeight="SemiBold">

                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="{Binding PriceDisplay}" />
                                                                                <Setter Property="Foreground" Value="#E0F5FF" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                                                                        <Setter Property="Foreground" Value="#BBE912" />
                                                                                        <Setter Property="Margin" Value="6,0,0,0" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsFree}" Value="True">
                                                                                        <Setter Property="Foreground" Value="#57CBB7" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsComingSoon}" Value="True">
                                                                                        <Setter Property="Foreground" Value="#7A8A9A" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <Button
                Grid.Column="2"
                Width="Auto"
                Margin="10,0,0,0"
                Padding="0"
                HorizontalAlignment="Left"
                Background="Transparent"
                BorderBrush="Transparent"
                Command="{Binding ShowWishlistCommand}"
                Cursor="Hand"
                Foreground="White">

                <StackPanel Orientation="Horizontal">

                    <materialIcons:MaterialIcon
                        Width="17"
                        Height="17"
                        Margin="0,1.5,0,0"
                        Kind="Star" />

                    <TextBlock
                        Margin="5,0.1,0,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Text="{DynamicResource nav_wishlist}" />

                    <TextBlock
                        Margin="4,1,0,0"
                        VerticalAlignment="Bottom"
                        FontSize="13.1"
                        Text="{Binding WishlistCount}" />
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>