<UserControl
    x:Class="Rift_App.TitleBars.SearchBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rift_App.TitleBars"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="#132333">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="990" />
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">

                    <Border
                        Width="280"
                        Height="33"
                        Background="#22282F"
                        BorderBrush="#1B5680"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBox
                                    x:Name="SearchBox"
                                    Style="{StaticResource RiftSearchBar}"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource Rift_CLear_Button}"
                                    Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource StringToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid>

                <Popup
                    x:Name="SearchPopup"
                    IsOpen="{Binding ShowDropdown}"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=SearchBox}"
                    StaysOpen="True">

                    <Border
                        MinWidth="320"
                        Background="#1A2B3A"
                        BorderBrush="#2A4A5A"
                        BorderThickness="1.5">

                        <StackPanel>

                            <TextBlock
                                Margin="12,8,12,4"
                                FontSize="13"
                                Foreground="#7A8A9A"
                                Text="Searching..."
                                Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Results}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Button
                                            Margin="0,5,0,0"
                                            Padding="0"
                                            HorizontalContentAlignment="Stretch"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Command="{Binding DataContext.SelectResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand">

                                            <Border Padding="8,6" Background="Transparent">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#243545" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="60" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border
                                                        Grid.Column="0"
                                                        Width="56"
                                                        Height="26"
                                                        ClipToBounds="True"
                                                        CornerRadius="2">
                                                        <Image
                                                            RenderOptions.BitmapScalingMode="HighQuality"
                                                            Source="{Binding HeaderImageUrl}"
                                                            Stretch="UniformToFill" />
                                                    </Border>

                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="8,0,8,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Foreground="White"
                                                        Text="{Binding Name}"
                                                        TextTrimming="CharacterEllipsis" />

                                                    <StackPanel
                                                        Grid.Column="2"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Orientation="Vertical">

                                                        <Border
                                                            Padding="4,1"
                                                            HorizontalAlignment="Right"
                                                            Background="#4C6B22"
                                                            CornerRadius="2"
                                                            Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock
                                                                FontSize="11"
                                                                FontWeight="Bold"
                                                                Foreground="#A4D85A"
                                                                Text="{Binding DiscountDisplay}" />
                                                        </Border>

                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontSize="12"
                                                            Foreground="#C0BFC0"
                                                            Text="{Binding PriceDisplay}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFree}" Value="True">
                                                                            <Setter Property="Foreground" Value="#90EE90" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <Button
                Grid.Column="2"
                Width="105"
                Margin="10,0,0,0"
                Padding="0"
                HorizontalAlignment="Left"
                Background="Transparent"
                BorderBrush="Transparent"
                Command="{Binding ShowWishlistCommand}"
                Cursor="Hand"
                Foreground="White">

                <StackPanel Orientation="Horizontal">

                    <materialIcons:MaterialIcon
                        Width="17"
                        Height="17"
                        Margin="0,1.5,0,0"
                        Kind="Star" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Text="Wishlist" />

                    <TextBlock
                        Margin="5,5,0,0"
                        VerticalAlignment="Bottom"
                        FontSize="13"
                        Text="{Binding WishlistCount}" />
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>