<UserControl x:Class="Rift_App.TitleBars.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.TitleBars"
             mc:Ignorable="d">

    <Grid>
        <materialDesign:Card UniformCornerRadius="0"
                             Background="#132333"
                             Height="45"
                             materialDesign:ElevationAssist.Elevation="Dp12">
            <Grid>
                <!-- ĽAVÁ STRANA - Browse, Categories -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Margin="170,0,0,0">
                    <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox}">
                        <materialDesign:PopupBox.ToggleContent>
                            <TextBlock Text="Browse"
                                       VerticalAlignment="Center" />
                        </materialDesign:PopupBox.ToggleContent>
                        <ScrollViewer MaxHeight="200"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                <Button Content="Library"
                                        Style="{StaticResource Rift_PopupItems}" />
                                <Button Content="Games"
                                        Style="{StaticResource Rift_PopupItems}" />
                                <Button Content="Store"
                                        Style="{StaticResource Rift_PopupItems}" />
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:PopupBox>
                    <materialDesign:PopupBox Style="{StaticResource Rift_PopupBox}">
                        <materialDesign:PopupBox.ToggleContent>
                            <TextBlock Text="Categories"
                                       VerticalAlignment="Center" />
                        </materialDesign:PopupBox.ToggleContent>
                        <ScrollViewer MaxHeight="200"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Style="{StaticResource Rift_PopupStackPanel}">
                                <Button Content="Library"
                                        Style="{StaticResource Rift_PopupItems}" />
                                <Button Content="Games"
                                        Style="{StaticResource Rift_PopupItems}" />
                                <Button Content="Store"
                                        Style="{StaticResource Rift_PopupItems}" />
                            </StackPanel>
                        </ScrollViewer>
                    </materialDesign:PopupBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Width="312"
                            Margin="0,0,110,0">
                    <Grid>
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource RiftSearchBar}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:TextFieldAssist.TextFieldCornerRadius="2,0,0,2" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="147,5,1,5">
                            <Button Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource StringToVisibilityConverter}}"
                                    Style="{StaticResource Rift_CLear_Button}"
                                    Command="{Binding ClearCommand}" />
                        </StackPanel>
                    </Grid>
                    <Button Height="21.999"
                            Width="21.999"
                            materialDesign:ButtonAssist.CornerRadius="0">
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Height="15"
                                                 Width="15"
                                                 Foreground="White"
                                                 Margin="-12.8,0,0,0" />
                    </Button>
                    <Button Style="{x:Null}"
                            Margin="10,0,0,0"
                            Background="Transparent"
                            BorderBrush="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <materialIcons:MaterialIcon Kind="Star"
                                                        Width="11"
                                                        Height="11"
                                                        Foreground="White" />
                            <TextBlock Text="Wishlist"
                                       Margin="5,1.5,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       FontSize="10"
                                       FontFamily="Arial" />
                            <TextBlock Text="25"
                                       Margin="3,1.5,0,0"
                                       Foreground="White"
                                       FontSize="7"
                                       Width="Auto"
                                       Height="8" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
