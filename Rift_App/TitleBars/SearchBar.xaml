<UserControl
    x:Class="Rift_App.TitleBars.SearchBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rift_App.TitleBars"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="#132333">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="990" />
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">

                <Button HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="18,0,0,0"
                        Padding="5,5"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding RefreshCommand}"
                        Cursor="Hand"
                        Foreground="White"
                        ToolTip="Refresh library, wishlist and profile">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="Root"
                                                        Property="Background"
                                                        Value="#1A3A52" />
                                            </Trigger>
                                            <Trigger Property="IsPressed"
                                                     Value="True">
                                                <Setter TargetName="Root"
                                                        Property="Background"
                                                        Value="#0F2A3D" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsRefreshing}"
                                                         Value="True">
                                                <Setter Property="IsEnabled"
                                                        Value="False" />
                                                <Setter TargetName="Root"
                                                        Property="Opacity"
                                                        Value="0.5" />
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                    <StackPanel Orientation="Horizontal">
                        <materialIcons:MaterialIcon Kind="Refresh"
                                                    Width="16"
                                                    Height="16"
                                                    Margin="0,1,0,0"
                                                    Foreground="#99C5DE" />
                        <TextBlock Margin="5,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="#99C5DE"
                                   Text="Refresh" />
                    </StackPanel>
                </Button>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">

                    <Border
                        Width="280"
                        Height="33"
                        Background="#22282F"
                        BorderBrush="#1B5680"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBox
                                    x:Name="SearchBox"
                                    Style="{StaticResource RiftSearchBar}"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource Rift_CLear_Button}"
                                    Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource StringToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid>

                <Popup x:Name="SearchPopup"
                       IsOpen="{Binding ShowDropdown}"
                       PlacementTarget="{Binding ElementName=SearchBox}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">

                    <Border Background="#313641">

                        <StackPanel Margin="0,5,0,15">

                            <TextBlock
                                Margin="12,8,12,4"
                                FontSize="13"
                                Foreground="#7A8A9A"
                                Text="Searching..."
                                Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Results}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Button Padding="0"
                                                Margin="10,8,10,0"
                                                Height="Auto"
                                                MinWidth="400"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Command="{Binding DataContext.SelectResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand">

                                            <Border  Background="#464D5A">
                                                                                               
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0">
                                                        
                                                        <Border Width="155"
                                                                Margin="3"
                                                                Height="70"
                                                                ClipToBounds="True">

                                                            <Border.Background>
                                                                <ImageBrush ImageSource="{Binding HeaderImageUrl}"
                                                                            RenderOptions.BitmapScalingMode="HighQuality"
                                                                            Stretch="UniformToFill" />
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>

                                                    <Grid Grid.Column="1">

                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>

                                                        <Grid Grid.Row="0">

                                                            <TextBlock Margin="8,14,8,0"
                                                                       VerticalAlignment="Top"
                                                                       FontSize="15"
                                                                       Width="220"
                                                                       Foreground="White"
                                                                       Text="{Binding Name}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Grid>

                                                        <Grid Grid.Row="1">

                                                            <StackPanel HorizontalAlignment="Left"
                                                                        VerticalAlignment="Center"
                                                                        Margin="10,0,0,0"
                                                                        Orientation="Horizontal">

                                                                <Border Padding="5,2,5,2"
                                                                        Background="#46593C"
                                                                        CornerRadius="3"
                                                                        Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    
                                                                    <TextBlock FontSize="14"
                                                                               FontWeight="Bold"
                                                                               Foreground="#BBE912"
                                                                               Text="{Binding DiscountDisplay}" />
                                                                </Border>

                                                                <TextBlock HorizontalAlignment="Right"
                                                                           FontSize="13.5"
                                                                           VerticalAlignment="Center"
                                                                           Margin="5,0,0,0"
                                                                           Foreground="#E0F5FF"
                                                                           Text="{Binding PriceDisplay}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsFree}"
                                                                                             Value="True">
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <Button
                Grid.Column="2"
                Width="105"
                Margin="10,0,0,0"
                Padding="0"
                HorizontalAlignment="Left"
                Background="Transparent"
                BorderBrush="Transparent"
                Command="{Binding ShowWishlistCommand}"
                Cursor="Hand"
                Foreground="White">

                <StackPanel Orientation="Horizontal">

                    <materialIcons:MaterialIcon
                        Width="17"
                        Height="17"
                        Margin="0,1.5,0,0"
                        Kind="Star" />
                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Text="Wishlist" />

                    <TextBlock
                        Margin="5,0,0,0"
                        VerticalAlignment="Bottom"
                        FontSize="13"
                        Text="{Binding WishlistCount}" />
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>