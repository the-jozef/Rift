<UserControl x:Class="Rift_App.Account.Account"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Account"
             mc:Ignorable="d"
             d:DesignHeight="1000"
             d:DesignWidth="1600">
    
    <Grid>
        <Border CornerRadius="0,0,7.5,7.5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="#0E1921"
                                  Offset="0" />
                    <GradientStop Color="#131C28"
                                  Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="295" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="1">

                            <Border Background="#431432">
                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="660" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0"
                                              Margin="0,35,0,0">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0">

                                                <Border BorderBrush="#6DCFF6"
                                                        BorderThickness="2"
                                                        Margin="20,0,0,0"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top">

                                                    <Image Source="{Binding AvatarUrl}"
                                                           Width="168"
                                                           Height="168"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Column="1">

                                                <StackPanel VerticalAlignment="Top"
                                                            HorizontalAlignment="Left"
                                                            Margin="40,10,0,0"
                                                            Orientation="Vertical">

                                                    <TextBlock Text="{Binding Username}"
                                                               FontSize="28"
                                                               FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                               Foreground="White" />

                                                    <TextBlock Text="{Binding Email}"
                                                               FontSize="14"
                                                               Margin="2,5,0,0"
                                                               FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                               Foreground="#C0BFC0" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                        <Grid Grid.Row="1"
                                              Margin="10,28,0,0">

                                            <Border Background="#2E1026"
                                                    CornerRadius="5">
                                                
                                                <Grid>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0">
                                                        
                                                        <Border>
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0"
                                                                                     EndPoint="1,1">
                                                                    <GradientStop Color="#173841"
                                                                                  Offset="0" />
                                                                    <GradientStop Color="#38173B"
                                                                                  Offset="1" />
                                                                </LinearGradientBrush>
                                                            </Border.Background>

                                                            <Grid>

                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Grid Grid.Column="0"
                                                                      Margin="10,8,0,8">

                                                                    <TextBlock Text="Recent Activity"
                                                                               FontSize="17"
                                                                               HorizontalAlignment="Left"
                                                                               FontWeight="Regular"
                                                                               Foreground="White"/>
                                                                </Grid>

                                                                <Grid Grid.Column="1"
                                                                      Margin="0,8,5,8"
                                                                      HorizontalAlignment="Right">

                                                                    <TextBlock Text="0 hours past 2 weeks"
                                                                               FontSize="17"
                                                                               HorizontalAlignment="Right"
                                                                               FontWeight="Regular"
                                                                               Foreground="White" />
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>

                                                    <Grid Grid.Row="1"
                                                          Margin="15,0,15,0">

                                                        <StackPanel Orientation="Vertical">

                                                            <Border Background="#1B1B1B"
                                                                    CornerRadius="6"
                                                                    Margin="0,20,0,0">
                                                                
                                                                <Grid>

                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>

                                                                    <Grid Grid.Row="0"
                                                                          Margin="10,10,10,10">

                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <Grid Grid.Column="0">

                                                                            <StackPanel Orientation="Horizontal">

                                                                                <Border CornerRadius="2"
                                                                                        Width="180"
                                                                                        Height="65">
                                                                                    
                                                                                    <Border.Background>
                                                                                        <ImageBrush ImageSource="/Image/Red.png"
                                                                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                                                                    Stretch="UniformToFill" />
                                                                                    </Border.Background>

                                                                                </Border>

                                                                                <TextBlock Text="No Man's Sky"
                                                                                           FontSize="15"
                                                                                           Margin="10,10,0,0"
                                                                                           FontWeight="Regular"
                                                                                           Foreground="White" />
                                                                            </StackPanel>
                                                                        </Grid>

                                                                        <Grid Grid.Column="1">

                                                                            <StackPanel Orientation="Vertical"
                                                                                        HorizontalAlignment="Right"
                                                                                        VerticalAlignment="Bottom">

                                                                                <TextBlock Text="63 hrs on record"
                                                                                           HorizontalAlignment="Right"
                                                                                           FontSize="14"                                                                                          
                                                                                           FontWeight="Regular"
                                                                                           Foreground="#C0BFC0" />

                                                                                <TextBlock Text="last played on 3 May"
                                                                                           HorizontalAlignment="Right"
                                                                                           FontSize="14"                                                                                          
                                                                                           FontWeight="Regular"
                                                                                           Foreground="#C0BFC0" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Grid>

                                                                    <Grid Grid.Row="1"
                                                                          Margin="10,0,10,0">

                                                                        <Border Background="#2C0D22"
                                                                                Margin="2,0,0,10"
                                                                                CornerRadius="4">

                                                                            <Grid Margin="16">
                                                                                
                                                                                <StackPanel Orientation="Horizontal"
                                                                                            Margin="0,2,0,0">

                                                                                    <TextBlock Text="Achievement Progress"
                                                                                               FontSize="14"    
                                                                                               FontFamily="Arial"
                                                                                               Foreground="White"/>

                                                                                    <TextBlock Text="22 of 57"
                                                                                               FontSize="14"
                                                                                               Margin="12,0,0,0"
                                                                                               FontWeight="Regular"
                                                                                               Foreground="#B3B3B3" />

                                                                                    <ProgressBar HorizontalAlignment="Right"
                                                                                                 Width="150"
                                                                                                 Height="12"
                                                                                                 Margin="8,2,0,0"                                                                                              
                                                                                                 Maximum="27"
                                                                                                 Value="18">
                                                                                        <ProgressBar.Foreground>
                                                                                            <LinearGradientBrush StartPoint="0.5,0"
                                                                                                                 EndPoint="0.5,1">
                                                                                                <GradientStop Color="#604F5B"
                                                                                                              Offset="0.0" />
                                                                                                <GradientStop Color="#2E1F2D"
                                                                                                              Offset="0.844" />
                                                                                            </LinearGradientBrush> 
                                                                                        </ProgressBar.Foreground>
                                                                                        <ProgressBar.Style>
                                                                                            <Style TargetType="ProgressBar">
                                                                                                <Setter Property="Template">
                                                                                                    <Setter.Value>
                                                                                                        <ControlTemplate TargetType="ProgressBar">
                                                                                                            <Border Background="#12050E"
                                                                                                                    CornerRadius="6"
                                                                                                                    ClipToBounds="True">
                                                                                                                
                                                                                                                <Grid x:Name="PART_Track">
                                                                                                                    <Border x:Name="PART_Indicator"
                                                                                                                            Background="{TemplateBinding Foreground}"
                                                                                                                            CornerRadius="6"
                                                                                                                            Margin="0,1.5,0,1.5"
                                                                                                                            HorizontalAlignment="Left" />
                                                                                                                </Grid>
                                                                                                            </Border>
                                                                                                        </ControlTemplate>
                                                                                                    </Setter.Value>
                                                                                                </Setter>
                                                                                            </Style>
                                                                                        </ProgressBar.Style>
                                                                                    </ProgressBar>
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>
                                                                    </Grid>
                                                                </Grid>
                                                            </Border>

                                                            
                                                            
                                                            
                                                           
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>

                                    <Grid Grid.Column="2">

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="25" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">

                                            <StackPanel VerticalAlignment="Top"
                                                        HorizontalAlignment="Left"
                                                        Orientation="Horizontal"
                                                        Margin="0,35,0,0">
                                                
                                                <TextBlock Text="Level"
                                                           FontSize="28"
                                                           FontWeight="Thin"                                                       
                                                           Foreground="White" />

                                                <Viewbox Width="30"
                                                         Height="30"
                                                         Margin="8,10,0,0"
                                                         VerticalAlignment="Center">
                                                    
                                                    <Grid Width="30"
                                                          Height="30">

                                                        <Ellipse Stroke="#989798"
                                                                 StrokeThickness="2" />

                                                        <TextBlock HorizontalAlignment="Center"
                                                                   Text="{Binding Level}"
                                                                   FontSize="18"
                                                                   Margin="0,-2,0,0"
                                                                   Foreground="White"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Viewbox>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1"
                                              Margin="0,160,10,0">

                                            <Border CornerRadius="5"
                                                    Background="#2E1026">

                                                <Grid>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="70" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="60" />
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0">

                                                        <TextBlock Text="Currently Online"
                                                                   FontSize="21"
                                                                   HorizontalAlignment="Left"
                                                                   FontWeight="Thin"
                                                                   Foreground="#65C7DB"
                                                                   Margin="8,10,0,0" />
                                                    </Grid>

                                                    <Grid Grid.Row="2">
                                                        
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Top"
                                                                    Margin="10,0,0,0">

                                                            <Button Content="Games"
                                                                    FontSize="16"
                                                                    FontWeight="Regular"
                                                                    Foreground="White"
                                                                    Padding="0"
                                                                    Background="Transparent"
                                                                    BorderBrush="Transparent" />

                                                            <TextBlock Text="{Binding GamesOwnedCount}"
                                                                       FontSize="25"
                                                                       Margin="5,-3,0,0"   
                                                                       FontWeight="Thin"
                                                                       Foreground="#C0BFC0" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Grid.Row="3">

                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Top"
                                                                    Margin="10,8,0,0">

                                                            <Button Content="Wishlist"
                                                                    FontSize="16"
                                                                    FontWeight="Regular"
                                                                    Foreground="White"
                                                                    Padding="0"
                                                                    Background="Transparent"
                                                                    BorderBrush="Transparent" />

                                                            <TextBlock Text="{Binding GamesOwnedCount}"
                                                                       FontSize="25"
                                                                       Margin="5,-3,0,0"
                                                                       FontWeight="Thin"
                                                                       Foreground="#C0BFC0" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Grid.Row="4">

                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Top"
                                                                    Margin="10,8,0,0">

                                                            <Button Content="Change Account"
                                                                    FontSize="16"
                                                                    FontWeight="Regular"
                                                                    Foreground="White"
                                                                    Padding="0"
                                                                    Background="Transparent"
                                                                    BorderBrush="Transparent" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Grid.Row="5">

                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Top"
                                                                    Margin="10,8,0,0">

                                                            <Button Content="Do not press"
                                                                    FontSize="16"
                                                                    FontWeight="Regular"
                                                                    Foreground="White"
                                                                    Padding="0"
                                                                    Background="Transparent"
                                                                    BorderBrush="Transparent" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Grid.Row="6">

                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Top"
                                                                    Margin="10,8,0,0">

                                                            <Button Content="About Rift"
                                                                    FontSize="16"
                                                                    FontWeight="Regular"
                                                                    Foreground="White"
                                                                    Padding="0"
                                                                    Background="Transparent"
                                                                    BorderBrush="Transparent" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Grid.Row="7"
                                                          Margin="0,50,0,0">

                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Grid Grid.Row="0">

                                                            <StackPanel Orientation="Horizontal"
                                                                        Margin="10,0,0,0"
                                                                        HorizontalAlignment="Left">
                                                                
                                                            <TextBlock Text="Friends"
                                                                       FontSize="16"
                                                                       FontWeight="Regular"
                                                                       Foreground="White"/>

                                                                <TextBlock Text="{Binding GamesOwnedCount}"
                                                                           FontSize="25"
                                                                           Margin="5,-8,0,0"
                                                                           FontWeight="Thin"
                                                                           Foreground="#C0BFC0" />
                                                            </StackPanel>
                                                        </Grid>

                                                        <Grid Grid.Row="1"
                                                              Margin="10,0,0,0">

                                                            <StackPanel Orientation="Vertical">

                                                                <StackPanel Orientation="Horizontal"
                                                                            Margin="0,10,0,0">
                                                                    
                                                                    <Image Source="/Image/Red.png"
                                                                           Width="30"
                                                                           Height="30"                                                                          
                                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                                           Stretch="UniformToFill" />

                                                                    <StackPanel Orientation="Vertical"
                                                                                Margin="5,0,0,0"
                                                                                TextElement.Foreground="#ADACAD"
                                                                                TextElement.FontSize="12">
                                                                        
                                                                        <TextBlock Text="John Doe"/>
                                                                        
                                                                        <TextBlock Text="Last Online 2 Days ago"
                                                                                   Margin="2,0,0,0"/>
                                                                    </StackPanel>
                                                                </StackPanel>

                                                                <StackPanel Orientation="Horizontal"
                                                                            Margin="0,10,0,0">

                                                                    <Image Source="/Image/Red.png"
                                                                           Width="30"
                                                                           Height="30"
                                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                                           Stretch="UniformToFill" />

                                                                    <StackPanel Orientation="Vertical"
                                                                                Margin="5,0,0,0"
                                                                                TextElement.Foreground="#ADACAD"
                                                                                TextElement.FontSize="12">

                                                                        <TextBlock Text="Sano Hanuliak" />

                                                                        <TextBlock Text="Last Online 2 Days ago"
                                                                                   Margin="2,0,0,0" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>