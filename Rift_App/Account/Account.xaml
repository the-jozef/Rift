<UserControl x:Class="Rift_App.Account.Account"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Account"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <UserControl.Resources>

        <!-- Colors -->
        <SolidColorBrush x:Key="PageBg"
                         Color="#1B2838" />
        <SolidColorBrush x:Key="ProfileHeaderBg"
                         Color="#2E1A3A" />
        <SolidColorBrush x:Key="ContentBg"
                         Color="#32213F" />
        <SolidColorBrush x:Key="CardBg"
                         Color="#3D2650" />
        <SolidColorBrush x:Key="SidebarBg"
                         Color="#3D1F4E" />
        <SolidColorBrush x:Key="SidebarTop"
                         Color="#4A2060" />
        <SolidColorBrush x:Key="AvatarBorder"
                         Color="#4C8DB8" />
        <SolidColorBrush x:Key="OnlineColor"
                         Color="#57CBDE" />
        <SolidColorBrush x:Key="TextWhite"
                         Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextLight"
                         Color="#C6D4DF" />
        <SolidColorBrush x:Key="TextGray"
                         Color="#8F98A0" />
        <SolidColorBrush x:Key="TextDim"
                         Color="#6A7880" />
        <SolidColorBrush x:Key="EditBtnBg"
                         Color="#6B3F7A" />
        <SolidColorBrush x:Key="ProgressBg"
                         Color="#2A1A35" />
        <SolidColorBrush x:Key="ProgressFg"
                         Color="#4A6A80" />
        <SolidColorBrush x:Key="Divider"
                         Color="#4A2D5C" />
        <SolidColorBrush x:Key="GameRowBg"
                         Color="#2A1838" />
        <SolidColorBrush x:Key="AchRowBg"
                         Color="#231430" />

        <!-- ===== PROGRESS BAR TEMPLATE ===== -->
        <Style x:Key="SteamProgress"
               TargetType="ProgressBar">
            <Setter Property="Height"
                    Value="4" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="#2A1A35"
                                    CornerRadius="2" />
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        Background="#577A92"
                                        CornerRadius="2"
                                        HorizontalAlignment="Left" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== SIDEBAR LINK ===== -->
        <Style x:Key="SidebarLinkStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#8FB0C8" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="FontFamily"
                    Value="Arial" />
            <Setter Property="Margin"
                    Value="0,0,0,11" />
            <Setter Property="Cursor"
                    Value="Hand" />
        </Style>

        <!-- ===== EDIT PROFILE BUTTON ===== -->
        <Style x:Key="EditBtn"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#6B3F7A" />
            <Setter Property="Foreground"
                    Value="#C6D4DF" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="FontFamily"
                    Value="Arial" />
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="Padding"
                    Value="12,6" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#7D4D8F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#0E1921"
                              Offset="0" />
                <GradientStop Color="#131C28"
                              Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ===== NAV BAR ===== -->
            <Border Grid.Row="0"
                    Background="#000000"
                    Height="30"
                    Opacity="0.85" />

            <!-- ===== MAIN CONTENT ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="640" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ===== CENTER COLUMN ===== -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- PROFILE HEADER AREA -->
                        <Border Background="#32213F"
                                Padding="0,18,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar box -->
                                    <Border Grid.Column="0"
                                            Width="100"
                                            Height="100"
                                            BorderBrush="#4C8DB8"
                                            BorderThickness="2"
                                            Margin="0,0,16,0"
                                            CornerRadius="0">
                                        <Border>
                                            <Image Source="/Icons/Red.png"
                                                   Stretch="UniformToFill" />

                                        </Border>
                                    </Border>

                                    <!-- Name / alias -->
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Guest"
                                                       FontFamily="Arial"
                                                       FontSize="21"
                                                       FontWeight="Bold"
                                                       Foreground="#FFFFFF" />
                                            <TextBlock Text=" "
                                                       FontSize="13"
                                                       Foreground="#8F98A0"
                                                       VerticalAlignment="Center"
                                                       Margin="2,3,0,0" />
                                        </StackPanel>
                                        <TextBlock Text="Your name"
                                                   FontFamily="Arial"
                                                   FontSize="12"
                                                   Foreground="#8F98A0"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Grid>

                                <!-- RECENT ACTIVITY BAR -->
                                <Border Background="#2B1C37"
                                        Padding="0,8">
                                    <Grid Margin="0,0,0,0">
                                        <TextBlock Text="Recent Activity"
                                                   FontFamily="Arial"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#C6D4DF"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Text="0 hours past 2 weeks"
                                                   FontFamily="Arial"
                                                   FontSize="12"
                                                   Foreground="#8F98A0"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- GAME CARDS AREA -->
                        <Border Background="#2B1C37"
                                Padding="0,1,0,8">
                            <StackPanel>

                                <!-- ===== GAME 1: No Man's Sky ===== -->
                                <Border Margin="0,10,0,0"
                                        Background="#1E1228">
                                    <StackPanel>
                                        <Grid Height="70">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="184" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    ClipToBounds="True">
                                                <Border.Background>

                                                    <ImageBrush ImageSource="/Icons/Red.png"
                                                                Stretch="UniformToFill" />
                                                </Border.Background>
                                                <StackPanel VerticalAlignment="Bottom"
                                                            Margin="8,0,8,4">

                                                    <TextBlock Text=""
                                                               FontFamily="Arial"
                                                               FontSize="9"
                                                               FontWeight="Bold"
                                                               Foreground="#AADDEE" />
                                                </StackPanel>
                                            </Border>

                                            <Grid Grid.Column="1"
                                                  Margin="12,0,12,0">
                                                <StackPanel HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="???"
                                                               FontFamily="Arial"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="#C6D4DF" />
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="63 hrs on record"
                                                               FontFamily="Arial"
                                                               FontSize="12"
                                                               Foreground="#8F98A0"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="last played on 7 Apr"
                                                               FontFamily="Arial"
                                                               FontSize="11"
                                                               Foreground="#6A7880"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                        <Border Background="#1A0E24"
                                                Padding="12,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="Achievement Progress"
                                                           FontFamily="Arial"
                                                           FontSize="11"
                                                           Foreground="#8F98A0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="  18 of 27  "
                                                           FontFamily="Arial"
                                                           FontSize="11"
                                                           Foreground="#8F98A0"
                                                           VerticalAlignment="Center" />
                                                <ProgressBar Grid.Column="2"
                                                             Style="{StaticResource SteamProgress}"
                                                             Value="67"
                                                             VerticalAlignment="Center" />


                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ===== GAME 2: Wallpaper Engine ===== -->
                                <Border Margin="0,10,0,0"
                                        Background="#1E1228">
                                    <StackPanel>
                                        <Grid Height="70">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="184" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    ClipToBounds="True">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="/Icons/Red.png"
                                                                Stretch="UniformToFill" />
                                                </Border.Background>

                                            </Border>

                                            <Grid Grid.Column="1"
                                                  Margin="12,0,12,0">
                                                <TextBlock Text="???"
                                                           FontFamily="Arial"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="#C6D4DF"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center" />
                                                <StackPanel HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="0.3 hrs on record"
                                                               FontFamily="Arial"
                                                               FontSize="12"
                                                               Foreground="#8F98A0"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="last played on 24 Mar"
                                                               FontFamily="Arial"
                                                               FontSize="11"
                                                               Foreground="#6A7880"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                        <Border Background="#1A0E24"
                                                Padding="12,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="160" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Achievement Progress"
                                                           FontFamily="Arial"
                                                           FontSize="11"
                                                           Foreground="#8F98A0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="  0 of 17  "
                                                           FontFamily="Arial"
                                                           FontSize="11"
                                                           Foreground="#8F98A0"
                                                           VerticalAlignment="Center" />
                                                <ProgressBar Grid.Column="2"
                                                             Style="{StaticResource SteamProgress}"
                                                             Value="0"
                                                             VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ===== GAME 3: Assassin's Creed Unity ===== -->
                                <Border Margin="0,10,0,0"
                                        Background="#1E1228">
                                    <StackPanel>
                                        <Grid Height="70">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="184" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    ClipToBounds="True">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="/Icons/Red.png"
                                                                Stretch="UniformToFill" />
                                                </Border.Background>

                                            </Border>

                                            <Grid Grid.Column="1"
                                                  Margin="12,0,12,0">
                                                <TextBlock Text="???"
                                                           FontFamily="Arial"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Foreground="#C6D4DF"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center" />
                                                <StackPanel HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="29 hrs on record"
                                                               FontFamily="Arial"
                                                               FontSize="12"
                                                               Foreground="#8F98A0"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="last played on 21 Mar"
                                                               FontFamily="Arial"
                                                               FontSize="11"
                                                               Foreground="#6A7880"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                        <Border Background="#1A0E24"
                                                Padding="12,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="Achievement Progress"
                                                           FontFamily="Arial"
                                                           FontSize="11"
                                                           Foreground="#8F98A0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="  22 of 57  "
                                                           FontFamily="Arial"
                                                           FontSize="11"
                                                           Foreground="#8F98A0"
                                                           VerticalAlignment="Center" />
                                                <ProgressBar Grid.Column="2"
                                                             Style="{StaticResource SteamProgress}"
                                                             Value="39"
                                                             VerticalAlignment="Center" />


                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ===== RIGHT SIDEBAR ===== -->
                <Border Grid.Column="2">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="0,1">
                            <GradientStop Color="#4A1F60"
                                          Offset="0.0" />
                            <GradientStop Color="#3A1A50"
                                          Offset="0.3" />
                            <GradientStop Color="#2D1440"
                                          Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="#FF171212">
                        <StackPanel Margin="16,18,16,16">

                            <!-- LEVEL row -->
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Level"
                                               FontFamily="Arial"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#C6D4DF"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <Border Width="28"
                                            Height="28"
                                            BorderBrush="#8F98A0"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <TextBlock Text="?"
                                                   FontFamily="Arial"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#C6D4DF"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Badge hint text -->
                            <TextBlock FontFamily="Arial"
                                       FontSize="11"
                                       Foreground="#8F98A0"
                                       TextWrapping="Wrap"
                                       LineHeight="17"
                                       Margin="0,0,0,14">
                                <Run Text="You can feature one of your Badges here. Select one from your" />
                                
                                <Run Text="page." />
                            </TextBlock>




                            <!-- Divider -->
                            <Border Height="1"
                                    Background="DarkSlateGray"
                                    Margin="0,0,0,14" />

                            <!-- Currently Online -->
                            <TextBlock Text="Currently Online"
                                       FontFamily="Arial"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="#57CBDE"
                                       Margin="0,0,0,18" />

                            <!-- BADGES row -->
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Badges"
                                               FontFamily="Arial"
                                               FontSize="12"
                                               Foreground="#8F98A0"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="0"
                                               FontFamily="Arial"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#C6D4DF"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <!-- Badge icons -->
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,6,0,18">
                                <!-- Badge 1: 10+ years service -->
                                <Border Width="54"
                                        Height="54"
                                        CornerRadius="3"
                                        Margin="0,0,6,0">
                                    <Border.Background>
                                        <ImageBrush ImageSource="/Icons/Red.png"
                                                    Stretch="UniformToFill" />
                                    </Border.Background>

                                </Border>

                                <!-- Badge 2: Steam 2025 -->
                                <Border Width="54"
                                        Height="54"
                                        CornerRadius="3"
                                        Margin="0,0,6,0">
                                    <Border.Background>
                                        <ImageBrush ImageSource="/Icons/Red.png"
                                                    Stretch="UniformToFill" />
                                    </Border.Background>

                                </Border>

                                <!-- Badge 3: Level 2 square -->
                                <Border Width="54"
                                        Height="54"
                                        CornerRadius="3"
                                        BorderBrush="#6A6A6A"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <ImageBrush ImageSource="/Icons/Red.png"
                                                    Stretch="UniformToFill" />
                                    </Border.Background>

                                </Border>
                            </StackPanel>

                            <!-- Games count -->
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,18">
                                <TextBlock Text="Games"
                                           FontFamily="Arial"
                                           FontSize="12"
                                           Foreground="#8F98A0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="0"
                                           FontFamily="Arial"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#C6D4DF"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Divider -->
                            <Border Height="1"
                                    Background="#5A2D70"
                                    Margin="0,0,0,14" />

                            <!-- Sidebar links -->
                            <TextBlock Text="Inventory"
                                       Style="{StaticResource SidebarLinkStyle}" />
                            <TextBlock Text="Screenshots"
                                       Style="{StaticResource SidebarLinkStyle}" />
                            <TextBlock Text="Videos"
                                       Style="{StaticResource SidebarLinkStyle}" />
                            <TextBlock Text="Workshop Items"
                                       Style="{StaticResource SidebarLinkStyle}" />
                            <TextBlock Text="Reviews"
                                       Style="{StaticResource SidebarLinkStyle}" />
                            <TextBlock Text="Guides"
                                       Style="{StaticResource SidebarLinkStyle}" />
                            <TextBlock Text="Artwork"
                                       Style="{StaticResource SidebarLinkStyle}" />

                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>
    </Border>
</UserControl>
