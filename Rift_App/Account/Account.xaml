<UserControl x:Class="Rift_App.Account.Account"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Account"
             mc:Ignorable="d"
             d:DesignHeight="1000"
             d:DesignWidth="1600">

    <Grid>
        <Border CornerRadius="0,0,7.5,7.5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1">
                    <GradientStop Color="#0E1921"
                                  Offset="0" />
                    <GradientStop Color="#131C28"
                                  Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="295" />
                        </Grid.ColumnDefinitions>

                        <!-- ═══ CENTER COLUMN ═══ -->
                        <Grid Grid.Column="1">
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,1">
                                        <GradientStop Color="#431432"
                                                      Offset="0" />
                                        <GradientStop Color="#1C0A2A"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="660" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- ═══ LEFT PANEL ═══ -->
                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- Avatar + username -->
                                        <Grid Grid.Row="0"
                                              Margin="0,35,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    BorderBrush="#6DCFF6"
                                                    BorderThickness="2"
                                                    Margin="20,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top">
                                                <Image Source="{Binding AvatarUrl}"
                                                       Width="168"
                                                       Height="168"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Stretch="UniformToFill" />
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Top"
                                                        Margin="40,10,0,0"
                                                        Orientation="Vertical">
                                                <TextBlock Text="{Binding Username}"
                                                           FontSize="28"
                                                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                           Foreground="White" />

                                                <!-- Level badge -->
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,8,0,0">
                                                    <TextBlock Text="Steam Level"
                                                               FontSize="13"
                                                               Foreground="#C0BFC0"
                                                               VerticalAlignment="Center" />
                                                    <Border Background="#1A3A4A"
                                                            BorderBrush="#6DCFF6"
                                                            BorderThickness="1"
                                                            CornerRadius="12"
                                                            Margin="8,0,0,0"
                                                            Padding="10,2">
                                                        <TextBlock Text="{Binding Level}"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   Foreground="#6DCFF6" />
                                                    </Border>
                                                </StackPanel>

                                                <!-- Quick stats row -->
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,12,0,0">
                                                    <!-- Games -->
                                                    <Button Command="{Binding GoToLibraryCommand}"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            Padding="0"
                                                            Cursor="Hand">
                                                        <StackPanel Orientation="Vertical"
                                                                    Margin="0,0,20,0">
                                                            <TextBlock Text="{Binding GamesOwnedCount}"
                                                                       FontSize="22"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center" />
                                                            <TextBlock Text="Games"
                                                                       FontSize="12"
                                                                       Foreground="#C0BFC0"
                                                                       HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>

                                                    <!-- Separator -->
                                                    <Border Width="1"
                                                            Background="#3A2040"
                                                            Margin="0,2,20,2" />

                                                    <!-- Wishlist -->
                                                    <Button Command="{Binding GoToWishlistCommand}"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            Padding="0"
                                                            Cursor="Hand">
                                                        <StackPanel Orientation="Vertical"
                                                                    Margin="0,0,20,0">
                                                            <TextBlock Text="{Binding WishlistCount}"
                                                                       FontSize="22"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center" />
                                                            <TextBlock Text="Wishlist"
                                                                       FontSize="12"
                                                                       Foreground="#C0BFC0"
                                                                       HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>

                                                    <!-- Separator -->
                                                    <Border Width="1"
                                                            Background="#3A2040"
                                                            Margin="0,2,20,2" />

                                                    <!-- Friends -->
                                                    <StackPanel Orientation="Vertical">
                                                        <TextBlock Text="{Binding FriendsCount}"
                                                                   FontSize="22"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="Friends"
                                                                   FontSize="12"
                                                                   Foreground="#C0BFC0"
                                                                   HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Loading indicator -->
                                        <StackPanel Grid.Row="1"
                                                    Margin="20,16,0,0"
                                                    Orientation="Horizontal"
                                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Loading profile data..."
                                                       FontSize="13"
                                                       Foreground="#7A8A9A" />
                                        </StackPanel>

                                        <!-- Recent Achievements -->
                                        <Grid Grid.Row="2"
                                              Margin="10,24,10,0">
                                            <Border Background="#2E1026"
                                                    CornerRadius="5">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- Header -->
                                                    <Border Grid.Row="0"
                                                            CornerRadius="5,5,0,0">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0"
                                                                                 EndPoint="1,1">
                                                                <GradientStop Color="#173841"
                                                                              Offset="0" />
                                                                <GradientStop Color="#38173B"
                                                                              Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <TextBlock Text="Recent Achievements"
                                                                   FontSize="15"
                                                                   Foreground="White"
                                                                   Margin="12,8,0,8" />
                                                    </Border>

                                                    <!-- Achievement items -->
                                                    <ItemsControl Grid.Row="1"
                                                                  Margin="10,8,10,10"
                                                                  ItemsSource="{Binding RecentAchievements}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#1B1B1B"
                                                                        CornerRadius="4"
                                                                        Margin="0,0,0,6"
                                                                        Padding="10,8">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="44" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- Achievement icon -->
                                                                        <Border Grid.Column="0"
                                                                                Width="40"
                                                                                Height="40"
                                                                                CornerRadius="4"
                                                                                Background="#2C0D22">
                                                                            <Image Source="{Binding IconUrl}"
                                                                                   Width="36"
                                                                                   Height="36"
                                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                                   Stretch="UniformToFill" />
                                                                        </Border>

                                                                        <!-- Name + game -->
                                                                        <StackPanel Grid.Column="1"
                                                                                    Margin="10,0,0,0"
                                                                                    VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding AchievementName}"
                                                                                       FontSize="13"
                                                                                       Foreground="White"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                            <TextBlock Text="{Binding GameName}"
                                                                                       FontSize="11"
                                                                                       Foreground="#C0BFC0"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </StackPanel>

                                                                        <!-- Time -->
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding UnlockTimeDisplay}"
                                                                                   FontSize="11"
                                                                                   Foreground="#7A8A9A"
                                                                                   VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <!-- Menu buttons -->
                                        <Grid Grid.Row="3"
                                              Margin="10,16,10,20">
                                            <Border Background="#2E1026"
                                                    CornerRadius="5">
                                                <StackPanel Margin="12,10,12,10"
                                                            Orientation="Vertical">
                                                    <Button Command="{Binding GoToLibraryCommand}"
                                                            Content="Games"
                                                            FontSize="15"
                                                            Foreground="White"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            HorizontalAlignment="Left"
                                                            Padding="0,6" />
                                                    <Button Command="{Binding GoToWishlistCommand}"
                                                            Content="Wishlist"
                                                            FontSize="15"
                                                            Foreground="White"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            HorizontalAlignment="Left"
                                                            Padding="0,6" />
                                                    <Button Content="Change Account"
                                                            FontSize="15"
                                                            Foreground="White"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            HorizontalAlignment="Left"
                                                            Padding="0,6" />
                                                    <Button Content="About Rift"
                                                            FontSize="15"
                                                            Foreground="White"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            HorizontalAlignment="Left"
                                                            Padding="0,6" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>

                                    <!-- ═══ RIGHT PANEL — Friends ═══ -->
                                    <Grid Grid.Column="2"
                                          Margin="0,35,10,20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- Friends header -->
                                        <StackPanel Grid.Row="0"
                                                    Orientation="Horizontal"
                                                    Margin="4,0,0,10">
                                            <TextBlock Text="Friends"
                                                       FontSize="20"
                                                       FontWeight="Thin"
                                                       Foreground="White" />
                                            <Border Background="#1A3A4A"
                                                    BorderBrush="#6DCFF6"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Margin="8,4,0,4"
                                                    Padding="8,1">
                                                <TextBlock Text="{Binding FriendsCount}"
                                                           FontSize="13"
                                                           Foreground="#6DCFF6" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Private notice -->
                                        <Border Grid.Row="1"
                                                Background="#2E1026"
                                                CornerRadius="5"
                                                Padding="12"
                                                Visibility="{Binding FriendsPrivate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Text="⚠ Friends list is private"
                                                           FontSize="13"
                                                           Foreground="#F4C430"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,6,0,0"
                                                           FontSize="12"
                                                           Foreground="#C0BFC0"
                                                           TextWrapping="Wrap"
                                                           Text="To see your friends here, set your friends list to Public in Steam → Profile → Edit Profile → Privacy Settings." />
                                            </StackPanel>
                                        </Border>

                                        <!-- Friends list -->
                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Visibility="{Binding FriendsPrivate, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <ItemsControl ItemsSource="{Binding Friends}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#2E1026"
                                                                CornerRadius="5"
                                                                Margin="0,0,0,6"
                                                                Padding="8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="40" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Avatar -->
                                                                <Border Grid.Column="0"
                                                                        Width="36"
                                                                        Height="36"
                                                                        CornerRadius="18"
                                                                        ClipToBounds="True">
                                                                    <Image Source="{Binding AvatarUrl}"
                                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                                           Stretch="UniformToFill" />
                                                                </Border>

                                                                <!-- Name + game -->
                                                                <StackPanel Grid.Column="1"
                                                                            Margin="8,0,0,0"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Username}"
                                                                               FontSize="13"
                                                                               Foreground="White"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock FontSize="11"
                                                                               TextTrimming="CharacterEllipsis">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text"
                                                                                        Value="{Binding Status}" />
                                                                                <Setter Property="Foreground"
                                                                                        Value="#7A8A9A" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Status}"
                                                                                                 Value="In-Game">
                                                                                        <Setter Property="Foreground"
                                                                                                Value="#90EE90" />
                                                                                        <Setter Property="Text"
                                                                                                Value="{Binding CurrentGame}" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}"
                                                                                                 Value="Online">
                                                                                        <Setter Property="Foreground"
                                                                                                Value="#6DCFF6" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}"
                                                                                                 Value="Away">
                                                                                        <Setter Property="Foreground"
                                                                                                Value="#C0BFC0" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>

                                                                <!-- Status dot -->
                                                                <Ellipse Grid.Column="2"
                                                                         Width="8"
                                                                         Height="8"
                                                                         VerticalAlignment="Center">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill"
                                                                                    Value="#555555" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Status}"
                                                                                             Value="Online">
                                                                                    <Setter Property="Fill"
                                                                                            Value="#6DCFF6" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}"
                                                                                             Value="In-Game">
                                                                                    <Setter Property="Fill"
                                                                                            Value="#90EE90" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}"
                                                                                             Value="Away">
                                                                                    <Setter Property="Fill"
                                                                                            Value="#F4C430" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}"
                                                                                             Value="Busy">
                                                                                    <Setter Property="Fill"
                                                                                            Value="#E05252" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>