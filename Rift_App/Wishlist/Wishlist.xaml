<UserControl x:Class="Rift_App.Wishlist.Wishlist"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.Wishlist"
             mc:Ignorable="d"
             d:DesignHeight="1000"
             d:DesignWidth="800">

    <Grid>
        <Border CornerRadius="0,0,7.5,7.5">

            <Grid>
                <ScrollViewer Background="#1b2838"
                              VerticalScrollBarVisibility="Auto"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="1">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="60" />
                            </Grid.RowDefinitions>

                            <Grid Row="0"
                                  Margin="0,15,0,0">

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top">

                                    <Border BorderBrush="#6DCFF6"
                                            BorderThickness="1.5"
                                            Width="50"
                                            Height="50">

                                        <Image Source="/Image/Red.png"
                                               Stretch="UniformToFill" />
                                    </Border>

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="10,0,0,0">

                                        <TextBlock Text="{Binding WishlistTitle}"
                                                   Foreground="White"
                                                   FontFamily="Arial"
                                                   FontSize="20" />

                                        <TextBlock Foreground="#959BA6"
                                                   FontSize="10"
                                                   VerticalAlignment="Bottom"
                                                   FontFamily="Arial">
        <Run Text="{Binding TotalGames}" />
        <Run Text="items" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1"
                                  Margin="0,15,0,0">

                                <DockPanel>
                                    <Border BorderBrush="#45505E"
                                            BorderThickness="1"
                                            CornerRadius="0.5"/>

                                </DockPanel>
                            </Grid>

                            <Grid Grid.Row="2"
                                  Margin="0,5,0,0" >

                                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,40,0,0">
                                    <TextBlock Text="Loading wishlist..."
                                               Foreground="#959BA6"
                                               FontSize="13"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,40,0,0">
                                    <TextBlock Text="Your wishlist is empty."
                                               Foreground="#959BA6"
                                               FontSize="13"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Orientation="Vertical">

                                    <ItemsControl ItemsSource="{Binding Games}"
                                                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,10,0,0"
                                                        CornerRadius="4"
                                                        Padding="3">

                                                    <Border.Background>
                                                        <LinearGradientBrush>
                                                            <GradientStop Color="#33404D" />
                                                            <GradientStop Color="#374554"
                                                                          Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>

                                                    <Grid Margin="5">

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Grid Grid.Column="0">

                                                            <Button Background="Transparent"
                                                                    BorderBrush="Transparent"
                                                                    Padding="0"
                                                                    Command="{Binding DataContext.SelectGameCommand,RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}">

                                                                <Image Stretch="UniformToFill"
                                                                       Source="{Binding HeaderImage.Bitmap}"
                                                                       Height="95"
                                                                       Width="160" />
                                                            </Button>
                                                        </Grid>

                                                        <Grid Grid.Column="1"
                                                              Margin="10,0,0,0">

                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <Grid Row="0">
                                                                <Button Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        Padding="0"
                                                                        Command="{Binding DataContext.SelectGameCommand,RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}">

                                                                    <TextBlock Text="{Binding Name}"
                                                                               Foreground="White"
                                                                               FontSize="18"
                                                                               FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />
                                                                </Button>
                                                            </Grid>

                                                            <Grid Grid.Row="1"
                                                                  Margin="0,3,0,0">

                                                                <ItemsControl ItemsSource="{Binding DisplayTags}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <WrapPanel Orientation="Horizontal" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>

                                                                            <Border BorderBrush="#677785"
                                                                                    BorderThickness="0.5"
                                                                                    CornerRadius="1"
                                                                                    Padding="1"
                                                                                    Margin="0,0,2,0">

                                                                                <TextBlock Text="{Binding}"
                                                                                           FontSize="8"
                                                                                           Foreground="#788694" />
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Grid>

                                                            <Grid Grid.Row="2"
                                                                  Margin="0,10,0,0">

                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Grid Grid.Column="0">

                                                                    <StackPanel Orientation="Vertical"
                                                                                TextElement.FontSize="8"
                                                                                TextElement.Foreground="#959BA6">

                                                                        <TextBlock Text="OVERALL REVIEWS:" />

                                                                        <TextBlock Text="RELEASE DATE:"
                                                                                   Margin="0,2,0,0" />
                                                                    </StackPanel>
                                                                </Grid>

                                                                <Grid Grid.Column="1">

                                                                    <StackPanel Orientation="Vertical"
                                                                                TextElement.FontSize="8">

                                                                        <TextBlock Text="{Binding ReviewDesc}"
                                                                                   Foreground="{Binding ReviewBrush}" />

                                                                        <TextBlock Text="{Binding ReleaseDateDisplay}"
                                                                                   Foreground="#959BA6"
                                                                                   Margin="0,2,0,0" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Grid>

                                                            <Grid Grid.Row="3"
                                                                  Margin="0,2,0,0">

                                                                <StackPanel Orientation="Horizontal">

                                                                    <materialIcons:MaterialIcon Kind="Microsoft"
                                                                                                Foreground="#DBDBDB"
                                                                                                HorizontalAlignment="Left"
                                                                                                Height="15"
                                                                                                Width="15"
                                                                                                Visibility="{Binding PlatformWindows, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                                    <materialIcons:MaterialIcon Kind="Apple"
                                                                                                Foreground="#DBDBDB"
                                                                                                Height="14"
                                                                                                Width="14"
                                                                                                Margin="4,0,0,0"
                                                                                                Visibility="{Binding PlatformMac, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Grid>

                                                        <Grid Grid.Column="2"
                                                              MinWidth="180">

                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="*" />
                                                            </Grid.RowDefinitions>

                                                            <Grid Grid.Row="0">

                                                                <StackPanel Orientation="Horizontal"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Bottom">

                                                                    <TextBlock Text="{Binding DateAddedDisplay,
                                                                               StringFormat='Added on {0}'}"
                                                                               Foreground="#959BA6"
                                                                               FontSize="8"
                                                                               VerticalAlignment="Center"
                                                                               FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />


                                                                    <Border CornerRadius="1"
                                                                            Margin="5,0,0,0">

                                                                        <Border.Background>
                                                                            <SolidColorBrush Color="#586879"
                                                                                             Opacity="0.7" />
                                                                        </Border.Background>

                                                                        <Button Background="Transparent"
                                                                                BorderBrush="Transparent"
                                                                                Height="13"
                                                                                Width="40"
                                                                                Padding="0"
                                                                                Command="{Binding DataContext.RemoveGameCommand,RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}">

                                                                            <TextBlock Text="remove"
                                                                                       FontSize="8"
                                                                                       HorizontalAlignment="Center"
                                                                                       Foreground="#A9AFB6" />
                                                                        </Button>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Grid>

                                                            <Grid Grid.Row="1">

                                                                <StackPanel Orientation="Horizontal"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Bottom"
                                                                            Visibility="{Binding ShowAddToCart, Converter={StaticResource BooleanToVisibilityConverter}}">

                                                                    <Border Background="#27313B"
                                                                            CornerRadius="2"
                                                                            Height="30">

                                                                        <Grid>

                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <Border Grid.Column="0"
                                                                                    Padding="3"
                                                                                    Background="#4c6b22"
                                                                                    Margin="1.5"
                                                                                    CornerRadius="1"
                                                                                    Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">

                                                                                <TextBlock Text="{Binding DiscountDisplay}"
                                                                                           TextAlignment="Center"
                                                                                           FontSize="20"
                                                                                           Foreground="#a4d007"
                                                                                           FontWeight="Bold"
                                                                                           VerticalAlignment="Center" />
                                                                            </Border>

                                                                            <StackPanel Orientation="Vertical"
                                                                                        Grid.Column="1"
                                                                                        Margin="6,0,6,0">

                                                                                <TextBlock Text="{Binding OriginalPrice}"
                                                                                           FontSize="10"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="#91999E"
                                                                                           HorizontalAlignment="Right"
                                                                                           TextDecorations="Strikethrough"
                                                                                           VerticalAlignment="Center"
                                                                                           Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                                                <TextBlock Text="{Binding Price}"
                                                                                           FontSize="13"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="#D8E0E6"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center" />
                                                                            </StackPanel>

                                                                            <Border Grid.Column="2"
                                                                                    CornerRadius="1"
                                                                                    Margin="0,4,4,4">

                                                                                <Border.Background>
                                                                                    <LinearGradientBrush StartPoint="0,0"
                                                                                                         EndPoint="1,0">
                                                                                        <GradientStop Color="#46C734"
                                                                                                      Offset="0.251" />
                                                                                        <GradientStop Color="#3CB031"
                                                                                                      Offset="1" />
                                                                                    </LinearGradientBrush>
                                                                                </Border.Background>


                                                                                <Button Padding="6"
                                                                                        Background="Transparent"
                                                                                        BorderBrush="Transparent"
                                                                                        Height="23"
                                                                                        Command="{Binding DataContext.AddToCartCommand,RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                        CommandParameter="{Binding}">

                                                                                    <TextBlock Text="Add to Cart"
                                                                                               Foreground="#D1CFCF"
                                                                                               FontSize="12"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center" />
                                                                                </Button>
                                                                            </Border>
                                                                        </Grid>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>