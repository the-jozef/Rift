<Window x:Class="Rift_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:local="clr-namespace:Rift_App.TitleBars"
        xmlns:vm="clr-namespace:Rift_App.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="635"
        Width="1080"
        ResizeMode="{Binding WindowState.IsMaximized}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="7"
                            CaptionHeight="65"
                            CornerRadius="8"
                            GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Border CornerRadius="8"  
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1.5"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{Binding ShowSearchBar, 
                   Converter={StaticResource BoolToGridRowHeightConverter}}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <local:MenuBar HorizontalAlignment="Stretch"
                           Grid.Row="0" />

            <local:SearchBar Grid.Row="1"
                             Height="45"
                             HorizontalAlignment="Stretch"
                             Visibility="{Binding ShowSearchBar, 
                              Converter={StaticResource BooleanToVisibilityConverter}}" />

            <ContentControl Grid.Row="2"
                            Content="{Binding CurrentView}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />
        </Grid>
    </Border>
</Window>