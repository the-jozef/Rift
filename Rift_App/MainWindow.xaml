<Window
    x:Class="Rift_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rift_App.TitleBars"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:vm="clr-namespace:Rift_App.ViewModels"
    Title="MainWindow"
    MinWidth="1110"
    MinHeight="550"
    AllowsTransparency="False"
    Icon="/Image/Rift_icon.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="65"
            CornerRadius="18"
            GlassFrameThickness="0"
            ResizeBorderThickness="7" />
    </WindowChrome.WindowChrome>

    <Border
        BorderBrush="#373A3E"
        BorderThickness="2"
        ClipToBounds="True"
        CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{Binding ShowSearchBar, Converter={StaticResource BoolToGridRowHeightConverter}}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <local:MenuBar Grid.Row="0" HorizontalAlignment="Stretch" />

            <local:SearchBar
                Grid.Row="1"
                Height="50"
                HorizontalAlignment="Stretch"
                Visibility="{Binding ShowSearchBar, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <ContentControl
                Grid.Row="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Content="{Binding CurrentView}">

                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Margin" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                                <Setter Property="Margin" Value="0,0,5,0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
    </Border>
</Window>