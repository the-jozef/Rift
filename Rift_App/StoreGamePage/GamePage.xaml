<UserControl x:Class="Rift_App.StoreGamePage.GamePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.StoreGamePage"
             mc:Ignorable="d"
             d:Height="1800"
             d:Width="1500">

    <Grid>
        <Border Grid.Row="0"
                Background="#1A2636"
                CornerRadius="0,0,7.5,7.5">
            <ScrollViewer>
                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">

                        <Border Background="#FF293B53">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="165" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="1">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="35" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="1">

                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="1,0,0,12">

                                            <TextBlock Text="Crimson Desert"
                                                       FontFamily="Bold"
                                                       FontSize="30"
                                                       Foreground="#EBEBEB" />

                                        </StackPanel>
                                    </StackPanel>

                                    <Grid Grid.Row="2">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="810" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0">

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">

                                                <Image Source="/Image/Red.png"
                                                       Stretch="UniformToFill"
                                                       HorizontalAlignment="Stretch"
                                                       Height="460" />
                                            </Grid>

                                            <Grid Grid.Row="1">
                                                <Border HorizontalAlignment="Stretch"
                                                        ClipToBounds="True">

                                                    <ScrollViewer Style="{StaticResource SteamScrollViewerStyle}"
                                                                  HorizontalScrollBarVisibility="Auto"
                                                                  VerticalScrollBarVisibility="Disabled"
                                                                  x:Name="MediaScroll"
                                                                  PreviewMouseWheel="MediaScroll_PreviewMouseWheel">

                                                        <StackPanel Orientation="Horizontal"
                                                                    Margin="0,5,0,5">

                                                            <Image Source="/Image/Red.png"
                                                                   Stretch="UniformToFill"
                                                                   Width="110"
                                                                   Height="65" />
                                                            <Image Source="/Image/Red.png"
                                                                   Stretch="UniformToFill"
                                                                   Width="110"
                                                                   Height="65"
                                                                   Margin="4,0,0,0" />
                                                            <Image Source="/Image/Red.png"
                                                                   Stretch="UniformToFill"
                                                                   Width="110"
                                                                   Height="65"
                                                                   Margin="4,0,0,0" />
                                                            <Image Source="/Image/Red.png"
                                                                   Stretch="UniformToFill"
                                                                   Width="110"
                                                                   Height="65"
                                                                   Margin="4,0,0,0" />
                                                            <Image Source="/Image/Red.png"
                                                                   Stretch="UniformToFill"
                                                                   Width="110"
                                                                   Height="65"
                                                                   Margin="4,0,0,0" />
                                                            <Image Source="/Image/Red.png"
                                                                   Stretch="UniformToFill"
                                                                   Width="110"
                                                                   Height="65"
                                                                   Margin="4,0,0,0" />
                                                            <Image Source="/Image/Red.png"
                                                                   Stretch="UniformToFill"
                                                                   Width="110"
                                                                   Height="65"
                                                                   Margin="4,0,0,0" />
                                                            <Image Source="/Image/Red.png"
                                                                   Stretch="UniformToFill"
                                                                   Width="110"
                                                                   Height="65"
                                                                   Margin="4,0,0,0" />
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>
                                        </Grid>


                                        <Grid Grid.Column="1">

                                            <Border Background="#171D26"
                                                    BorderBrush="Transparent"
                                                    VerticalAlignment="Stretch">

                                                <Grid>

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="1">

                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>

                                                        <StackPanel Grid.Row="0">

                                                            <Image Source="/Image/Red.png"
                                                                   Stretch="UniformToFill"
                                                                   Width="370"
                                                                   Height="185" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1"
                                                                    Margin="0,18,0,0">

                                                            <TextBlock Text="Crimson Desert is an open-world action-adventure set on the continent of Pywel. Join Kliff on his journey to rebuild the Greymane faction and to save the land from a looming threat. From vast wilderness and cities to ruins and the mysterious Abyss, forge your path through battles and discovery."
                                                                       TextWrapping="WrapWithOverflow"
                                                                       FontSize="14.5"
                                                                       FontWeight="Medium"
                                                                       FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                       Foreground="#C8D4DB"
                                                                       Width="368"
                                                                       Height="Auto" />
                                                        </StackPanel>

                                                        <Grid Grid.Row="2">

                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="35" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <Grid Grid.Column="0">

                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <StackPanel Grid.Row="0">

                                                                    <TextBlock Text="ENGLISH REVIEWS:"
                                                                               FontSize="12"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                               Foreground="#91969E"
                                                                               Margin="0,25,0,0" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Row="1">

                                                                    <TextBlock Text="RELEASE DATE:"
                                                                               FontSize="12"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                               Foreground="#91969E"
                                                                               Margin="0,15,0,0" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Row="2"
                                                                            Orientation="Vertical"
                                                                            HorizontalAlignment="Left"
                                                                            Margin="0,20,0,0">

                                                                    <TextBlock Text="DEVELOPER:"
                                                                               FontSize="12"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                               Foreground="#91969E" />

                                                                    <TextBlock Text="PUBLISHER:"
                                                                               FontSize="12"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                               Foreground="#91969E"
                                                                               Margin="0,5,0,0" />
                                                                </StackPanel>
                                                            </Grid>

                                                            <Grid Grid.Column="2">

                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <StackPanel Grid.Row="0"
                                                                            Orientation="Horizontal"
                                                                            Margin="0,24,0,0">

                                                                    <TextBlock Text="Very Positive"
                                                                               FontSize="13.5"
                                                                               Foreground="#95D1F3"
                                                                               FontFamily="Arial" />


                                                                    <TextBlock Text="(47,125)"
                                                                               FontSize="13"
                                                                               Foreground="#959DA6"
                                                                               Margin="4,-1,0,0" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Row="1"
                                                                            Margin="0,13,0,0">

                                                                    <TextBlock Text="19 Mar, 2026"
                                                                               FontSize="13.5"
                                                                               FontFamily="Arial"
                                                                               Foreground="#959DA6" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Row="2"
                                                                            Orientation="Vertical"
                                                                            Margin="0,18,0,0">

                                                                    <TextBlock Text="Pearl Abyss"
                                                                               FontSize="13.5"
                                                                               Foreground="#95D1F3"
                                                                               FontFamily="Arial" />

                                                                    <TextBlock Text="Pearl Abyss"
                                                                               FontSize="13.5"
                                                                               Foreground="#95D1F3"
                                                                               FontFamily="Arial"
                                                                               Margin="0,5,0,0" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Grid>

                                                        <Grid Grid.Row="3">

                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="60" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Grid.Row="0"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalAlignment="Bottom">

                                                                <TextBlock Text="Popular user-defined tags for this product:"
                                                                           FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                           Foreground="#7D818A"
                                                                           FontSize="12.5" />
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal"
                                                                        Grid.Row="1"
                                                                        VerticalAlignment="Bottom"
                                                                        HorizontalAlignment="Left"
                                                                        Margin="0,4,0,0">

                                                                <StackPanel Orientation="Vertical"
                                                                            HorizontalAlignment="Left"
                                                                            Background="#2D4557"
                                                                            Margin="0,0,0,0"
                                                                            Height="Auto"
                                                                            Width="Auto">

                                                                    <TextBlock Text="FPS"
                                                                               FontSize="13"
                                                                               Width="Auto"
                                                                               Height="Auto"
                                                                               TextAlignment="Center"
                                                                               Foreground="#67C1F5"
                                                                               Margin="5,-1,5,1" />
                                                                </StackPanel>

                                                                <StackPanel Orientation="Vertical"
                                                                            HorizontalAlignment="Left"
                                                                            Background="#2D4557"
                                                                            Margin="2,0,0,0"
                                                                            Height="Auto"
                                                                            Width="Auto">

                                                                    <TextBlock Text="Realistic"
                                                                               FontSize="13"
                                                                               Width="Auto"
                                                                               Height="Auto"
                                                                               TextAlignment="Center"
                                                                               Foreground="#67C1F5"
                                                                               Margin="5,-1,5,1" />
                                                                </StackPanel>

                                                                <StackPanel Orientation="Vertical"
                                                                            HorizontalAlignment="Left"
                                                                            Background="#2D4557"
                                                                            Margin="2,0,0,0"
                                                                            Height="Auto"
                                                                            Width="Auto">

                                                                    <TextBlock Text="Gun Customization"
                                                                               FontSize="13"
                                                                               Width="Auto"
                                                                               Height="Auto"
                                                                               TextAlignment="Center"
                                                                               Foreground="#67C1F5"
                                                                               Margin="5,-1,5,1" />
                                                                </StackPanel>

                                                                <StackPanel Orientation="Vertical"
                                                                            HorizontalAlignment="Left"
                                                                            Background="#2D4557"
                                                                            Height="Auto"
                                                                            Margin="2,0,0,0"
                                                                            Width="Auto">

                                                                    <TextBlock Text="Tactical"
                                                                               FontSize="13"
                                                                               Width="Auto"
                                                                               Height="Auto"
                                                                               TextAlignment="Center"
                                                                               Foreground="#67C1F5"
                                                                               Margin="5,-1,5,1" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="165" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="1"
                                    Background="#213144"
                                    Padding="5">

                                <StackPanel Width="160"
                                            HorizontalAlignment="Left">

                                    <Button Background="#2A465D"
                                            BorderBrush="Transparent">

                                        <StackPanel HorizontalAlignment="Left"
                                                    Orientation="Horizontal"
                                                    Margin="-6,0,0,0">

                                            <materialIcons:MaterialIcon Kind="SquareOutline"
                                                                        Foreground="#4C92BF"
                                                                        Width="18"
                                                                        Height="18" />

                                            <TextBlock Text="Add to Wishlist"
                                                       Foreground="#457DA0"
                                                       FontSize="16"
                                                       Margin="5,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                            </Border>


                        </Grid>

                        <Grid Grid.Row="2">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="165" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="1">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="15" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <StackPanel>

                                        <TextBlock Text="CRIMSON DESERT EDITIONS"
                                                   FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                   FontSize="15"
                                                   FontWeight="Medium"
                                                   Foreground="White" />
                                        
                                        <Border Height="1"
                                                Background="White"
                                                VerticalAlignment="Bottom" />


                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1">

                                    <Border Background="Gray"
                                            Margin="0,5,0,0"
                                            CornerRadius="8">
                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">

                                                <TextBlock Text="Buy Crimson Desert"
                                                           FontSize="25"
                                                           Foreground="White"
                                                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />

                                            </StackPanel>

                                            <Grid Grid.Column="1">

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>


                                                <materialIcons:MaterialIcon Grid.Row="0"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            Kind="Microsoft"
                                                                            Foreground="White"
                                                                            Width="25"
                                                                            Height="25"
                                                                            Margin="0,5,5,5"/>

                                                <Grid Grid.Row="1">

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>


                                                    <Border Grid.Column="1"
                                                            Background="Black"
                                                            CornerRadius="5"
                                                            Height="30">

                                                        <Grid>

                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0"
                                                                       Text="69,99€"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>

                                                            <Border Grid.Column="1"
                                                                    Background="LightGreen"
                                                                    CornerRadius="5"
                                                                    Margin="0,2,2,2">

                                                                <TextBlock Text="To steam app"
                                                                           Foreground="White"
                                                                           FontSize="12"
                                                                           Margin="5,0,0,0" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="3">

                                    <Border Background="Gray"
                                            Margin="0,5,0,0"
                                            CornerRadius="8">
                                        
                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0">

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>


                                                <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Left">

                                                    <TextBlock Text="Buy Crimson Desert Deluxe Edition"
                                                               FontSize="15"
                                                               Foreground="White"
                                                               FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans" />

                                                    <TextBlock Text="Crimson Desert, Crimson Desert - Deluxe Pack"
                                                               FontSize="10"
                                                               Foreground="White"
                                                               FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans">
                                                        <Run Text="Includes 2 items: " Foreground="LightGreen" />
                                                    </TextBlock>

                                                   


                                                </StackPanel>
                                                
                                                
                                                
                                            </Grid>
                                            
                                           

                                            <Grid Grid.Column="1">

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>


                                                <materialIcons:MaterialIcon Grid.Row="0"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            Kind="Microsoft"
                                                                            Foreground="White"
                                                                            Width="25"
                                                                            Height="25"
                                                                            Margin="0,5,5,5" />

                                                <Grid Grid.Row="1">

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>


                                                    <Border Grid.Column="1"
                                                            Background="Black"
                                                            CornerRadius="5"
                                                            Height="30">

                                                        <Grid>

                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0"
                                                                       Text="69,99€"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />

                                                            <Border Grid.Column="1"
                                                                    Background="LightGreen"
                                                                    CornerRadius="5"
                                                                    Margin="0,2,2,2">

                                                                <TextBlock Text="To steam app"
                                                                           Foreground="White"
                                                                           FontSize="12"
                                                                           Margin="5,0,0,0" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>









                            </Grid>

                            <Grid Grid.Column="3">










                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
