<UserControl x:Class="Rift_App.StoreGamePage.GamePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:Rift_App.StoreGamePage"
             mc:Ignorable="d"
             d:Height="1500"
             d:Width="1500">

    <UserControl.Resources>
        <Style x:Key="SteamThumb"
               TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle"
                    Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#324155"
                                CornerRadius="2"
                                Height="14"
                                Margin="0,4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SteamScrollViewerStyle"
               TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Row="0" />

                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       Orientation="Horizontal"
                                       Height="22"
                                       Background="#171d24"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="{TemplateBinding Background}">
                                            <Track x:Name="PART_Track"
                                                   IsDirectionReversed="False">
                                                <Track.Thumb>
                                                    <Thumb Style="{StaticResource SteamThumb}" />
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Grid.Row="0"
                Background="#1A2636"
                CornerRadius="0,0,7.5,7.5">
            <ScrollViewer>
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">

                    <Border Background="#FF293B53">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="165" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="1">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="1">

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Bottom"
                                                Margin="1,0,0,12">

                                        <TextBlock Text="Crimson Desert"
                                                   FontFamily="Bold"                                                  
                                                   FontSize="30"
                                                   Foreground="#EBEBEB" />

                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Row="2">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">

                                            <Image Source="/Image/Red.png"
                                                   Stretch="UniformToFill"
                                                   Width="810"
                                                   Height="460" />
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <ScrollViewer Style="{StaticResource SteamScrollViewerStyle}"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Disabled">

                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,5,0,0">
                                                 
                                                    <Image Source="/Image/Red.png"
                                                           Stretch="UniformToFill"
                                                           Width="110"
                                                           Height="65" />

                                                    <Image Source="/Image/Red.png"
                                                           Stretch="UniformToFill"
                                                           Width="110"
                                                           Height="65" 
                                                           Margin="4,0,0,0"/>

                                                    <Image Source="/Image/Red.png"
                                                           Stretch="UniformToFill"
                                                           Width="110"
                                                           Height="65"
                                                           Margin="4,0,0,0" />


                                                    <Image Source="/Image/Red.png"
                                                           Stretch="UniformToFill"
                                                           Width="110"
                                                           Height="65"
                                                           Margin="4,0,0,0" />

                                                    <Image Source="/Image/Red.png"
                                                           Stretch="UniformToFill"
                                                           Width="110"
                                                           Height="65"
                                                           Margin="4,0,0,0" />


                                                    <Image Source="/Image/Red.png"
                                                           Stretch="UniformToFill"
                                                           Width="110"
                                                           Height="65"
                                                           Margin="4,0,0,0" />

                                                    <Image Source="/Image/Red.png"
                                                           Stretch="UniformToFill"
                                                           Width="110"
                                                           Height="65"
                                                           Margin="4,0,0,0" />
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>


                                    <Grid Grid.Column="1">

                                        <Border Background="#171D26"
                                                BorderBrush="Transparent">
                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="1">
                                                    
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0">

                                                        <Image Source="/Image/Red.png"
                                                               Stretch="UniformToFill"
                                                               Width="370"
                                                               Height="185" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="1"
                                                                Margin="0,15,0,0">

                                                        <TextBlock Text="Crimson Desert is an open-world action-adventure set on the continent of Pywel. Join Kliff on his journey to rebuild the Greymane faction and to save the land from a looming threat. From vast wilderness and cities to ruins and the mysterious Abyss, forge your path through battles and discovery."
                                                                   TextWrapping="WrapWithOverflow"
                                                                   FontSize="14.5"
                                                                   FontWeight="Medium"
                                                                   FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                   Foreground="#C8D4DB"
                                                                   Width="368" 
                                                                   Height="Auto"/>
                                                    </StackPanel>

                                                        <Grid Grid.Row="2">

                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="35" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <Grid Grid.Column="0">

                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <StackPanel Grid.Row="0">

                                                                    <TextBlock Text="ENGLISH REVIEWS:"
                                                                               FontSize="12"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                               Foreground="#91969E"
                                                                               Margin="0,25,0,0" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Row="1">

                                                                    <TextBlock Text="RELEASE DATE:"
                                                                               FontSize="12"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                               Foreground="#91969E"
                                                                               Margin="0,15,0,0" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Row="2"
                                                                            Orientation="Vertical"
                                                                            HorizontalAlignment="Left"
                                                                            Margin="0,20,0,0">

                                                                    <TextBlock Text="DEVELOPER:"
                                                                               FontSize="12"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                               Foreground="#91969E" />

                                                                    <TextBlock Text="PUBLISHER:"
                                                                               FontSize="12"
                                                                               FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                               Foreground="#91969E"
                                                                               Margin="0,5,0,0" />
                                                                </StackPanel>
                                                            </Grid>

                                                            <Grid Grid.Column="2">

                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <StackPanel Grid.Row="0"
                                                                            Orientation="Horizontal"
                                                                            Margin="0,24,0,0">

                                                                    <TextBlock Text="Very Positive"
                                                                               FontSize="13.5"
                                                                               Foreground="#95D1F3"
                                                                               FontFamily="Arial" />


                                                                    <TextBlock Text="(47,125)"
                                                                               FontSize="13"
                                                                               Foreground="#959DA6"
                                                                               Margin="4,-1,0,0" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Row="1"
                                                                            Margin="0,13,0,0">

                                                                    <TextBlock Text="19 Mar, 2026"
                                                                               FontSize="13.5"
                                                                               FontFamily="Arial"
                                                                               Foreground="#959DA6" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Row="2"
                                                                            Orientation="Vertical"
                                                                            Margin="0,18,0,0">

                                                                    <TextBlock Text="Pearl Abyss"
                                                                               FontSize="13.5"
                                                                               Foreground="#95D1F3"
                                                                               FontFamily="Arial" />

                                                                    <TextBlock Text="Pearl Abyss"
                                                                               FontSize="13.5"
                                                                               Foreground="#95D1F3"
                                                                               FontFamily="Arial"
                                                                               Margin="0,5,0,0" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Grid>

                                                        <Grid Grid.Row="3">

                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="70" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <StackPanel Grid.Row="0"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Bottom" >

                                                            <TextBlock Text="Popular user-defined tags for this product:"
                                                                           FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                           Foreground="#7D818A"
                                                                           FontSize="12.5" />
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal"
                                                                    Grid.Row="1"
                                                                    VerticalAlignment="Bottom"
                                                                    HorizontalAlignment="Left"
                                                                    Margin="0,4,0,0">

                                                            <StackPanel Orientation="Vertical"
                                                                        HorizontalAlignment="Left"
                                                                        Background="#2D4557"
                                                                        Margin="0,0,0,0"
                                                                        Height="Auto"
                                                                        Width="Auto">

                                                                <TextBlock Text="FPS"                                                               
                                                                           FontSize="13"
                                                                           Width="Auto"
                                                                           Height="Auto"
                                                                           TextAlignment="Center"
                                                                           Foreground="#67C1F5"
                                                                           Margin="5,-1,5,1" />
                                                            </StackPanel>

                                                            <StackPanel Orientation="Vertical"
                                                                        HorizontalAlignment="Left"
                                                                        Background="#2D4557" 
                                                                        Margin="2,0,0,0"
                                                                        Height="Auto"
                                                                        Width="Auto">

                                                                <TextBlock Text="Realistic"                                                                         
                                                                           FontSize="13"
                                                                           Width="Auto"
                                                                           Height="Auto"
                                                                           TextAlignment="Center"
                                                                           Foreground="#67C1F5"
                                                                           Margin="5,-1,5,1" />
                                                            </StackPanel>

                                                            <StackPanel Orientation="Vertical"
                                                                        HorizontalAlignment="Left"
                                                                        Background="#2D4557"    
                                                                        Margin="2,0,0,0"
                                                                        Height="Auto"
                                                                        Width="Auto">

                                                                <TextBlock Text="Gun Customization"                                                                         
                                                                           FontSize="13"
                                                                           Width="Auto"
                                                                           Height="Auto"
                                                                           TextAlignment="Center"
                                                                           Foreground="#67C1F5"
                                                                           Margin="5,-1,5,1" />
                                                            </StackPanel>

                                                            <StackPanel Orientation="Vertical"
                                                                        HorizontalAlignment="Left"
                                                                        Background="#2D4557"                                                                        
                                                                        Height="Auto"
                                                                        Margin="2,0,0,0"
                                                                        Width="Auto">

                                                                <TextBlock Text="Tactical"                                                                          
                                                                           FontSize="13"
                                                                           Width="Auto"
                                                                           Height="Auto"
                                                                           TextAlignment="Center"
                                                                           Foreground="#67C1F5"
                                                                           Margin="5,-1,5,1" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                    
                </Grid>
                
                
                
            </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
