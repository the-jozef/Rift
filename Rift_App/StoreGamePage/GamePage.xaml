<UserControl
    x:Class="Rift_App.StoreGamePage.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rift_App.StoreGamePage"
    xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Height="3000"
    d:Width="1500"
    mc:Ignorable="d">

    <Grid>
        <Border CornerRadius="0,0,7.5,7.5">

            <ScrollViewer
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                VerticalScrollBarVisibility="Auto">
                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="#1B2838">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="1">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="1,35,0,0">

                                <TextBlock
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    FontFamily="Bold"
                                    FontSize="30"
                                    Foreground="#EBEBEB"
                                    Text="Crimson Desert" />
                            </Grid>

                            <Grid
                                Grid.Row="1"
                                Height="560"
                                Margin="0,12,0,0"
                                Background="#1B2838">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">

                                        <Image
                                            Width="810"
                                            Height="460"
                                            HorizontalAlignment="Stretch"
                                            Source="/Image/Red.png"
                                            Stretch="UniformToFill" />
                                    </Grid>

                                    <Grid Grid.Row="1">

                                        <Border HorizontalAlignment="Stretch" ClipToBounds="True">

                                            <ScrollViewer
                                                x:Name="MediaScroll"
                                                Width="810"
                                                Margin="0,5,0,5"
                                                HorizontalScrollBarVisibility="Auto"
                                                Style="{StaticResource SteamScrollViewerStyle}"
                                                VerticalScrollBarVisibility="Disabled">

                                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">

                                                    <Image
                                                        Width="110"
                                                        Height="65"
                                                        Margin="4,0,0,0"
                                                        Source="/Image/Red.png"
                                                        Stretch="UniformToFill" />
                                                    <Image
                                                        Width="110"
                                                        Height="65"
                                                        Margin="4,0,0,0"
                                                        Source="/Image/Red.png"
                                                        Stretch="UniformToFill" />
                                                    <Image
                                                        Width="110"
                                                        Height="65"
                                                        Margin="4,0,0,0"
                                                        Source="/Image/Red.png"
                                                        Stretch="UniformToFill" />
                                                    <Image
                                                        Width="110"
                                                        Height="65"
                                                        Margin="4,0,0,0"
                                                        Source="/Image/Red.png"
                                                        Stretch="UniformToFill" />
                                                    <Image
                                                        Width="110"
                                                        Height="65"
                                                        Margin="4,0,0,0"
                                                        Source="/Image/Red.png"
                                                        Stretch="UniformToFill" />
                                                    <Image
                                                        Width="110"
                                                        Height="65"
                                                        Margin="4,0,0,0"
                                                        Source="/Image/Red.png"
                                                        Stretch="UniformToFill" />
                                                    <Image
                                                        Width="110"
                                                        Height="65"
                                                        Margin="4,0,0,0"
                                                        Source="/Image/Red.png"
                                                        Stretch="UniformToFill" />
                                                    <Image
                                                        Width="110"
                                                        Height="65"
                                                        Margin="4,0,0,0"
                                                        Source="/Image/Red.png"
                                                        Stretch="UniformToFill" />
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <Grid Grid.Column="1">

                                    <Border VerticalAlignment="Stretch" Background="#171D26">

                                        <Grid Margin="18,0,0,0">

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">

                                                <Image
                                                    Width="370"
                                                    Height="185"
                                                    Source="/Image/Red.png"
                                                    Stretch="UniformToFill" />
                                            </Grid>

                                            <Grid Grid.Row="1" Margin="0,18,0,0">

                                                <TextBlock
                                                    Width="368"
                                                    FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                    FontSize="14.5"
                                                    Foreground="#C8D4DB"
                                                    Text="Crimson Desert is an open-world action-adventure set on the continent of Pywel. Join Kliff on his journey to rebuild the Greymane faction and to save the land from a looming threat. From vast wilderness and cities to ruins and the mysterious Abyss, forge your path through battles and discovery."
                                                    TextWrapping="WrapWithOverflow" />
                                            </Grid>

                                            <Grid Grid.Row="2">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="35" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0">

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0" Margin="0,25,0,0">

                                                        <TextBlock
                                                            FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                            FontSize="12"
                                                            Foreground="#91969E"
                                                            Text="REVIEWS:" />
                                                    </Grid>

                                                    <Grid Grid.Row="1" Margin="0,15,0,0">

                                                        <TextBlock
                                                            FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                            FontSize="12"
                                                            Foreground="#91969E"
                                                            Text="RELEASE DATE:" />
                                                    </Grid>

                                                    <Grid Grid.Row="2" Margin="0,20,0,0">

                                                        <StackPanel Orientation="Vertical">

                                                            <TextBlock
                                                                FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                FontSize="12"
                                                                Foreground="#91969E"
                                                                Text="DEVELOPER:" />

                                                            <TextBlock
                                                                Margin="0,5,0,0"
                                                                FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                                FontSize="12"
                                                                Foreground="#91969E"
                                                                Text="PUBLISHER:" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>

                                                <Grid Grid.Column="2">

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0" Margin="0,25,0,0">

                                                        <StackPanel Orientation="Horizontal">

                                                            <TextBlock
                                                                FontFamily="Arial"
                                                                FontSize="13.5"
                                                                Foreground="#95D1F3"
                                                                Text="Very Positive" />


                                                            <TextBlock
                                                                Margin="4,-1,0,0"
                                                                FontSize="13"
                                                                Foreground="#959DA6"
                                                                Text="(47,125)" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Grid.Row="1" Margin="0,15,0,0">

                                                        <TextBlock
                                                            FontFamily="Arial"
                                                            FontSize="13.5"
                                                            Foreground="#959DA6"
                                                            Text="19 Mar, 2026" />
                                                    </Grid>

                                                    <Grid Grid.Row="2" Margin="0,20,0,0">

                                                        <StackPanel Orientation="Vertical">

                                                            <TextBlock
                                                                FontFamily="Arial"
                                                                FontSize="13.5"
                                                                Foreground="#95D1F3"
                                                                Text="Pearl Abyss" />

                                                            <TextBlock
                                                                Margin="0,5,0,0"
                                                                FontFamily="Arial"
                                                                FontSize="13.5"
                                                                Foreground="#95D1F3"
                                                                Text="Pearl Abyss" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Grid>

                                            <Grid Grid.Row="3">

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Margin="0,40,0,0">

                                                    <TextBlock
                                                        HorizontalAlignment="Left"
                                                        FontFamily="/Resources/Noto/NotoSans-Bold.ttf#Noto Sans"
                                                        FontSize="12.5"
                                                        Foreground="#7D818A"
                                                        Text="Popular user-defined tags for this product:" />
                                                </Grid>

                                                <Grid Grid.Row="1" Margin="0,4,0,0">

                                                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">

                                                        <Border
                                                            Margin="2,0,0,0"
                                                            Padding="4,0,4,0"
                                                            HorizontalAlignment="Left"
                                                            Background="#2D4557">

                                                            <TextBlock
                                                                FontSize="13"
                                                                Foreground="#67C1F5"
                                                                Text="FPS"
                                                                TextAlignment="Center" />
                                                        </Border>

                                                        <Border
                                                            Margin="2,0,0,0"
                                                            Padding="4,0,4,0"
                                                            HorizontalAlignment="Left"
                                                            Background="#2D4557">

                                                            <TextBlock
                                                                FontSize="13"
                                                                Foreground="#67C1F5"
                                                                Text="Realistic"
                                                                TextAlignment="Center" />
                                                        </Border>

                                                        <Border
                                                            Margin="2,0,0,0"
                                                            Padding="4,0,4,0"
                                                            HorizontalAlignment="Left"
                                                            Background="#2D4557">

                                                            <TextBlock
                                                                FontSize="13"
                                                                Foreground="#67C1F5"
                                                                Text="Gun Customization"
                                                                TextAlignment="Center" />
                                                        </Border>

                                                        <Border
                                                            Margin="2,0,0,0"
                                                            Padding="4,0,4,0"
                                                            HorizontalAlignment="Left"
                                                            Background="#2D4557">

                                                            <TextBlock
                                                                FontSize="13"
                                                                Foreground="#67C1F5"
                                                                Text="Tactical"
                                                                TextAlignment="Center" />
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1">

                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Offset="0.251" Color="#1E2E40" />
                                <GradientStop Offset="1" Color="#1E2E40" />
                            </LinearGradientBrush>
                        </Grid.Background>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,10,0,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="165" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="1">

                                <Button Background="#2F5069" BorderBrush="Transparent">

                                    <Button.Effect>
                                        <DropShadowEffect
                                            BlurRadius="70"
                                            Opacity="0.2"
                                            ShadowDepth="0"
                                            Color="White" />
                                    </Button.Effect>

                                    <StackPanel Margin="-4,0,0,0" Orientation="Horizontal">

                                        <materialIcons:MaterialIcon
                                            Width="18"
                                            Height="18"
                                            Foreground="#5AB3E8"
                                            Kind="SquareOutline" />

                                        <TextBlock
                                            Margin="5,0,0,0"
                                            FontSize="16"
                                            Foreground="#5AB3E8"
                                            Text="Add to Wishlist" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,50,0,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="165" />
                                <ColumnDefinition Width="740" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="136" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="1">

                                <StackPanel Orientation="Vertical">

                                    <Grid Margin="1,0,0,0">

                                        <TextBlock
                                            FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                            FontSize="16"
                                            Foreground="White"
                                            Text="CRIMSON DESERT EDITIONS" />

                                        <Border
                                            Height="1"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="1">

                                            <Border.Background>
                                                <LinearGradientBrush>
                                                    <GradientStop Offset="0" Color="#396B88" />
                                                    <GradientStop Offset="0.719" Color="#00397091" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">

                                        <Border CornerRadius="8">

                                            <Border.Background>
                                                <LinearGradientBrush>
                                                    <GradientStop Offset="0.424" Color="#2F4152" />
                                                    <GradientStop Offset="1" Color="#4D5D6E" />
                                                </LinearGradientBrush>
                                            </Border.Background>

                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel
                                                    Grid.Column="0"
                                                    Margin="15,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">

                                                    <TextBlock
                                                        FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                        FontSize="22"
                                                        Foreground="White"
                                                        Text="Buy Crimson Desert" />

                                                </StackPanel>

                                                <Grid Grid.Column="1">

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <materialIcons:MaterialIcon
                                                        Grid.Row="0"
                                                        Width="22"
                                                        Height="22"
                                                        Margin="0,8,20,5"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Foreground="White"
                                                        Kind="Microsoft" />

                                                    <Grid Grid.Row="1" Margin="0,5,20,-10">

                                                        <Border
                                                            Height="30"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Background="Black"
                                                            CornerRadius="2">

                                                            <Grid>

                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock
                                                                    Grid.Column="0"
                                                                    Margin="20,0,20,0"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="14"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="#D8E0E6"
                                                                    Text="69,99€" />

                                                                <Border
                                                                    Grid.Column="1"
                                                                    Width="Auto"
                                                                    Margin="0,3,3,3"
                                                                    Background="#6BA220"
                                                                    CornerRadius="2">

                                                                    <TextBlock
                                                                        Margin="5,5,5,5"
                                                                        Padding="6"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="12"
                                                                        Foreground="White"
                                                                        Text="Add to Cart" />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Grid Margin="0,25,0,0">

                                        <Border CornerRadius="8">

                                            <Border.Background>
                                                <LinearGradientBrush>
                                                    <GradientStop Offset="0.424" Color="#2F4152" />
                                                    <GradientStop Offset="1" Color="#4D5D6E" />
                                                </LinearGradientBrush>
                                            </Border.Background>

                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0">

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0" Margin="15,15,0,0">

                                                        <StackPanel HorizontalAlignment="Left" Orientation="Vertical">

                                                            <TextBlock
                                                                FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                                FontSize="22"
                                                                Foreground="White"
                                                                Text="Buy Crimson Desert Deluxe Edition" />

                                                            <TextBlock
                                                                Margin="2,0,0,0"
                                                                FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                                FontSize="12">

                                                                <Run Foreground="#92D43B" Text="Includes 2 items:" />
                                                                <Run Foreground="#BABABA" Text="Crimson Desert, Crimson Desert - Deluxe Pack" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Border
                                                        Grid.Row="1"
                                                        Margin="13,5,2,2"
                                                        Padding="3"
                                                        Background="#171E21"
                                                        CornerRadius="1">

                                                        <StackPanel Margin="7,0,0,0" Orientation="Horizontal">

                                                            <Image
                                                                Width="60"
                                                                Height="30"
                                                                Margin="0,2,2,2"
                                                                Source="/Image/Red.png"
                                                                Stretch="UniformToFill" />

                                                            <Image
                                                                Width="60"
                                                                Height="30"
                                                                Margin="0,2,2,2"
                                                                Source="/Image/Red.png"
                                                                Stretch="UniformToFill" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <Grid Grid.Column="1">

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>

                                                    <materialIcons:MaterialIcon
                                                        Grid.Row="0"
                                                        Width="22"
                                                        Height="22"
                                                        Margin="0,8,20,5"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Foreground="White"
                                                        Kind="Microsoft" />

                                                    <Grid Grid.Row="1">

                                                        <Border
                                                            Height="30"
                                                            Margin="0,5,20,-10"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Background="Black"
                                                            CornerRadius="2">

                                                            <Grid>

                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock
                                                                    Grid.Column="0"
                                                                    Margin="20,0,20,0"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="14"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="#D8E0E6"
                                                                    Text="79,99€" />

                                                                <Border
                                                                    Grid.Column="1"
                                                                    Margin="0,3,3,3"
                                                                    Background="#6BA220">

                                                                    <TextBlock
                                                                        Margin="5,5,5,5"
                                                                        Padding="6"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="12"
                                                                        Foreground="White"
                                                                        Text="Add to Cart" />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Grid Margin="1,20,0,0">

                                        <TextBlock
                                            FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                            FontSize="16"
                                            Foreground="White"
                                            Text="Content for this game" />

                                        <Border
                                            Height="1"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="1">

                                            <Border.Background>
                                                <LinearGradientBrush>
                                                    <GradientStop Offset="0" Color="#396B88" />

                                                    <GradientStop Offset="0.719" Color="#00397091" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">

                                        <Border CornerRadius="8">

                                            <Border.Background>
                                                <LinearGradientBrush>
                                                    <GradientStop Offset="0.424" Color="#2F4152" />
                                                    <GradientStop Offset="1" Color="#4D5D6E" />
                                                </LinearGradientBrush>
                                            </Border.Background>

                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0">

                                                    <Image
                                                        Width="150"
                                                        Height="70"
                                                        Margin="5"
                                                        Source="/Image/Red.png"
                                                        Stretch="UniformToFill" />
                                                </Grid>

                                                <Grid Grid.Column="1">

                                                    <StackPanel VerticalAlignment="Center" Orientation="Vertical">

                                                        <Border
                                                            HorizontalAlignment="Left"
                                                            Background="#4482A6"
                                                            CornerRadius="5">

                                                            <TextBlock
                                                                Margin="1,1,1,1"
                                                                FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                                FontSize="11"
                                                                Foreground="White"
                                                                Text="RECOMMENDED" />
                                                        </Border>

                                                        <TextBlock
                                                            HorizontalAlignment="Left"
                                                            FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                                            FontSize="10"
                                                            Foreground="#BABABA"
                                                            Text="Crimson Desert - Deluxe Pack" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom">

                                                    <Border
                                                        Height="30"
                                                        Margin="0,5,20,-10"
                                                        Background="Black"
                                                        CornerRadius="2">

                                                        <Grid>

                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock
                                                                Grid.Column="0"
                                                                Margin="20,0,20,0"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontSize="14"
                                                                FontWeight="SemiBold"
                                                                Foreground="#D8E0E6"
                                                                Text="12,99€" />

                                                            <Border
                                                                Grid.Column="1"
                                                                Margin="0,3,3,3"
                                                                Background="#6BA220"
                                                                CornerRadius="2">

                                                                <TextBlock
                                                                    Margin="5,5,5,5"
                                                                    Padding="6"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="12"
                                                                    Foreground="White"
                                                                    Text="Add to Cart" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Grid Margin="1,20,0,0">

                                        <TextBlock
                                            FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                            FontSize="16"
                                            Foreground="White"
                                            Text="Digital Deluxe edition" />

                                        <Border
                                            Height="1"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="1">

                                            <Border.Background>
                                                <LinearGradientBrush>
                                                    <GradientStop Offset="0" Color="#396B88" />

                                                    <GradientStop Offset="0.719" Color="#00397091" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">

                                        <Image
                                            Height="500"
                                            Source="/Image/Red.png"
                                            Stretch="UniformToFill" />
                                    </Grid>

