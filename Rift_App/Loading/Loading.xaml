<Window x:Class="Rift_App.Loading.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:local="clr-namespace:Rift_App.Loading"
        mc:Ignorable="d"
        Title="Loading"
        d:DesignHeight="435"
        d:DesignWidth="702"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent">
   
    <Window.Resources>

        <Storyboard x:Key="SpinBlue"
                    RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="BlueGroup"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0"
                             To="360"
                             Duration="0:0:1.2" />
        </Storyboard>

        <Storyboard x:Key="SpinGray"
                    RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="GrayGroup"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0"
                             To="360"
                             Duration="0:0:0.85" />
        </Storyboard>

        <Storyboard x:Key="FadeAnim"
                    RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SpinnerContainer"
                                           Storyboard.TargetProperty="Opacity"
                                           Duration="0:0:4.1">
                <LinearDoubleKeyFrame KeyTime="0:0:0.00"
                                      Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.20"
                                      Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.50"
                                      Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:5.20"
                                      Value="1" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinBlue}" />
            <BeginStoryboard Storyboard="{StaticResource SpinGray}" />
            <BeginStoryboard Storyboard="{StaticResource FadeAnim}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid>

        <MediaElement x:Name="BgVideo"
                      LoadedBehavior="Play"
                      UnloadedBehavior="Manual"
                      Source="Videos\Background_animation.mp4"
                      IsMuted="True"
                      Stretch="UniformToFill"
                      IsHitTestVisible="False" />

        <Border CornerRadius="7.5,7.5,0,0"
                Background="Gray"
                Opacity="0.15"
                Panel.ZIndex="1" />

        <Grid Panel.ZIndex="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="220" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">

                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Center">

                    <Grid Width="130"
                          Height="130">

                        <Grid x:Name="SpinnerContainer"
                              Width="130"
                              Height="130">

                            <Grid x:Name="BlueGroup"
                                  Width="130"
                                  Height="130"
                                  RenderTransformOrigin="0.5,0.5">

                                <Grid.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Grid.RenderTransform>

                                <Ellipse Width="130"
                                         Height="130"
                                         StrokeThickness="4"
                                         StrokeDashArray="51 51"
                                         StrokeDashOffset="0"
                                         StrokeStartLineCap="Round"
                                         StrokeEndLineCap="Round"
                                         StrokeDashCap="Round">

                                    <Ellipse.Stroke>
                                        <SolidColorBrush Color="#66CCFF" />
                                    </Ellipse.Stroke>
                                </Ellipse>
                            </Grid>

                            <Grid x:Name="GrayGroup"
                                  Width="130"
                                  Height="130"
                                  RenderTransformOrigin="0.5,0.5">

                                <Grid.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Grid.RenderTransform>

                                <Ellipse Width="130"
                                         Height="130"
                                         StrokeThickness="3"
                                         StrokeDashArray="45 150"
                                         StrokeDashOffset="0"
                                         StrokeStartLineCap="Round"
                                         StrokeEndLineCap="Round"
                                         StrokeDashCap="Round">

                                    <Ellipse.Stroke>
                                        <SolidColorBrush Color="#BBBBBB"
                                                         Opacity="0.5" />
                                    </Ellipse.Stroke>
                                </Ellipse>
                            </Grid>

                        </Grid>

                        <Ellipse Width="105"
                                 Height="105"
                                 StrokeThickness="1.5">

                            <Ellipse.Stroke>
                                <SolidColorBrush Color="#83289C"
                                                 Opacity="0.35" />
                            </Ellipse.Stroke>

                            <Ellipse.Fill>
                                <ImageBrush ImageSource="/Image/Rift_logo.png" />
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">

                <StackPanel Orientation="Vertical"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center"
                            Margin="0,25,0,0">

                    <TextBlock VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="Loading..."
                               FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                               Foreground="White"
                               FontSize="24">

                    </TextBlock>

                    <StackPanel HorizontalAlignment="left"
                                Orientation="Horizontal"
                                Grid.Row="1"
                                VerticalAlignment="Top"
                                Margin="-8,35,0,0">

                        <Border Width="28"
                                Height="28">

                            <Image Source="/Image/Red.png"
                                   Width="28"
                                   Height="28"
                                   Stretch="UniformToFill" />
                        </Border>

                        <TextBlock Margin="5,5,0,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Text="Guest_user"
                                   FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                                   Foreground="#EBEBEB"
                                   FontSize="19" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>