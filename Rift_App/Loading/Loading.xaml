<Window x:Class="Rift_App.Loading.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Rift_App.Loading"
        xmlns:materialDesign="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Loading"
        Icon="/Image/Rift_icon.ico"
        Width="705"
        Height="438"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="438"
            CornerRadius="18"
            GlassFrameThickness="0"
            ResizeBorderThickness="7" />
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <Storyboard x:Key="SpinBlue" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="BlueGroup"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                From="0"
                To="360"
                Duration="0:0:1.2" />
        </Storyboard>

        <Storyboard x:Key="SpinGray" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="GrayGroup"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                From="0"
                To="360"
                Duration="0:0:0.85" />
        </Storyboard>

        <Storyboard x:Key="FadeAnim" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="SpinnerContainer"
                Storyboard.TargetProperty="Opacity"
                Duration="0:0:4.1">
                <LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.20" Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.50" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:5.20" Value="1" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinBlue}" />
            <BeginStoryboard Storyboard="{StaticResource SpinGray}" />
            <BeginStoryboard Storyboard="{StaticResource FadeAnim}" />
        </EventTrigger>
    </Window.Triggers>

    <Grid>

        <Image Opacity="0.5"
               RenderOptions.BitmapScalingMode="HighQuality"
               Source="/Image/Steam.jpg"
               Stretch="UniformToFill" />

        <MediaElement x:Name="BgVideo"
                      IsHitTestVisible="False"
                      IsMuted="True"
                      LoadedBehavior="Play"
                      Source="Videos\Background_animation.mp4"
                      Stretch="UniformToFill"
                      UnloadedBehavior="Manual" />

        <Border Background="Gray"
                CornerRadius="7.5,7.5,0,0"
                Opacity="0.13" />

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="250" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Bottom">

                    <Grid Width="130"
                          Height="130">

                        <Grid x:Name="SpinnerContainer"
                              Width="130"
                              Height="130">

                            <Grid x:Name="BlueGroup"
                                  Width="130"
                                  Height="130"
                                  RenderTransformOrigin="0.5,0.5">

                                <Grid.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Grid.RenderTransform>

                                <Ellipse Width="130"
                                         Height="130"
                                         StrokeDashArray="51 51"
                                         StrokeDashCap="Round"
                                         StrokeDashOffset="0"
                                         StrokeEndLineCap="Round"
                                         StrokeStartLineCap="Round"
                                         StrokeThickness="4">

                                    <Ellipse.Stroke>
                                        <SolidColorBrush Color="#66CCFF" />
                                    </Ellipse.Stroke>
                                </Ellipse>
                            </Grid>

                            <Grid x:Name="GrayGroup"
                                  Width="130"
                                  Height="130"
                                  RenderTransformOrigin="0.5,0.5">

                                <Grid.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Grid.RenderTransform>

                                <Ellipse Width="130"
                                         Height="130"
                                         StrokeDashArray="45 150"
                                         StrokeDashCap="Round"
                                         StrokeDashOffset="0"
                                         StrokeEndLineCap="Round"
                                         StrokeStartLineCap="Round"
                                         StrokeThickness="3">

                                    <Ellipse.Stroke>
                                        <SolidColorBrush Opacity="0.5"
                                                         Color="#BBBBBB" />
                                    </Ellipse.Stroke>
                                </Ellipse>
                            </Grid>

                        </Grid>

                        <Ellipse Width="105"
                                 Height="105"
                                 StrokeThickness="1.5">

                            <Ellipse.Stroke>
                                <SolidColorBrush Opacity="0.35"
                                                 Color="#83289C" />
                            </Ellipse.Stroke>

                            <Ellipse.Fill>
                                <ImageBrush ImageSource="/Image/Rift_logo.png" />
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="10,25,0,0">

                <TextBlock Margin="-20,0,0,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           FontFamily="/Resources/Noto/NotoSans-Regular.ttf#Noto Sans"
                           FontSize="24"
                           Foreground="White"
                           Text="{Binding LoadingText}" />
            </Grid>
        </Grid>
    </Grid>
</Window>